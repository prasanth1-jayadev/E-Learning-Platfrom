<!DOCTYPE html>

<html class="light" lang="en">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Learnify - Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap"
    rel="stylesheet" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#34D399", // Mint Green
            "background-light": "#F9FAFB",
            "background-dark": "#111827",
            "surface-light": "#FFFFFF",
            "surface-dark": "#1F2937",
          },
          fontFamily: {
            display: ["Inter", "sans-serif"],
          },
          borderRadius: {
            DEFAULT: "0.5rem",
          },
        },
      },
    };
  </script>
</head>

<body
  class="font-display bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 h-screen overflow-hidden flex">

  <%- include('../partials/admin-sidebar') %>

    <main class="flex-1 ml-64 p-8 h-screen overflow-y-auto">
      <header class="flex justify-between items-center mb-10">
        <div>
          <h2 class="text-3xl font-bold text-slate-800 dark:text-white">Dashboard</h2>
          <p class="text-slate-500 dark:text-slate-400 mt-1">Welcome to your admin dashboard</p>
        </div>
        <div class="flex items-center gap-4">
          <div class="relative">
            <button
              class="p-2 bg-surface-light dark:bg-surface-dark border border-slate-200 dark:border-slate-800 rounded-lg relative">
              <span class="material-icons-outlined text-slate-600 dark:text-slate-300">notifications</span>
              <span
                class="absolute top-2 right-2 w-4 h-4 bg-red-500 text-white text-[10px] flex items-center justify-center rounded-full border-2 border-surface-light dark:border-surface-dark">7</span>
            </button>
          </div>
          <button
            class="p-2 bg-surface-light dark:bg-surface-dark border border-slate-200 dark:border-slate-800 rounded-lg"
            onclick="document.documentElement.classList.toggle('dark')">
            <span class="material-icons-outlined text-slate-600 dark:text-slate-300">dark_mode</span>
          </button>
        </div>
      </header>
      <section>
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
          <h3 class="text-xl font-semibold text-slate-800 dark:text-white">Analytics Overview</h3>
          <div class="flex items-center gap-2">
            <button
              class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white text-sm font-medium rounded-lg flex items-center gap-2 transition-colors">
              <span class="material-icons-outlined text-base">picture_as_pdf</span> PDF
            </button>
            <button
              class="px-4 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-lg flex items-center gap-2 transition-colors">
              <span class="material-icons-outlined text-base">file_download</span> Excel
            </button>
          </div>
        </div>
        <div
          class="bg-surface-light dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 mb-8">
          <div class="flex flex-wrap items-center gap-4">
            <div class="flex p-1 bg-slate-100 dark:bg-slate-800 rounded-xl">
              <button class="px-6 py-2 bg-primary text-white rounded-lg text-sm font-medium shadow-sm">This
                Month</button>
              <button
                class="px-6 py-2 text-slate-600 dark:text-slate-400 text-sm font-medium hover:text-slate-900 dark:hover:text-slate-200">Last
                Month</button>
              <button
                class="px-6 py-2 text-slate-600 dark:text-slate-400 text-sm font-medium hover:text-slate-900 dark:hover:text-slate-200">This
                Year</button>
            </div>
            <div class="flex items-center gap-3 ml-auto">
              <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
                <span class="material-icons-outlined text-sm">calendar_today</span>
                <span>Custom Range:</span>
              </div>
              <div class="flex items-center gap-2">
                <input
                  class="bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary focus:border-primary px-3 py-2 w-40"
                  type="date" />
                <span class="text-slate-400 italic">to</span>
                <input
                  class="bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary focus:border-primary px-3 py-2 w-40"
                  type="date" />
                <button
                  class="px-5 py-2 bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300 text-sm font-medium rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">Apply</button>
              </div>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <div
            class="bg-surface-light dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex justify-between items-start">
            <div>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Active Students</p>
              <h4 class="text-3xl font-bold text-slate-800 dark:text-white mt-1">84</h4>
              <p class="text-xs text-slate-400 dark:text-slate-500 mt-2">Total: 86</p>
            </div>
            <div
              class="w-12 h-12 bg-blue-50 dark:bg-blue-900/20 rounded-xl flex items-center justify-center text-blue-500">
              <span class="material-icons-outlined">group</span>
            </div>
          </div>
          <div
            class="bg-surface-light dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex justify-between items-start">
            <div>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Total Tutors</p>
              <h4 class="text-3xl font-bold text-slate-800 dark:text-white mt-1">
                <%= totalTutors %>
              </h4>
              <p class="text-xs text-slate-400 dark:text-slate-500 mt-2">Pending: <%= pendingCount %>
              </p>
            </div>
            <div
              class="w-12 h-12 bg-emerald-50 dark:bg-emerald-900/20 rounded-xl flex items-center justify-center text-emerald-500">
              <span class="material-icons-outlined">school</span>
            </div>
          </div>
          <div
            class="bg-surface-light dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex justify-between items-start">
            <div>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Total Courses</p>
              <h4 class="text-3xl font-bold text-slate-800 dark:text-white mt-1">14</h4>
              <p class="text-xs text-slate-400 dark:text-slate-500 mt-2">Active: 13</p>
            </div>
            <div
              class="w-12 h-12 bg-purple-50 dark:bg-purple-900/20 rounded-xl flex items-center justify-center text-purple-500">
              <span class="material-icons-outlined">menu_book</span>
            </div>
          </div>
          <div
            class="bg-surface-light dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex justify-between items-start">
            <div>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Total Revenue</p>
              <h4 class="text-3xl font-bold text-slate-800 dark:text-white mt-1">Rs.27.6K</h4>
              <p class="text-xs text-slate-400 dark:text-slate-500 mt-2">Orders: 73</p>
            </div>
            <div
              class="w-12 h-12 bg-amber-50 dark:bg-amber-900/20 rounded-xl flex items-center justify-center text-amber-500">
              <span class="material-icons-outlined">payments</span>
            </div>
          </div>
        </div>
        <div
          class="bg-surface-light dark:bg-surface-dark p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800">
          <div class="flex items-center justify-between mb-8">
            <h4 class="text-lg font-bold text-slate-800 dark:text-white">Revenue &amp; Profit Overview</h4>
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-blue-500"></span>
                <span
                  class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Revenue</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-primary"></span>
                <span
                  class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Profit</span>
              </div>
            </div>
          </div>
          <div class="relative h-[300px] w-full mt-4 flex items-end justify-between gap-4 px-2">
            <div class="flex-1 flex flex-col justify-end gap-1 h-full">
              <div class="w-full bg-blue-100 dark:bg-blue-900/20 rounded-t-md relative group h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-blue-500 rounded-t-md h-3/4 transition-all duration-500">
                </div>
              </div>
              <div class="w-full bg-emerald-100 dark:bg-emerald-900/20 rounded-t-md relative group h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-primary rounded-t-md h-2/4 transition-all duration-500">
                </div>
              </div>
              <span class="text-[10px] text-slate-400 text-center mt-2">Jan</span>
            </div>
            <div class="flex-1 flex flex-col justify-end gap-1 h-full">
              <div class="w-full bg-blue-100 dark:bg-blue-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-blue-500 rounded-t-md h-4/5"></div>
              </div>
              <div class="w-full bg-emerald-100 dark:bg-emerald-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-primary rounded-t-md h-3/5"></div>
              </div>
              <span class="text-[10px] text-slate-400 text-center mt-2">Feb</span>
            </div>
            <div class="flex-1 flex flex-col justify-end gap-1 h-full">
              <div class="w-full bg-blue-100 dark:bg-blue-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-blue-500 rounded-t-md h-5/6"></div>
              </div>
              <div class="w-full bg-emerald-100 dark:bg-emerald-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-primary rounded-t-md h-4/6"></div>
              </div>
              <span class="text-[10px] text-slate-400 text-center mt-2">Mar</span>
            </div>
            <div class="flex-1 flex flex-col justify-end gap-1 h-full">
              <div class="w-full bg-blue-100 dark:bg-blue-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-blue-500 rounded-t-md h-2/3"></div>
              </div>
              <div class="w-full bg-emerald-100 dark:bg-emerald-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-primary rounded-t-md h-1/3"></div>
              </div>
              <span class="text-[10px] text-slate-400 text-center mt-2">Apr</span>
            </div>
            <div class="flex-1 flex flex-col justify-end gap-1 h-full">
              <div class="w-full bg-blue-100 dark:bg-blue-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-blue-500 rounded-t-md h-full"></div>
              </div>
              <div class="w-full bg-emerald-100 dark:bg-emerald-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-primary rounded-t-md h-4/5"></div>
              </div>
              <span class="text-[10px] text-slate-400 text-center mt-2">May</span>
            </div>
            <div class="flex-1 flex flex-col justify-end gap-1 h-full">
              <div class="w-full bg-blue-100 dark:bg-blue-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-blue-500 rounded-t-md h-3/4"></div>
              </div>
              <div class="w-full bg-emerald-100 dark:bg-emerald-900/20 rounded-t-md relative h-1/2">
                <div class="absolute bottom-0 left-0 w-full bg-primary rounded-t-md h-1/2"></div>
              </div>
              <span class="text-[10px] text-slate-400 text-center mt-2">Jun</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Admin Session Management Script -->
    <script src="/js/admin-session.js"></script>
</body>

</html>