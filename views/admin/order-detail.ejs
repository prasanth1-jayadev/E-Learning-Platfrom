<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Order Details - Learnify</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#00d9b1",
                        "background-light": "#F9FAFB",
                        "background-dark": "#111827",
                        "surface-light": "#FFFFFF",
                        "surface-dark": "#1F2937",
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"],
                    },
                },
            },
        };
    </script>
</head>

<body class="font-display bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 h-screen overflow-hidden flex">

    <%- include('../partials/admin-sidebar') %>

    <main class="flex-1 ml-64 p-8 h-screen overflow-y-auto">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-4">
                <button onclick="window.location.href='/admin/orders'" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors">
                    <span class="material-icons-outlined text-slate-600 dark:text-slate-400">arrow_back</span>
                </button>
                <div>
                    <h2 class="text-3xl font-bold text-slate-800 dark:text-white">Order Details</h2>
                    <p class="text-slate-500 dark:text-slate-400 mt-1">View complete order information</p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <!-- Download Invoice Button -->
                <a href="/user/invoice/<%= order.orderId %>" 
                   class="inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors">
                    <span class="material-icons-outlined text-sm">download</span>
                    Invoice
                </a>
                
                <button class="p-2 bg-surface-light dark:bg-surface-dark border border-slate-200 dark:border-slate-800 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors" onclick="document.documentElement.classList.toggle('dark')">
                    <span class="material-icons-outlined text-slate-600 dark:text-slate-300">dark_mode</span>
                </button>
            </div>
        </div>

        <!-- Order Overview -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
            <!-- Order Information -->
            <div class="lg:col-span-2 bg-surface-light dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-4 flex items-center gap-2">
                    <span class="material-icons-outlined text-primary">receipt_long</span>
                    Order Information
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Order ID</p>
                        <p class="text-sm font-mono font-medium text-slate-800 dark:text-white"><%= order.orderId %></p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Payment ID</p>
                        <p class="text-sm font-mono font-medium text-slate-800 dark:text-white"><%= order.paymentId %></p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Amount</p>
                        <p class="text-xl font-bold text-primary">₹<%= (order.amount / 100).toLocaleString('en-IN') %></p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Status</p>
                        <span class="inline-block px-3 py-1 text-sm font-medium rounded-full <%= order.status === 'completed' ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : order.status === 'pending' ? 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' : 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400' %>">
                            <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                        </span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Payment Method</p>
                        <p class="text-sm font-medium text-slate-800 dark:text-white"><%= order.paymentMethod || 'Razorpay' %></p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Currency</p>
                        <p class="text-sm font-medium text-slate-800 dark:text-white"><%= order.currency %></p>
                    </div>
                    <div class="col-span-2">
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Order Date</p>
                        <p class="text-sm font-medium text-slate-800 dark:text-white"><%= new Date(order.createdAt).toLocaleString('en-US', { dateStyle: 'full', timeStyle: 'short' }) %></p>
                    </div>
                </div>
            </div>

            <!-- Status Update Card -->
            <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-4 flex items-center gap-2">
                    <span class="material-icons-outlined text-primary">edit</span>
                    Update Status
                </h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Order Status</label>
                        <select id="statusSelect" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                            <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                            <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
                            <option value="failed" <%= order.status === 'failed' ? 'selected' : '' %>>Failed</option>
                        </select>
                    </div>
                    <button onclick="updateStatus()" class="w-full px-4 py-2.5 bg-primary hover:bg-[#00c9a1] text-white rounded-lg font-medium transition-colors flex items-center justify-center gap-2">
                        <span class="material-icons-outlined text-[20px]">check_circle</span>
                        Update Status
                    </button>
                </div>
            </div>
        </div>

        <!-- Customer Information -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-800 p-6 mb-6">
            <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-4 flex items-center gap-2">
                <span class="material-icons-outlined text-primary">person</span>
                Customer Details
            </h3>
            <div class="flex items-center gap-4">
                <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(order.user?.fullName || 'User') %>&background=00d9b1&color=fff&size=64" alt="<%= order.user?.fullName %>" class="w-16 h-16 rounded-full" />
                <div class="flex-1">
                    <h4 class="font-semibold text-slate-800 dark:text-white text-lg"><%= order.user?.fullName || 'Unknown User' %></h4>
                    <p class="text-sm text-slate-500 dark:text-slate-400"><%= order.user?.email || 'N/A' %></p>
                </div>
                <button onclick="window.location.href='/admin/students'" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-medium transition-colors">
                    View Profile
                </button>
            </div>
        </div>

        <!-- Course Information -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-800 p-6 mb-6">
            <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-4 flex items-center gap-2">
                <span class="material-icons-outlined text-primary">menu_book</span>
                Course Purchased
            </h3>
            <div class="flex items-start gap-4">
                <img src="<%= order.course?.thumbnail || 'https://via.placeholder.com/120x80?text=No+Image' %>" alt="<%= order.course?.title %>" class="w-32 h-20 object-cover rounded-lg flex-shrink-0" />
                <div class="flex-1">
                    <h4 class="font-semibold text-slate-800 dark:text-white text-lg mb-2"><%= order.course?.title || 'N/A' %></h4>
                    <div class="flex items-center gap-4 text-sm text-slate-600 dark:text-slate-400">
                        <div class="flex items-center gap-1">
                            <span class="material-icons-outlined text-[18px]">person</span>
                            <span>Tutor: <%= order.course?.tutor?.fullName || 'Unknown' %></span>
                        </div>
                        <div class="flex items-center gap-1">
                            <span class="material-icons-outlined text-[18px]">payments</span>
                            <span class="font-semibold text-primary">₹<%= order.course?.price || 0 %></span>
                        </div>
                    </div>
                </div>
                <button onclick="window.location.href='/admin/course/<%= order.course?._id %>'" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-medium transition-colors">
                    View Course
                </button>
            </div>
        </div>

        <!-- Payment Details -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-800 p-6">
            <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-4 flex items-center gap-2">
                <span class="material-icons-outlined text-primary">payment</span>
                Payment Details
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg">
                    <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Razorpay Order ID</p>
                    <p class="text-sm font-mono font-medium text-slate-800 dark:text-white break-all"><%= order.orderId %></p>
                </div>
                <div class="p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg">
                    <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Razorpay Payment ID</p>
                    <p class="text-sm font-mono font-medium text-slate-800 dark:text-white break-all"><%= order.paymentId %></p>
                </div>
                <div class="p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg md:col-span-2">
                    <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">Payment Signature</p>
                    <p class="text-sm font-mono font-medium text-slate-800 dark:text-white break-all"><%= order.signature %></p>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function updateStatus() {
            const newStatus = document.getElementById('statusSelect').value;
            const currentStatus = '<%= order.status %>';
            
            if (newStatus === currentStatus) {
                Swal.fire({
                    icon: 'info',
                    title: 'No Change',
                    text: 'Status is already set to ' + newStatus,
                    confirmButtonColor: '#00d9b1'
                });
                return;
            }
            
            const result = await Swal.fire({
                title: 'Update Order Status?',
                text: `Change status from "${currentStatus}" to "${newStatus}"?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#00d9b1',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Yes, update it',
                cancelButtonText: 'Cancel'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch('/admin/order/<%= order._id %>/update-status', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status: newStatus })
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Updated!',
                            text: data.message,
                            confirmButtonColor: '#00d9b1'
                        }).then(() => location.reload());
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: data.message,
                            confirmButtonColor: '#00d9b1'
                        });
                    }
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'Something went wrong',
                        confirmButtonColor: '#00d9b1'
                    });
                }
            }
        }
    </script>

    <script src="/js/admin-session.js"></script>
</body>

</html>
