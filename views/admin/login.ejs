<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Learnify - Admin Login</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2beead",
                        "background-light": "#f6f8f7",
                        "background-dark": "#10221c",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .geometric-pattern {
            background-color: #10221c;
            background-image: radial-gradient(#2beead 0.5px, transparent 0.5px), radial-gradient(#2beead 0.5px, #10221c 0.5px);
            background-size: 20px 20px;
            background-position: 0 0, 10px 10px;
            opacity: 0.1;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display h-screen overflow-hidden">
    <div class="flex h-screen w-full overflow-hidden">
        <!-- Sidebar Section (Left) -->
        <div
            class="hidden lg:flex flex-col w-[400px] bg-background-dark relative border-r border-white/10 h-full overflow-hidden">
            <!-- Subtle Geometric Pattern Overlay -->
            <div class="absolute inset-0 geometric-pattern"></div>
            <div class="relative z-10 flex flex-col h-full p-10 justify-between">
                <div class="flex flex-col gap-8">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center">
                            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/>
                                <circle cx="12" cy="12" r="1.5" fill="white"/>
                            </svg>
                        </div>
                        <div class="flex flex-col">
                            <div class="flex items-center">
                                <span class="text-xl font-bold text-white">Learn</span>
                                <span class="text-xl font-bold text-primary">ify</span>
                            </div>
                            <p class="text-primary text-xs font-semibold uppercase tracking-widest -mt-0.5">Admin Panel</p>
                        </div>
                    </div>
                    <div class="mt-20">
                        <h2 class="text-white text-3xl font-bold leading-tight mb-4">Elevate your e-learning management.
                        </h2>
                        <p class="text-gray-400 text-sm leading-relaxed max-w-[280px]">
                            Access the administrative dashboard to monitor courses, manage users, and analyze
                            performance data in real-time.
                        </p>
                    </div>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white/5 border border-white/10">
                        <span class="material-symbols-outlined text-primary">admin_panel_settings</span>
                        <p class="text-white text-sm font-medium">Secure Admin Gateway</p>
                    </div>
                    <p class="text-gray-500 text-[10px] uppercase tracking-tighter text-center">Authorized Personnel
                        Only</p>
                </div>
            </div>
        </div>
        <!-- Login Form Section (Right) -->
        <div
            class="flex-1 flex flex-col h-full overflow-y-auto justify-center items-center bg-white dark:bg-background-dark/50 relative px-6">
            <!-- Mobile Logo (Shown only on small screens) -->
            <div class="lg:hidden absolute top-8 left-8 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">eco</span>
                <span class="text-background-dark font-bold text-lg">Learnify</span>
            </div>
            <div class="w-full max-w-[420px] flex flex-col">
                <!-- HeadlineText Component -->
                <div class="mb-8">
                    <h1 class="text-[#111816] dark:text-white tracking-tight text-[32px] font-bold leading-tight">Admin
                        Login</h1>
                    <p class="text-[#61897c] text-sm mt-2">Welcome back. Please enter your administrative credentials.
                    </p>
                </div>
                <form class="flex flex-col gap-2" id="adminLoginForm" action="/admin/login" method="POST">
                    <!-- TextField Component: Email -->
                    <div class="flex flex-col w-full py-2">
                        <label class="flex flex-col">
                            <p class="text-[#111816] dark:text-gray-300 text-sm font-semibold leading-normal pb-2">Admin
                                Email</p>
                            <div class="relative">
                                <input
                                    class="form-input flex w-full rounded-lg text-[#111816] focus:outline-0 focus:ring-2 focus:ring-primary/20 border border-[#dbe6e2] dark:border-white/10 bg-white dark:bg-transparent focus:border-primary h-14 placeholder:text-[#61897c]/50 p-[15px] pl-11 text-base font-normal"
                                    placeholder="admin@organiclearn.com" type="email" name="email" value="" required />
                                <span
                                    class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#61897c]">mail</span>
                            </div>
                        </label>
                    </div>
                    <!-- TextField Component: Password -->
                    <div class="flex flex-col w-full py-2">
                        <label class="flex flex-col">
                            <p class="text-[#111816] dark:text-gray-300 text-sm font-semibold leading-normal pb-2">
                                Password</p>
                            <div class="flex w-full items-stretch rounded-lg relative">
                                <span
                                    class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#61897c] z-10">lock</span>
                                <input
                                    class="form-input flex w-full rounded-lg text-[#111816] focus:outline-0 focus:ring-2 focus:ring-primary/20 border border-[#dbe6e2] dark:border-white/10 bg-white dark:bg-transparent focus:border-primary h-14 placeholder:text-[#61897c]/50 p-[15px] pl-11 pr-12 text-base font-normal"
                                    placeholder="Enter secure password" type="password" name="password" value=""
                                    required />
                                <button
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-[#61897c] hover:text-background-dark focus:outline-none"
                                    type="button"
                                    onclick="togglePasswordVisibility(this)">
                                    <svg id="aEyeOpen" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                                        stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    </svg>
                                    <svg id="aEyeClosed" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24"
                                        stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.477 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                                    </svg>
                                </button>
                            </div>
                        </label>
                    </div>
                    <!-- MetaText Component -->
                    <div class="flex justify-between items-center py-2">
                        <a class="text-[#61897c] hover:text-background-dark text-xs font-medium underline transition-colors"
                            href="#">Forgot Admin Password?</a>
                    </div>
                    <!-- Submit Button -->
                    <div class="mt-6">
                        <button
                            class="w-full bg-primary hover:bg-primary/90 text-background-dark font-bold py-4 px-6 rounded-lg flex items-center justify-center gap-2 transition-all shadow-lg shadow-primary/10"
                            type="submit">
                            <span class="material-symbols-outlined">verified_user</span>
                            Secure Login
                        </button>
                    </div>
                </form>
                <div class="mt-12 flex items-center justify-center gap-6 border-t border-gray-100 pt-8">
                    <div class="flex items-center gap-1 opacity-40">
                        <span class="material-symbols-outlined text-xs">encrypted</span>
                        <span class="text-[10px] font-bold uppercase tracking-wider">256-Bit SSL</span>
                    </div>
                    <div class="flex items-center gap-1 opacity-40">
                        <span class="material-symbols-outlined text-xs">shield</span>
                        <span class="text-[10px] font-bold uppercase tracking-wider">Protected Access</span>
                    </div>
                </div>
            </div>
            <script>
                // Simple, direct approach
                function handleLogin(event) {
                    event.preventDefault();
                    
                    const email = document.querySelector('input[name="email"]').value.trim();
                    const password = document.querySelector('input[name="password"]').value.trim();
                    
                    if (!email || !password) {
                        showToast('Please fill in all fields', 'error');
                        return false;
                    }
                    
                    const submitBtn = document.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.disabled = true;
                        submitBtn.innerHTML = 'Logging in...';
                    }
                    
                    fetch('/admin/login', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ email, password })
                    })
                    .then(response => {
                        return response.json();
                    })
                    .then(data => {
                        if (data.redirect) {
                            window.location.href = data.redirect;
                        } else {
                            showToast(data.message || 'Login failed', 'error');
                        }
                    })
                    .catch(error => {
                        showToast('Network error. Please try again.', 'error');
                    })
                    .finally(() => {
                        if (submitBtn) {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = '<span class="material-symbols-outlined">verified_user</span> Secure Login';
                        }
                    });
                    
                    return false;
                }
                
                // Set up form handler when page loads
                window.onload = function() {
                    const form = document.getElementById('adminLoginForm');
                    if (form) {
                        form.onsubmit = handleLogin;
                    }
                };

                // Password toggle functionality
                function togglePasswordVisibility(button) {
                    const input = button.closest('div').querySelector('input');
                    const eyeOpen = document.getElementById('aEyeOpen');
                    const eyeClosed = document.getElementById('aEyeClosed');
                    
                    if (input && eyeOpen && eyeClosed) {
                        if (input.type === 'password') {
                            input.type = 'text';
                            eyeOpen.classList.add('hidden');
                            eyeClosed.classList.remove('hidden');
                        } else {
                            input.type = 'password';
                            eyeOpen.classList.remove('hidden');
                            eyeClosed.classList.add('hidden');
                        }
                    }
                }
            </script>
            <!-- Visual Decoration (Floating Image) -->
            <div class="absolute bottom-8 right-8 pointer-events-none opacity-10">
                <img alt="Abstract security shield pattern" class="w-32 h-32"
                    data-alt="Abstract security shield pattern icon"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuDpMb1F3ZS9w_5aRE0hK1XJok9X1sv4RsO8vRMfF0DqnTow2Rl-lHQvX1LZI_UWJQ5fUQ_156H_UhTIacNfeMqedWwP-6sbGsCvOtsuCUSxNX32QfBBSlwIFMK4kihJ-1qXAEHJvtGL-kI4M99RsuDFVEC2H4aova1A66S-jP--Bq617PTxMjgLv93dNArGV-LHQlO91bYKpRqQWZa-Eqt4IW38XpJ7ABqrY8tIX_wkvmRUzpzK-N9zr35QgJQ_xodkR-JjUsRiBEU" />
            </div>
        </div>
    </div>

    <!-- Admin Session Management Script -->
    <script src="/js/admin-session.js"></script>
    
    <%- include('../partials/toast') %>
</body>

</html>