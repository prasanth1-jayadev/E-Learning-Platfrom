<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Courses - Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#34D399",
                        "background-light": "#F9FAFB",
                        "background-dark": "#111827",
                        "surface-light": "#FFFFFF",
                        "surface-dark": "#1F2937",
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"],
                    },
                },
            },
        };
    </script>
</head>
<body class="font-display bg-background-light text-slate-900 h-screen overflow-hidden flex">
    
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8 h-screen overflow-y-auto">
        <header class="mb-8">
            <h2 class="text-3xl font-bold text-slate-800">Courses</h2>
            <p class="text-slate-500 mt-1">Manage all courses in the platform</p>
        </header>

        <!-- Coming Soon -->
        <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
            <span class="material-icons-outlined text-6xl text-slate-300 mb-4">menu_book</span>
            <h3 class="text-xl font-semibold text-slate-600 mb-2">Course Management</h3>
            <p class="text-slate-500 mb-6">This feature is coming soon. You'll be able to view and manage all courses created by tutors here.</p>
            <button class="px-6 py-3 bg-primary text-white rounded-lg hover:bg-green-600 font-medium">
                View All Courses
            </button>
        </div>
    </main>

    <!-- Admin Session Management Script -->
    <script src="/js/admin-session.js"></script>
</body>
</html>