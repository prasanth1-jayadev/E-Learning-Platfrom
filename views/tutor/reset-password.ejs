                    <img alt="User" class="w-12 h-12 rounded-full border-2 border-deep-forest"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCEXqTcMxDdzsEleuhT33b0HIGwge2EOsNa2Bm0z9PqiUPB1-2hjlCr1YaI_TbhYeWN3uvtrzsXyNNleqm8fo3swfdkFAqIzqJXzpDeDstoqIGFrz4QeuVBGXjWyLUfwIF1s66C4S6uRyfDPzh2iG1CklETTjHB2r7k5eB1Cp7ZSvr6OOyFhuC5HNGVnPUIkrYvlcSy2-ck6zEPOomlhNJ-ydL7_6j7HWl1tQPgjZP4rCAO6jRI3OkzbSMpFPF9YrbFnwVFyioXLxE" />
                    <div
                        class="w-12 h-12 rounded-full bg-primary flex items-center justify-center text-xs font-bold border-2 border-deep-forest text-deep-forest">
                        +50k</div>
                </div>
                <p class="text-sm font-medium text-white/80 italic">"The transition from student to master happens
                    here." — Career Graduate</p>
            </div>
        </section>
        <section class="flex flex-col bg-white dark:bg-background-dark overflow-y-auto h-full">
            <div class="flex-1 flex flex-col justify-center px-6 py-8 md:px-16 lg:px-20">
                <div class="max-w-md mx-auto w-full">
                    <div class="flex items-center justify-between mb-12 max-w-[240px] mx-auto">
                        <div class="flex items-center w-full">
                            <div
                                class="w-8 h-8 rounded-full border-2 border-primary text-primary flex items-center justify-center font-bold text-sm bg-primary/5">
                                1</div>
                            <div class="flex-1 h-[2px] bg-primary"></div>
                            <div
                                class="w-8 h-8 rounded-full border-2 border-primary text-primary flex items-center justify-center font-bold text-sm bg-primary/5">
                                2</div>
                            <div class="flex-1 h-[2px] bg-primary"></div>
                            <div
                                class="w-10 h-10 rounded-full bg-primary text-[#0d1b17] flex items-center justify-center font-bold text-lg step-glow ring-4 ring-primary/20">
                                3</div>
                        </div>
                    </div>
                    <div class="mb-10">
                        <h2 class="text-3xl font-black mb-2 text-[#0d1b17] dark:text-white">Final Step</h2>
                        <p class="text-[#4c9a80] dark:text-[#a0c5ba]">Set your new password to complete the recovery
                            process.</p>
                    </div>
                    <form class="flex flex-col gap-6 mb-8" id="tutorResetForm">
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-bold opacity-70" for="new_password">New Password</label>
                            <input
                                class="w-full bg-background-light dark:bg-[#1a3a30] border-[#e7f3ef] dark:border-[#1a3a30] rounded-xl px-4 py-3 focus:ring-primary focus:border-primary text-[#0d1b17] dark:text-white"
                                id="new_password" placeholder="At least 8 characters" type="password" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-bold opacity-70" for="confirm_password">Confirm New
                                Password</label>
                            <input
                                class="w-full bg-background-light dark:bg-[#1a3a30] border-[#e7f3ef] dark:border-[#1a3a30] rounded-xl px-4 py-3 focus:ring-primary focus:border-primary text-[#0d1b17] dark:text-white"
                                id="confirm_password" placeholder="Repeat your new password" type="password" />
                        </div>
                        <button
                            class="bg-primary text-[#0d1b17] py-4 rounded-xl font-black text-lg shadow-xl shadow-primary/20 hover:scale-[1.01] transition-transform mt-4"
                            type="submit">
                            Update Password
                        </button>
                    </form>
                    <script>
                        document.getElementById('tutorResetForm').addEventListener('submit', async function (e) {
                            e.preventDefault();
                            const password = document.getElementById('new_password').value;
                            const confirm  = document.getElementById('confirm_password').value;

                            if (!password || password.length < 8) {
                                showToast('Password must be at least 8 characters.', 'error'); return;
                            }
                            if (password !== confirm) {
                                showToast('Passwords do not match.', 'error'); return;
                            }

                            const res = await fetch('/tutor/reset-password', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ password })
                            });
                            const data = await res.json();
                            if (res.ok) {
                                showToast('Password reset successfully!', 'success');
                                setTimeout(() => window.location.href = data.redirect || '/tutor/login', 1500);
                            } else {
                                showToast(data.message || 'Password reset failed', 'error');
                            }
                        });
                    </script>
                    <!-- <div class="p-4 bg-primary/10 border border-primary/20 rounded-xl flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary">check_circle</span>
                        <p class="text-sm font-medium text-[#0d1b17] dark:text-[#a0c5ba]">
                            Ready to go? Once updated, you can <a class="text-primary font-bold hover:underline"
                                href="/tutor/login">login</a> immediately.
                        </p>
                    </div> -->
