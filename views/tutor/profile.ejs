<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tutor Profile - Organic Learn</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { primary: '#2beead' },
          fontFamily: { display: ['Be Vietnam Pro', 'sans-serif'] }
        }
      }
    }
  </script>
</head>
<body class="font-display bg-[#f0f4f3] min-h-screen flex flex-col">

<!-- Navbar -->
<nav class="bg-white border-b border-gray-100 px-8 py-3 flex items-center justify-between sticky top-0 z-50">
  <div class="flex items-center gap-2">
    <div class="w-7 h-7 bg-primary/20 rounded-lg flex items-center justify-center">
      <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 48 48"><path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z"/></svg>
    </div>
    <span class="font-bold text-sm"><span class="text-primary">Organic</span> Learn</span>
  </div>
  <div class="flex items-center gap-3">
    <button class="text-gray-400 hover:text-gray-600">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
    </button>
    <div class="flex items-center gap-2">
      <div class="text-right">
        <p class="text-xs font-bold text-gray-800">Prasanth B jayadev</p>
        <p class="text-[10px] text-primary">Tutor</p>
      </div>
      <div class="w-8 h-8 rounded-full bg-amber-200 overflow-hidden">
        <svg class="w-full h-full text-amber-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
      </div>
    </div>
  </div>
</nav>

<!-- Main -->
<div class="flex-1 max-w-5xl mx-auto w-full px-6 py-8 flex gap-6 items-start">

  <%- include('../partials/tutor-sidebar') %>

  <!-- Profile Settings Card -->
  <div class="flex-1">
    <div class="bg-white rounded-2xl shadow-sm p-7 mb-5">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold text-gray-900">Profile Settings</h2>
        <button id="editBtn" onclick="toggleEdit()" class="flex items-center gap-2 bg-primary text-gray-900 text-xs font-bold px-4 py-2 rounded-lg hover:brightness-110 transition">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          <span id="editBtnText">Edit Profile</span>
        </button>
      </div>

      <!-- Avatar -->
      <div class="flex justify-center mb-7">
        <div class="relative">
          <div class="w-20 h-20 rounded-full bg-gray-700 overflow-hidden border-2 border-gray-200">
            <svg class="w-full h-full text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
          </div>
          <div class="absolute bottom-0 right-0 w-5 h-5 bg-primary rounded-full border-2 border-white flex items-center justify-center">
            <svg class="w-2.5 h-2.5 text-gray-900" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12z"/></svg>
          </div>
        </div>
      </div>

      <div class="space-y-5">
        <!-- Name -->
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5">Name</label>
          <input type="text" id="fullName" value="<%= tutor.fullName %>" readonly
            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none focus:border-primary focus:bg-white transition"/>
        </div>

        <!-- Email -->
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5">Email</label>
          <div class="flex gap-3">
            <input type="email" value="<%= tutor.email %>" readonly
              class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none"/>
            <button onclick="openEmailModal()" class="px-4 py-2.5 border border-primary text-primary text-xs font-bold rounded-lg hover:bg-primary/5 transition whitespace-nowrap">
              Change Email
            </button>
          </div>
          <p class="text-[11px] text-gray-400 mt-1.5 flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Email changes require verification for security
          </p>
        </div>

        <!-- Phone -->
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5">Phone</label>
          <input type="text" id="phone" value="<%= tutor.phone || '' %>" placeholder="Enter your phone number" readonly
            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none focus:border-primary focus:bg-white transition"/>
        </div>

        <!-- Subjects Teaching -->
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5">Subjects Teaching</label>
          <input type="text" id="subjects" value="<%= tutor.subjects || '' %>" placeholder="e.g., Mathematics, Physics, Chemistry" readonly
            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none focus:border-primary focus:bg-white transition"/>
        </div>

        <!-- Bio -->
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1.5">Bio</label>
          <textarea id="bio" rows="4" placeholder="Tell students about yourself, your teaching experience, and approach..." readonly
            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none focus:border-primary focus:bg-white resize-none transition"><%= tutor.bio || '' %></textarea>
          <div class="flex justify-between mt-1">
            <p class="text-[11px] text-gray-400">Maximum 500 characters</p>
            <p class="text-[11px] text-gray-400"><span id="bioCount">0</span>/500</p>
          </div>
        </div>

        <!-- Save Button (Hidden by default) -->
        <div id="saveSection" class="hidden pt-2">
          <button onclick="saveProfile()" class="w-full bg-primary text-gray-900 py-3 rounded-lg font-bold hover:brightness-110 transition">
            Save Changes
          </button>
        </div>

        <!-- Change Password -->
        <div class="pt-2 flex justify-center">
          <button class="flex items-center gap-2 px-5 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-600 font-medium hover:bg-gray-50 transition">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
            Change Password
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

