<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tutor Dashboard - Learnify</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#00d9b1',
            'background-light': '#F9FAFB'
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif']
          }
        }
      }
    }
  </script>
</head>
<body class="bg-background-light">

<%- include('../partials/tutor-sidebar', { tutor: tutor, currentPage: 'dashboard' }) %>

<!-- Main Content -->
<main class="tutor-main-content p-6 min-h-screen">
  
  <% if (!isApproved) { %>
    <% if (tutor.approvalStatus === 'rejected') { %>
      <!-- Rejection & Re-upload Form Banner -->
      <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded-lg mb-6">
        <div class="flex items-start gap-4 mb-4">
          <div class="flex-shrink-0">
            <span class="material-icons-outlined text-red-600 text-3xl">cancel</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-red-900 mb-1">Application Rejected</h3>
            <p class="text-red-800 leading-relaxed">Unfortunately, your tutor application was not approved. Please re-upload a clear certificate to resubmit your application for review.</p>
          </div>
        </div>
        
        <!-- Re-upload Form -->
        <form id="resubmitForm" class="mt-4 max-w-md bg-white p-4 rounded-lg border border-red-200">
          <label class="block text-sm font-medium text-gray-700 mb-2">Upload Professional Certificate (PDF, PNG, JPG)</label>
          <input type="file" id="newCertificateFile" accept=".pdf,.png,.jpg,.jpeg" required
                 class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-red-50 file:text-red-700 hover:file:bg-red-100 mb-3"/>
          <button type="submit" class="w-full py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-semibold transition">
            Resubmit Application
          </button>
        </form>
      </div>
    <% } else { %>
      <!-- Approval Pending Banner -->
      <div class="bg-amber-50 border-l-4 border-amber-400 p-6 rounded-lg mb-6 flex items-start gap-4">
        <div class="flex-shrink-0">
          <span class="material-icons-outlined text-amber-600 text-3xl">warning</span>
        </div>
        <div>
          <h3 class="text-lg font-bold text-amber-900 mb-2">Account Under Review</h3>
          <p class="text-amber-800 leading-relaxed">Your tutor application is currently being reviewed by our admin team. Once approved, you'll have access to all tutor features including course creation, student management, and earnings tracking.</p>
        </div>
      </div>
    <% } %>
  <% } else { %>

  <!-- Dashboard Header -->
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Analytics Overview</h1>
    <p class="text-gray-600">Welcome back, <%= tutor.fullName %>! Here's your performance summary.</p>
  </div>

  <!-- Time Range Filter -->
  <div class="flex gap-2 mb-6">
    <button class="px-4 py-2 bg-primary text-white rounded-lg font-medium text-sm">Last Week</button>
    <button class="px-4 py-2 bg-white text-gray-700 rounded-lg font-medium text-sm hover:bg-gray-50">Last Month</button>
    <button class="px-4 py-2 bg-white text-gray-700 rounded-lg font-medium text-sm hover:bg-gray-50">Last 3 Months</button>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <!-- Total Students -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center">
          <span class="material-icons-outlined text-blue-600">people</span>
        </div>
        <span class="material-icons-outlined text-gray-400">trending_up</span>
      </div>
      <h3 class="text-sm font-medium text-gray-600 mb-1">Total Students</h3>
      <p class="text-3xl font-bold text-gray-900"><%= stats.totalStudents || 0 %></p>
      <p class="text-xs text-green-600 mt-2">+12% from last month</p>
    </div>

    <!-- Total Courses -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 bg-cyan-50 rounded-lg flex items-center justify-center">
          <span class="material-icons-outlined text-cyan-600">menu_book</span>
        </div>
        <span class="material-icons-outlined text-gray-400">trending_up</span>
      </div>
      <h3 class="text-sm font-medium text-gray-600 mb-1">Total Courses</h3>
      <p class="text-3xl font-bold text-gray-900"><%= stats.totalCourses || 0 %></p>
      <p class="text-xs text-gray-500 mt-2"><%= stats.publishedCourses || 0 %> published</p>
    </div>

    <!-- Active Courses -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center">
          <span class="material-icons-outlined text-green-600">check_circle</span>
        </div>
        <span class="material-icons-outlined text-gray-400">trending_up</span>
      </div>
      <h3 class="text-sm font-medium text-gray-600 mb-1">Active Courses</h3>
      <p class="text-3xl font-bold text-gray-900"><%= stats.publishedCourses || 0 %></p>
      <p class="text-xs text-gray-500 mt-2">Currently live</p>
    </div>

    <!-- Total Revenue -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <div class="w-12 h-12 bg-purple-50 rounded-lg flex items-center justify-center">
          <span class="material-icons-outlined text-purple-600">account_balance_wallet</span>
        </div>
        <span class="material-icons-outlined text-gray-400">trending_up</span>
      </div>
      <h3 class="text-sm font-medium text-gray-600 mb-1">Total Revenue</h3>
      <p class="text-3xl font-bold text-gray-900">₹<%= (stats.totalRevenue || 0).toLocaleString('en-IN') %></p>
      <p class="text-xs text-green-600 mt-2">+8% from last month</p>
    </div>
  </div>

  <!-- Charts Section -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    
    <!-- Revenue & Profit Overview -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold text-gray-900">Revenue & Profit Overview</h2>
        <div class="flex gap-4 text-sm">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
            <span class="text-gray-600">Revenue</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-cyan-500 rounded-full"></div>
            <span class="text-gray-600">Profit</span>
          </div>
        </div>
      </div>
      <div class="h-64">
        <canvas id="revenueChart"></canvas>
      </div>
    </div>

    <!-- Course Performance -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-bold text-gray-900 mb-6">Course Performance</h2>
      <div class="h-64 flex items-center justify-center">
        <canvas id="coursePerformanceChart"></canvas>
      </div>
    </div>

  </div>

  <!-- Key Metrics Chart -->
  <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 mb-6">
    <h2 class="text-lg font-bold text-gray-900 mb-6">Key Metrics</h2>
    <div class="h-64">
      <canvas id="keyMetricsChart"></canvas>
    </div>
  </div>

  <!-- Course Management Table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-lg font-bold text-gray-900">Course Management</h2>
      <a href="/tutor/courses/create" class="px-4 py-2 bg-primary text-white rounded-lg font-medium text-sm hover:bg-primary/90 transition flex items-center gap-2">
        <span class="material-icons-outlined text-sm">add</span>
        New Course
      </a>
    </div>
    
    <% if (recentCourses && recentCourses.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Course</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Students</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% recentCourses.forEach(course => { %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <% if (course.thumbnail) { %>
                  <img src="<%= course.thumbnail %>" alt="<%= course.title %>" class="w-12 h-12 rounded-lg object-cover">
                <% } else { %>
                  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
                    <span class="material-icons-outlined text-primary">menu_book</span>
                  </div>
                <% } %>
                <div>
                  <p class="font-semibold text-gray-900"><%= course.title %></p>
                  <p class="text-sm text-gray-500"><%= course.lessons.length %> lessons</p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs font-medium">
                <%= course.category %>
              </span>
            </td>
            <td class="px-6 py-4 text-gray-900 font-medium">
              <%= course.enrolledStudents.length %>
            </td>
            <td class="px-6 py-4 text-gray-900 font-semibold">
              ₹<%= course.price.toLocaleString('en-IN') %>
            </td>
            <td class="px-6 py-4">
              <% if (course.isPublished) { %>
                <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium flex items-center gap-1 w-fit">
                  <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                  Published
                </span>
              <% } else { %>
                <span class="px-3 py-1 bg-amber-100 text-amber-700 rounded-full text-xs font-medium flex items-center gap-1 w-fit">
                  <span class="w-1.5 h-1.5 bg-amber-500 rounded-full"></span>
                  Draft
                </span>
              <% } %>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center gap-2">
                <a href="/tutor/courses/<%= course._id %>/edit" class="p-2 text-gray-600 hover:text-primary hover:bg-primary/10 rounded-lg transition" title="Edit">
                  <span class="material-icons-outlined text-sm">edit</span>
                </a>
                <a href="/tutor/courses/<%= course._id %>" class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition" title="View">
                  <span class="material-icons-outlined text-sm">visibility</span>
                </a>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="p-12 text-center">
      <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="material-icons-outlined text-gray-400 text-4xl">menu_book</span>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">No courses yet</h3>
      <p class="text-gray-600 mb-6">Start creating your first course to share your knowledge with students.</p>
      <a href="/tutor/courses/create" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition">
        <span class="material-icons-outlined">add</span>
        Create Your First Course
      </a>
    </div>
    <% } %>
  </div>

  <% } %>
</main>

<!-- Chart.js Configuration -->
<script>
  <% if (isApproved) { %>
  // Chart colors
  const primaryColor = '#00d9b1';
  const secondaryColor = '#06b6d4';
  const chartColors = ['#3b82f6', '#06b6d4', '#8b5cf6', '#f59e0b', '#10b981', '#ef4444'];

  // Revenue & Profit Chart
  const revenueCtx = document.getElementById('revenueChart').getContext('2d');
  new Chart(revenueCtx, {
    type: 'line',
    data: {
      labels: <%- JSON.stringify(analytics.revenueData.labels) %>,
      datasets: [
        {
          label: 'Revenue',
          data: <%- JSON.stringify(analytics.revenueData.revenue) %>,
          borderColor: '#3b82f6',
          backgroundColor: 'rgba(59, 130, 246, 0.1)',
          fill: true,
          tension: 0.4,
          borderWidth: 2
        },
        {
          label: 'Profit',
          data: <%- JSON.stringify(analytics.revenueData.profit) %>,
          borderColor: '#06b6d4',
          backgroundColor: 'rgba(6, 182, 212, 0.1)',
          fill: true,
          tension: 0.4,
          borderWidth: 2
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              return context.dataset.label + ': ₹' + context.parsed.y.toLocaleString('en-IN');
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: function(value) {
              return '₹' + (value / 1000) + 'k';
            }
          },
          grid: {
            color: 'rgba(0, 0, 0, 0.05)'
          }
        },
        x: {
          grid: {
            display: false
          }
        }
      }
    }
  });

  // Course Performance Donut Chart
  const coursePerformanceCtx = document.getElementById('coursePerformanceChart').getContext('2d');
  new Chart(coursePerformanceCtx, {
    type: 'doughnut',
    data: {
      labels: ['Excellent', 'Good', 'Average'],
      datasets: [{
        data: [
          <%= analytics.coursePerformance.excellent %>,
          <%= analytics.coursePerformance.good %>,
          <%= analytics.coursePerformance.average %>
        ],
        backgroundColor: ['#3b82f6', '#f59e0b', '#e5e7eb'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            padding: 20,
            usePointStyle: true,
            font: {
              size: 12
            }
          }
        }
      },
      cutout: '70%'
    }
  });

  // Key Metrics Bar Chart
  const keyMetricsCtx = document.getElementById('keyMetricsChart').getContext('2d');
  new Chart(keyMetricsCtx, {
    type: 'bar',
    data: {
      labels: ['Total Views', 'Enrollments', 'Completions'],
      datasets: [{
        label: 'Metrics',
        data: [
          <%= analytics.keyMetrics.totalViews %>,
          <%= analytics.keyMetrics.totalEnrollments %>,
          <%= analytics.keyMetrics.totalCompletions %>
        ],
        backgroundColor: ['#3b82f6', '#06b6d4', '#8b5cf6'],
        borderRadius: 8,
        barThickness: 60
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: {
            color: 'rgba(0, 0, 0, 0.05)'
          }
        },
        x: {
          grid: {
            display: false
          }
        }
      }
    }
  });
  <% } %>
</script>

<script>
  const resubmitForm = document.getElementById('resubmitForm');
  if (resubmitForm) {
      resubmitForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const fileInput = document.getElementById('newCertificateFile');
          if (!fileInput || !fileInput.files[0]) {
              showToast('Please select a certificate file', 'error');
              return;
          }

          const formData = new FormData();
          formData.append('certificateFile', fileInput.files[0]);

          try {
              const button = resubmitForm.querySelector('button');
              button.disabled = true;
              button.textContent = 'Submitting...';

              const response = await fetch('/tutor/resubmit-application', {
                  method: 'POST',
                  body: formData
              });
              const data = await response.json();

              if (data.success) {
                  showToast(data.message || 'Application resubmitted successfully!', 'success');
                  setTimeout(() => {
                      window.location.reload();
                  }, 1500);
              } else {
                  showToast(data.message || 'Resubmission failed', 'error');
                  button.disabled = false;
                  button.textContent = 'Resubmit Application';
              }
          } catch (error) {
              console.error(error);
              showToast('An error occurred during submission.', 'error');
              const button = resubmitForm.querySelector('button');
              button.disabled = false;
              button.textContent = 'Resubmit Application';
          }
      });
  }
</script>

<%- include('../partials/toast') %>

</body>
</html>
