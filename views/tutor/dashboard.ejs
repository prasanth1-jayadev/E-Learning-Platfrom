                                <circle class="stroke-slate-100 dark:stroke-slate-800" cx="18" cy="18" fill="none"
                                    r="16" stroke-width="3"></circle>
                                <circle class="stroke-primary" cx="18" cy="18" fill="none" r="16"
                                    stroke-dasharray="75, 100" stroke-width="3"></circle>
                            </svg>
                            <div class="absolute inset-0 flex items-center justify-center flex-col">
                                <span class="text-2xl font-bold text-slate-800 dark:text-white">1</span>
                                <span
