                    Share Profile
                </button>
            </div>
            <nav class="space-y-1">
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg bg-primary text-white font-medium" href="#">
                    <span class="material-icons-outlined text-[20px]">dashboard</span>
                    Dashboard
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
                    href="#">
                    <span class="material-icons-outlined text-[20px]">person_outline</span>
                    Profile
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
                    href="#">
                    <span class="material-icons-outlined text-[20px]">menu_book</span>
                    Courses
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
                    href="#">
                    <span class="material-icons-outlined text-[20px]">shopping_cart</span>
                    Orders
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
                    href="#">
                    <span class="material-icons-outlined text-[20px]">account_balance_wallet</span>
                    Wallet
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
                    href="#">
                    <span class="material-icons-outlined text-[20px]">confirmation_number</span>
                    Coupon
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
                    href="#">
                    <span class="material-icons-outlined text-[20px]">chat</span>
                    Chat
                </a>
            </nav>
            <a href="/tutor/logout"
                class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-red-500 hover:bg-red-50 text-sm font-medium transition mt-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Logout
        </aside>
        <main class="flex-1 md:ml-64 p-6 lg:p-8 h-screen overflow-y-auto">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
                <h1 class="text-2xl font-bold text-slate-800 dark:text-white">Analytics Overview</h1>
                <div class="flex gap-2">
                    <button
                        class="flex items-center gap-2 px-4 py-2 bg-rose-500 text-white rounded-md text-sm font-medium hover:bg-rose-600 transition-colors">
                        <span class="material-icons-outlined text-sm">picture_as_pdf</span> PDF
                    </button>
                    <button
                        class="flex items-center gap-2 px-4 py-2 bg-emerald-500 text-white rounded-md text-sm font-medium hover:bg-emerald-600 transition-colors">
                        <span class="material-icons-outlined text-sm">file_download</span> Excel
                    </button>
                </div>
            </div>
            <div
                class="flex flex-wrap gap-2 mb-8 bg-white dark:bg-surface-dark p-2 rounded-lg border border-slate-200 dark:border-slate-700 w-fit">
                <button class="px-4 py-2 text-sm font-medium rounded-md bg-primary text-white">This Month</button>
                <button
                    class="px-4 py-2 text-sm font-medium rounded-md text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800">Last
                    Month</button>
                <button
                    class="px-4 py-2 text-sm font-medium rounded-md text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800">This
                    Year</button>
                <div class="relative">
                    <button
                        class="px-4 py-2 text-sm font-medium rounded-md text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 flex items-center gap-1">
                        <span class="material-icons-outlined text-sm">calendar_today</span> This Month <span
                            class="material-icons-outlined text-sm">expand_more</span>
                    </button>
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div
                    class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-slate-200 dark:border-slate-700 flex justify-between items-start">
                    <div>
                        <p
                            class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">
                            Total Students</p>
                        <h4 class="text-3xl font-bold text-slate-900 dark:text-white">0</h4>
                    </div>
                    <div
                        class="w-12 h-12 rounded-lg bg-teal-50 dark:bg-teal-900/20 flex items-center justify-center text-primary">
                        <span class="material-icons-outlined">group</span>
                    </div>
                </div>
                <div
                    class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-slate-200 dark:border-slate-700 flex justify-between items-start">
                    <div>
                        <p
                            class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">
                            Total Courses</p>
                        <h4 class="text-3xl font-bold text-slate-900 dark:text-white">1</h4>
                    </div>
                    <div
                        class="w-12 h-12 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center text-emerald-500">
                        <span class="material-icons-outlined">menu_book</span>
                    </div>
                </div>
                <div
                    class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-slate-200 dark:border-slate-700 flex justify-between items-start">
                    <div>
                        <p
                            class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">
                            Active Courses</p>
                        <h4 class="text-3xl font-bold text-slate-900 dark:text-white">1</h4>
                    </div>
                    <div
                        class="w-12 h-12 rounded-lg bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center text-indigo-500">
                        <span class="material-icons-outlined">school</span>
                    </div>
                </div>
                <div
                    class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-slate-200 dark:border-slate-700 flex justify-between items-start">
                    <div>
                        <p
                            class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">
                            Total Revenue</p>
                        <h4 class="text-3xl font-bold text-slate-900 dark:text-white">Rs.0</h4>
                    </div>
                    <div
                        class="w-12 h-12 rounded-lg bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center text-amber-500">
                        <span class="material-icons-outlined">payments</span>
                    </div>
                </div>
            </div>
            <div
                class="bg-white dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-700 p-6 mb-8">
                <div class="flex justify-between items-center mb-8">
                    <h3 class="text-lg font-bold text-slate-800 dark:text-white">Revenue &amp; Profit Overview</h3>
                    <div class="flex gap-4">
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-primary"></span>
                            <span class="text-xs font-medium text-slate-600 dark:text-slate-400">Revenue</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
                            <span class="text-xs font-medium text-slate-600 dark:text-slate-400">Profit</span>
                        </div>
                    </div>
                </div>
                <div class="h-80 w-full relative">
                    <div class="absolute inset-0 chart-placeholder opacity-30"></div>
                    <svg class="w-full h-full relative z-10 overflow-visible" viewBox="0 0 1000 300">
                        <g class="text-[10px] fill-slate-400">
                            <text x="0" y="320">Jan</text>
                            <text x="90" y="320">Feb</text>
                            <text x="180" y="320">Mar</text>
                            <text x="270" y="320">Apr</text>
                            <text x="360" y="320">May</text>
                            <text x="450" y="320">Jun</text>
                            <text x="540" y="320">Jul</text>
                            <text x="630" y="320">Aug</text>
                            <text x="720" y="320">Sep</text>
                            <text x="810" y="320">Oct</text>
                            <text x="900" y="320">Nov</text>
                            <text x="990" y="320">Dec</text>
                        </g>
                        <g class="text-[10px] fill-slate-400 text-right">
                            <text x="-30" y="10">₹1</text>
                            <text x="-30" y="150">₹0</text>
                            <text x="-30" y="290">₹-1</text>
                        </g>
                        <line stroke="#cbd5e1" stroke-width="2" x1="0" x2="1000" y1="150" y2="150"></line>
                        <polyline fill="none" points="0,150 1000,150" stroke="#109D89" stroke-linecap="round"
                            stroke-width="3"></polyline>
                    </svg>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
