        <div class="flex items-center gap-2">
            <span class="text-primary font-bold text-2xl tracking-tight">Organic Learn</span>
            <span class="text-slate-500 dark:text-slate-400 text-sm font-medium mt-1">Tutor</span>
        </div>
        <div class="flex items-center gap-6">
            <button class="text-slate-500 hover:text-primary transition-colors">
                <span class="material-icons-outlined">notifications</span>
            </button>
            <div class="flex items-center gap-3">
                <div class="text-right hidden sm:block">
                    <p class="text-sm font-semibold text-slate-900 dark:text-white leading-none">Prasanth B jayadev</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Premium Instructor</p>
                </div>
                <a href="/tutor/profile"
                    class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center overflow-hidden border border-slate-300 dark:border-slate-600 hover:ring-2 hover:ring-primary transition">
                    <img alt="User avatar"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBrbYKyg1rnhudi6KyVw66CxMSJ_c3I2xBiPv-xOkbwUfqbLAwmEAZMaryeciCHofOcxsflL6SngW9P8QdpuR5JWT48KGAHVmC8mfFmr5slywvKQPKm5hmVQMhi_5ReVaiUD4sIEWv7IRS8Rs2rxlvzZ3V_4gaN4wXnxx0D6afCQZ8KSp1MXi9hioV1Ebwd-7ScTpX5iufa5YuZgB1VqK4WaftAMyYzVAZO3FwqQ-LkR-UhaT8QxW7yvnKI0kyRrJ-AbCvxowHj8KE" />
                </a>
            </div>
        </div>
    </header>
    <div class="flex">
        <aside
            class="w-64 fixed left-0 top-[65px] bottom-0 bg-white dark:bg-surface-dark border-r border-slate-200 dark:border-slate-700 hidden md:flex flex-col p-4">
            <div class="flex flex-col items-center mb-8 pt-4">
                <div
                    class="w-20 h-20 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-4 overflow-hidden border border-slate-200 dark:border-slate-700">
                    <img alt="Tutor profile" class="object-cover w-full h-full"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCNMIltABFj7UqUVMOyGfic72OQiPyCWu6WnE3aUeE1ojE8LHTRppa-TFg_AfG7X6aDfbkW3TUHcOMT2UIluG8Xp8uFFB_6N_iNzjlmtkEgds5_uug2DbmWLN15YiPG5P4CfNtveIyUqZneeg6RcoTBzPHB7UfNzRt7RYaNC_c4A8XwF4bJujYUaOkgLaCSGTjQwsBWryQAv9Y2LHK79_xFlrcreyxJ-Z1ikLDR78T1Q3qJvdhzjYmk0ZjhEFliDDgR-rpMJ9nja10" />
                </div>
                <h3 class="font-semibold text-slate-900 dark:text-white">Prasanth B jayadev</h3>
                <button
