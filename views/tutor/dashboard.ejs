<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tutor Dashboard - Organic Learn</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { primary: '#2beead' },
          fontFamily: { display: ['Be Vietnam Pro', 'sans-serif'] }
        }
      }
    }
  </script>
</head>
<body class="font-display bg-[#f0f4f3] min-h-screen flex flex-col">

<!-- Navbar -->
<nav class="bg-white border-b border-gray-100 px-8 py-3 flex items-center justify-between sticky top-0 z-50">
  <div class="flex items-center gap-2">
    <div class="w-7 h-7 bg-primary/20 rounded-lg flex items-center justify-center">
      <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 48 48"><path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z"/></svg>
    </div>
    <span class="font-bold text-sm"><span class="text-primary">Organic</span> Learn</span>
  </div>
  <div class="flex items-center gap-3">
    <button class="text-gray-400 hover:text-gray-600">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
    </button>
    <a href="/tutor/profile" class="flex items-center gap-2 hover:bg-gray-50 rounded-lg p-2 transition-colors cursor-pointer">
      <div class="text-right">
        <p class="text-xs font-bold text-gray-800"><%= tutor.fullName %></p>
        <p class="text-[10px] text-primary">Tutor</p>
      </div>
      <div class="w-8 h-8 rounded-full bg-amber-200 overflow-hidden">
        <svg class="w-full h-full text-amber-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
      </div>
    </a>
  </div>
</nav>

<!-- Main -->
<div class="flex-1 max-w-5xl mx-auto w-full px-6 py-8 flex gap-6 items-start">

  <%- include('../partials/tutor-sidebar') %>

  <!-- Dashboard Content -->
  <div class="flex-1">
    <!-- Approval Status Banner -->
    <% if (!isApproved) { %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-6 mb-6">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-yellow-800 mb-2">Account Under Review</h3>
          <p class="text-yellow-700 mb-4">
            Your tutor application is currently being reviewed by our admin team. 
            Once approved, you'll have access to all tutor features including course creation, 
            student management, and earnings tracking.
          </p>
          <div class="bg-yellow-100 rounded-lg p-4">
            <h4 class="font-semibold text-yellow-800 mb-2">What happens next?</h4>
            <ul class="text-sm text-yellow-700 space-y-1">
              <li>• Admin will review your submitted documents</li>
              <li>• You'll receive an email notification once approved</li>
              <li>• Full access to tutor features will be unlocked</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <% } else { %>
    
    <!-- Analytics Overview Header -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Analytics Overview</h1>
          <p class="text-gray-500 mt-1">Welcome back, <%= tutor.fullName %>!</p>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex bg-gray-100 rounded-lg p-1">
            <button class="px-4 py-2 bg-primary text-white rounded-md text-sm font-medium">This Month</button>
            <button class="px-4 py-2 text-gray-600 text-sm font-medium">Last Month</button>
            <button class="px-4 py-2 text-gray-600 text-sm font-medium">This Year</button>
            <button class="px-4 py-2 text-gray-600 text-sm font-medium">All Time Month</button>
          </div>
          <div class="flex items-center gap-2">
            <button class="px-4 py-2 bg-red-500 text-white rounded-lg text-sm font-medium">PDF</button>
            <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium">Excel</button>
          </div>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-blue-50 p-6 rounded-xl border border-blue-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-blue-600 mb-1">TOTAL STUDENTS</p>
              <h4 class="text-3xl font-bold text-blue-900">0</h4>
            </div>
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
            </div>
          </div>
        </div>
        
        <div class="bg-green-50 p-6 rounded-xl border border-green-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-green-600 mb-1">TOTAL COURSES</p>
              <h4 class="text-3xl font-bold text-green-900">1</h4>
            </div>
            <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
          </div>
        </div>
        
        <div class="bg-purple-50 p-6 rounded-xl border border-purple-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-purple-600 mb-1">ACTIVE COURSES</p>
              <h4 class="text-3xl font-bold text-purple-900">1</h4>
            </div>
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            </div>
          </div>
        </div>
        
        <div class="bg-yellow-50 p-6 rounded-xl border border-yellow-100">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-yellow-600 mb-1">TOTAL REVENUE</p>
              <h4 class="text-3xl font-bold text-yellow-900">Rs.0</h4>
            </div>
            <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Revenue & Profit Overview Chart -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Revenue & Profit Overview</h2>
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-primary rounded-full"></div>
            <span class="text-sm text-gray-600">Revenue</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-gray-300 rounded-full"></div>
            <span class="text-sm text-gray-600">Profit</span>
          </div>
        </div>
      </div>
      
      <!-- Chart Placeholder -->
      <div class="h-64 bg-gray-50 rounded-lg flex items-center justify-center border-2 border-dashed border-gray-200">
        <div class="text-center">
          <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
          <p class="text-gray-500 text-sm">Revenue chart will appear here</p>
          <p class="text-gray-400 text-xs mt-1">Start earning to see your revenue trends</p>
        </div>
      </div>
    </div>

    <!-- Bottom Row: Course Performance & Key Metrics -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <!-- Course Performance -->
      <div class="bg-white rounded-2xl shadow-sm p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-6">Course Performance</h3>
        
        <!-- Circular Progress -->
        <div class="flex items-center justify-center mb-6">
          <div class="relative w-32 h-32">
            <svg class="w-32 h-32 transform -rotate-90" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="50" stroke="#e5e7eb" stroke-width="8" fill="none"/>
              <circle cx="60" cy="60" r="50" stroke="#10b981" stroke-width="8" fill="none" 
                      stroke-dasharray="314" stroke-dashoffset="250" stroke-linecap="round"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center">
                <div class="text-2xl font-bold text-gray-900">1</div>
                <div class="text-xs text-gray-500">Course</div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Legend -->
        <div class="flex justify-center gap-6 text-sm">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-primary rounded-full"></div>
            <span class="text-gray-600">Active Course</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-blue-400 rounded-full"></div>
            <span class="text-gray-600">Draft Course</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-orange-400 rounded-full"></div>
            <span class="text-gray-600">Total Lessons</span>
          </div>
        </div>
      </div>

      <!-- Key Metrics -->
      <div class="bg-white rounded-2xl shadow-sm p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-6">Key Metrics</h3>
        
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center">
            <div class="w-full h-24 bg-gray-100 rounded-lg mb-3 flex items-end justify-center pb-2">
              <div class="w-8 bg-gray-300 rounded-t" style="height: 60%"></div>
            </div>
            <p class="text-xs text-gray-500 uppercase tracking-wide">TOTAL REVENUE</p>
          </div>
          
          <div class="text-center">
            <div class="w-full h-24 bg-gray-100 rounded-lg mb-3 flex items-end justify-center pb-2">
              <div class="w-8 bg-primary rounded-t" style="height: 80%"></div>
            </div>
            <p class="text-xs text-gray-500 uppercase tracking-wide">STUDENTS</p>
          </div>
          
          <div class="text-center">
            <div class="w-full h-24 bg-gray-100 rounded-lg mb-3 flex items-end justify-center pb-2">
              <div class="w-8 bg-green-300 rounded-t" style="height: 70%"></div>
            </div>
            <p class="text-xs text-gray-500 uppercase tracking-wide">COURSES</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Course Management Table -->
    <div class="bg-white rounded-2xl shadow-sm p-6">
      <h3 class="text-lg font-bold text-gray-900 mb-6">Course Management</h3>
      
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="text-left py-3 px-4 font-semibold text-gray-700 text-sm">COURSE NAME</th>
              <th class="text-left py-3 px-4 font-semibold text-gray-700 text-sm">STUDENTS</th>
              <th class="text-left py-3 px-4 font-semibold text-gray-700 text-sm">LESSONS</th>
              <th class="text-left py-3 px-4 font-semibold text-gray-700 text-sm">PRICE</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="py-4 px-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900">Mastering Advanced React Patterns</p>
                    <p class="text-sm text-gray-500">React, JavaScript, Frontend</p>
                  </div>
                </div>
              </td>
              <td class="py-4 px-4 text-gray-600">0</td>
              <td class="py-4 px-4 text-gray-600">24</td>
              <td class="py-4 px-4 text-gray-900 font-semibold">₹4,999</td>
            </tr>
          </tbody>
        </table>
        
        <div class="text-center py-8 text-gray-500">
          <p class="text-sm">No more courses to display</p>
        </div>
      </div>
    </div>
    
    <% } %>
  </div>
</div>

</body>
</html>