<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Courses - Organic Learn</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { primary: '#2beead' },
          fontFamily: { display: ['Be Vietnam Pro', 'sans-serif'] }
        }
      }
    }
  </script>
</head>
<body class="font-display bg-[#f0f4f3] min-h-screen flex flex-col">

<!-- Navbar -->
<nav class="bg-white border-b border-gray-100 px-8 py-3 flex items-center justify-between sticky top-0 z-50">
  <div class="flex items-center gap-2">
    <div class="w-7 h-7 bg-primary/20 rounded-lg flex items-center justify-center">
      <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 48 48"><path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z"/></svg>
    </div>
    <span class="font-bold text-sm"><span class="text-primary">Organic</span> Learn</span>
  </div>
  <div class="flex items-center gap-3">
    <button class="text-gray-400 hover:text-gray-600">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
    </button>
    <a href="/tutor/profile" class="flex items-center gap-2 hover:bg-gray-50 rounded-lg p-2 transition-colors cursor-pointer">
      <div class="text-right">
        <p class="text-xs font-bold text-gray-800"><%= tutor.fullName %></p>
        <p class="text-[10px] text-primary">Tutor</p>
      </div>
      <div class="w-8 h-8 rounded-full bg-amber-200 overflow-hidden">
        <svg class="w-full h-full text-amber-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
      </div>
    </a>
  </div>
</nav>

<!-- Main -->
<div class="flex-1 max-w-5xl mx-auto w-full px-6 py-8 flex gap-6 items-start">

  <%- include('../partials/tutor-sidebar') %>

  <!-- Courses Content -->
  <div class="flex-1">
    <div class="bg-white rounded-2xl shadow-sm p-7 mb-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">My Courses</h2>
        <button class="flex items-center gap-2 bg-primary text-gray-900 text-sm font-bold px-4 py-2 rounded-lg hover:brightness-110 transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Create New Course
        </button>
      </div>
      
      <div class="text-center py-12">
        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        </div>
        <h3 class="text-lg font-medium text-gray-600 mb-2">No courses yet</h3>
        <p class="text-gray-500 mb-6">Create your first course to start teaching</p>
        <button class="px-6 py-3 bg-primary text-gray-900 rounded-lg hover:brightness-110 transition font-medium">
          Create Your First Course
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="bg-white border-t border-gray-100 mt-8">
  <div class="max-w-5xl mx-auto px-6 py-10 grid grid-cols-4 gap-8">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <div class="w-6 h-6 bg-primary/20 rounded-lg flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-primary" fill="currentColor" viewBox="0 0 48 48"><path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z"/></svg>
        </div>
        <span class="font-bold text-sm text-gray-800">Organic Learn</span>
      </div>
      <p class="text-xs text-gray-400 leading-relaxed mb-4">Empowering learners worldwide with quality education. Join thousands of students and expert tutors in our learning community.</p>
      <div class="flex gap-2">
        <div class="w-7 h-7 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-primary/10 cursor-pointer transition">
          <svg class="w-3.5 h-3.5 text-gray-500" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </div>
        <div class="w-7 h-7 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-primary/10 cursor-pointer transition">
          <svg class="w-3.5 h-3.5 text-gray-500" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
        </div>
        <div class="w-7 h-7 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-primary/10 cursor-pointer transition">
          <svg class="w-3.5 h-3.5 text-gray-500" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </div>
        <div class="w-7 h-7 bg-gray-100 rounded-lg flex items-center justify-center hover:bg-primary/10 cursor-pointer transition">
          <svg class="w-3.5 h-3.5 text-gray-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </div>
      </div>
    </div>
    <div>
      <p class="text-xs font-bold text-gray-800 mb-3">Quick Links</p>
      <ul class="space-y-2 text-xs text-gray-400">
        <li><a href="#" class="hover:text-primary transition">Browse Courses</a></li>
        <li><a href="#" class="hover:text-primary transition">Categories</a></li>
        <li><a href="#" class="hover:text-primary transition">About Us</a></li>
        <li><a href="#" class="hover:text-primary transition">Contact</a></li>
        <li><a href="#" class="hover:text-primary transition">Help Center</a></li>
      </ul>
    </div>
    <div>
      <p class="text-xs font-bold text-gray-800 mb-3">For Educators</p>
      <ul class="space-y-2 text-xs text-gray-400">
        <li><a href="#" class="hover:text-primary transition">Become a Tutor</a></li>
        <li><a href="#" class="hover:text-primary transition">Tutor Login</a></li>
        <li><a href="#" class="hover:text-primary transition">Teaching Guide</a></li>
        <li><a href="#" class="hover:text-primary transition">Resources</a></li>
        <li><a href="#" class="hover:text-primary transition">Tutor Support</a></li>
      </ul>
    </div>
    <div>
      <p class="text-xs font-bold text-gray-800 mb-3">Contact Us</p>
      <ul class="space-y-2 text-xs text-gray-400">
        <li>hello@organiclearn.com</li>
        <li>+1 (234) 567-890</li>
        <li class="leading-relaxed">123 Education Street,<br/>Learning City, LC 12345</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-gray-100 py-4 text-center text-xs text-gray-400">
    © 2024 Organic Learn. All rights reserved.
  </div>
</footer>

<!-- Dark mode FAB -->
<button class="fixed bottom-6 right-6 w-10 h-10 bg-[#0d1b17] text-primary rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition">
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
</button>

</body>
</html>