                    </div>
                    <span>Joined by 50,000+ students worldwide</span>
                </div>
            </div>
        </div>

        <!-- RIGHT FORM -->
        <div class="w-full md:w-1/2 bg-white dark:bg-background-dark flex flex-col h-full overflow-y-auto">
            <div class="flex-1 flex flex-col justify-center items-center px-6 py-8 md:px-16 lg:px-20">
                <div class="w-full max-w-md my-8">
                    <div class="md:hidden flex items-center gap-2 mb-8 justify-center">
                        <span class="material-icons text-primary text-3xl">school</span>
                        <span class="text-2xl font-bold dark:text-white">Scholara</span>
                    </div>
                    <div class="mb-10 text-center md:text-left">
                        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Create Account</h2>
                        <p class="text-slate-500 dark:text-slate-400">Please provide your details and professional
                            documents for verification.</p>
                    </div>

                    <form class="space-y-6" id="tutorSignupForm">
                        <div class="grid grid-cols-1 gap-5">
                            <div>
                                <label class="block text-sm font-bold text-slate-800 mb-2">Full Name</label>
                                <input class="w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition"
                                    id="fullName" placeholder="John Doe" type="text" required />
                                <p class="text-red-500 text-xs mt-1 hidden" id="fullNameError">Full Name is required</p>
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-slate-800 mb-2">Email Address</label>
                                <input class="w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition"
                                    id="email" placeholder="john@example.com" type="email" required />
                                <p class="text-red-500 text-xs mt-1 hidden" id="emailError">Valid Email is required</p>
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-slate-800 mb-2">Create Password</label>
                                <div class="relative">
                                    <input class="w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition pr-12"
                                        id="password" placeholder="••••••••" type="password" required />
                                    <button type="button"
                                        onclick="this.previousElementSibling.type=this.previousElementSibling.type==='password'?'text':'password'"
                                        class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 focus:outline-none">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                    </button>
                                    <p class="text-red-500 text-xs mt-1 hidden" id="passwordError">Password must be at least 8 characters</p>
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-slate-800 mb-2">Confirm Password</label>
                                <div class="relative">
                                    <input class="w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition pr-12"
                                        id="confirmPassword" placeholder="Repeat your password" type="password" required />
                                    <button type="button"
                                        onclick="this.previousElementSibling.type=this.previousElementSibling.type==='password'?'text':'password'"
                                        class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 focus:outline-none">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                    </button>
                                    <p class="text-red-500 text-xs mt-1 hidden" id="confirmPasswordError">Passwords must match</p>
                                </div>
                            </div>
                        </div>

                        <!-- Professional Verification -->
                        <div class="pt-2">
                            <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-4 uppercase tracking-wider">
                                Professional Verification
                            </h3>
                            <div class="relative group">
                                <!-- Default Upload Area -->
                                <label id="uploadArea" class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl bg-slate-50 dark:bg-slate-800/30 hover:bg-slate-100 dark:hover:bg-slate-800/50 hover:border-primary/50 transition-all cursor-pointer group-hover:scale-[1.02] active:scale-[0.98]">
                                    <div class="flex flex-col items-center justify-center pt-5 pb-6" id="uploadContent">
                                        <span class="material-symbols-outlined text-4xl text-slate-400 dark:text-slate-500 mb-3 group-hover:text-primary transition-colors">cloud_upload</span>
                                        <p class="text-sm text-slate-600 dark:text-slate-400 font-medium group-hover:text-slate-800 transition-colors">Upload ID or Professional Certificate</p>
                                        <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">(PDF, PNG, JPG - Max 5MB)</p>
                                    </div>
                                    <input accept=".pdf,.png,.jpg,.jpeg" id="certificateFile" class="hidden" type="file" />
                                </label>

                                <!-- File Selected State (Hidden by default) -->
                                <div id="fileSelectedArea" class="hidden w-full border-2 border-green-300 bg-green-50 rounded-xl p-4">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                                                <span class="material-symbols-outlined text-green-600" id="fileIcon">description</span>
                                            </div>
                                            <div>
                                                <p class="text-sm font-medium text-green-800" id="fileName">document.pdf</p>
                                                <p class="text-xs text-green-600" id="fileSize">2.3 MB</p>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <span class="material-symbols-outlined text-green-600 text-lg">check_circle</span>
                                            <button type="button" id="removeFile" class="text-red-500 hover:text-red-700 transition-colors">
                                                <span class="material-symbols-outlined text-lg">close</span>
                                            </button>
                                        </div>
                                    </div>
                                    <p class="text-xs text-green-600 mt-2 flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">check</span>
                                        File uploaded successfully
                                    </p>
                                </div>

                                <p class="text-red-500 text-xs mt-1 hidden" id="fileError">Please upload a certificate</p>
                            </div>
                        </div>

                        <button type="submit" class="w-full bg-primary hover:bg-[#0E8A78] text-white font-bold py-4 rounded-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
