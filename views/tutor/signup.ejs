            </div>

            <footer class="px-6 py-6 md:px-16 border-t border-[#e7f3ef] flex justify-between items-center text-[10px] opacity-50 font-bold uppercase tracking-widest mt-auto">
                <p>© 2024 Scholara</p>
                <div class="flex gap-4">
                    <a class="hover:text-primary" href="#">Privacy</a>
                    <a class="hover:text-primary" href="#">Terms</a>
                </div>
            </footer>
        </div>
    </div>
  
     <script>
const form = document.getElementById('tutorSignupForm');
const file = document.getElementById('certificateFile');

form.addEventListener('submit', async function(e) {
    e.preventDefault();

    const fullName = document.getElementById('fullName');
    const email = document.getElementById('email');
    const password = document.getElementById('password');
    const confirm = document.getElementById('confirmPassword');

    const fullNameError = document.getElementById('fullNameError');
    const emailError = document.getElementById('emailError');
    const passwordError = document.getElementById('passwordError');
    const confirmPasswordError = document.getElementById('confirmPasswordError');
    const fileError = document.getElementById('fileError');

    // Reset errors
    [fullNameError, emailError, passwordError, confirmPasswordError, fileError]
        .forEach(el => el.classList.add('hidden'));

    let valid = true;

    // Full Name validation
    if (!fullName.value.trim()) {
        fullNameError.textContent = 'Full name is required';
        fullNameError.classList.remove('hidden');
        valid = false;
    } else {
        // Validate full name (only letters and single spaces between words)
        const nameRegex = /^[a-zA-Z]+(\s[a-zA-Z]+)*$/;
        if (!nameRegex.test(fullName.value.trim())) {
            fullNameError.textContent = 'Full name can only contain letters and single spaces between words';
            fullNameError.classList.remove('hidden');
            valid = false;
        } else if (fullName.value.trim().length < 2 || fullName.value.trim().length > 50) {
            fullNameError.textContent = 'Full name must be between 2 and 50 characters';
            fullNameError.classList.remove('hidden');
            valid = false;
        }
    }

    // Email validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email.value.trim()) {
        emailError.textContent = 'Email is required';
        emailError.classList.remove('hidden');
        valid = false;
    } else if (!emailRegex.test(email.value.trim())) {
        emailError.textContent = 'Please enter a valid email address';
        emailError.classList.remove('hidden');
        valid = false;
    }

    // Password validation
    if (!password.value) {
        passwordError.textContent = 'Password is required';
        passwordError.classList.remove('hidden');
        valid = false;
    } else if (password.value.length < 8) {
        passwordError.textContent = 'Password must be at least 8 characters long';
        passwordError.classList.remove('hidden');
        valid = false;
    } else {
        // Check for password complexity
        const hasUpperCase = /[A-Z]/.test(password.value);
        const hasLowerCase = /[a-z]/.test(password.value);
        const hasNumbers = /\d/.test(password.value);

        if (!hasUpperCase || !hasLowerCase || !hasNumbers) {
            passwordError.textContent = 'Password must contain at least one uppercase letter, one lowercase letter, and one number';
            passwordError.classList.remove('hidden');
            valid = false;
        }
    }

    // Confirm Password validation
    if (!confirm.value) {
        confirmPasswordError.textContent = 'Please confirm your password';
        confirmPasswordError.classList.remove('hidden');
        valid = false;
    } else if (password.value !== confirm.value) {
        confirmPasswordError.textContent = 'Passwords do not match';
        confirmPasswordError.classList.remove('hidden');
        valid = false;
    }

    // File validation
    const allowedTypes = ['application/pdf', 'image/png', 'image/jpg', 'image/jpeg'];

    if (file.files.length === 0) {
        fileError.textContent = 'Please upload your certificate';
        fileError.classList.remove('hidden');
        valid = false;
    } else if (!allowedTypes.includes(file.files[0].type)) {
        fileError.textContent = 'Only PDF, PNG, JPG allowed';
        fileError.classList.remove('hidden');
        valid = false;
    }

    if (!valid) return;

    try {
        const formData = new FormData();
        formData.append('fullName', fullName.value.trim());
        formData.append('email', email.value.trim());
        formData.append('password', password.value);
        formData.append('certificateFile', file.files[0]);

        const response = await fetch('/tutor/signup', {
            method: 'POST',
            body: formData
        });

        const data = await response.json();

        if (response.ok) {
            showToast('Account created! Check your email for OTP.', 'success');
            setTimeout(() => {
                window.location.href = data.redirect || '/tutor/verify-otp';
            }, 1500);
        } else {
            showToast(data.message || 'Signup failed', 'error');
            emailError.textContent = data.message || 'Error';
            emailError.classList.remove('hidden');
        }

    } catch (error) {
        showToast('Something went wrong. Please try again.', 'error');
        fullNameError.textContent = 'Something went wrong';
        fullNameError.classList.remove('hidden');
    }
});

// Enhanced file upload handling
file.addEventListener('change', function() {
    const error = document.getElementById('fileError');
    const uploadArea = document.getElementById('uploadArea');
    const fileSelectedArea = document.getElementById('fileSelectedArea');
    const fileName = document.getElementById('fileName');
    const fileSize = document.getElementById('fileSize');
    const fileIcon = document.getElementById('fileIcon');
    
    if (this.files.length > 0) {
        const selectedFile = this.files[0];
        const allowedTypes = ['application/pdf', 'image/png', 'image/jpg', 'image/jpeg'];
        const maxSize = 5 * 1024 * 1024; // 5MB in bytes
        
        // Validate file type
        if (!allowedTypes.includes(selectedFile.type)) {
            error.textContent = 'Please upload a valid file (PDF, PNG, JPG only)';
            error.classList.remove('hidden');
            this.value = ''; // Clear the input
            return;
        }
        
        // Validate file size
        if (selectedFile.size > maxSize) {
            error.textContent = 'File size must be less than 5MB';
            error.classList.remove('hidden');
            this.value = ''; // Clear the input
            return;
        }
        
        // File is valid - show success state
        error.classList.add('hidden');
        uploadArea.classList.add('hidden');
        fileSelectedArea.classList.remove('hidden');
        
        // Update file details
        fileName.textContent = selectedFile.name;
        fileSize.textContent = formatFileSize(selectedFile.size);
        
        // Set appropriate icon based on file type
        if (selectedFile.type === 'application/pdf') {
            fileIcon.textContent = 'picture_as_pdf';
        } else {
            fileIcon.textContent = 'image';
        }
        
    } else {
        // No file selected - show upload area
        uploadArea.classList.remove('hidden');
        fileSelectedArea.classList.add('hidden');
        error.classList.add('hidden');
    }
});

// Remove file functionality
document.getElementById('removeFile').addEventListener('click', function() {
    const uploadArea = document.getElementById('uploadArea');
    const fileSelectedArea = document.getElementById('fileSelectedArea');
    const error = document.getElementById('fileError');
    
    // Clear the file input
    file.value = '';
    
    // Show upload area, hide selected area
    uploadArea.classList.remove('hidden');
    fileSelectedArea.classList.add('hidden');
    error.classList.add('hidden');
});

// Helper function to format file size
function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

// Drag and drop functionality
const uploadArea = document.getElementById('uploadArea');

['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
    uploadArea.addEventListener(eventName, preventDefaults, false);
});

function preventDefaults(e) {
    e.preventDefault();
    e.stopPropagation();
}

['dragenter', 'dragover'].forEach(eventName => {
    uploadArea.addEventListener(eventName, highlight, false);
});

['dragleave', 'drop'].forEach(eventName => {
    uploadArea.addEventListener(eventName, unhighlight, false);
});

function highlight(e) {
    uploadArea.classList.add('border-primary', 'bg-primary/5');
}

function unhighlight(e) {
    uploadArea.classList.remove('border-primary', 'bg-primary/5');
}

uploadArea.addEventListener('drop', handleDrop, false);

function handleDrop(e) {
    const dt = e.dataTransfer;
    const files = dt.files;
    
    if (files.length > 0) {
        file.files = files;
        // Trigger change event
        const event = new Event('change', { bubbles: true });
        file.dispatchEvent(event);
    }
}
</script>

<%- include('../partials/toast') %>
