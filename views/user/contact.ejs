<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Contact Us - Organic Learn</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { brand: '#00d9b1' },
          fontFamily: { display: ['Be Vietnam Pro', 'sans-serif'] }
        }
      }
    }
  </script>
  <style>
    .floating-card-shift {
      margin-top: -3.5rem;
    }
    .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s cubic-bezier(0, 1, 0, 1);
    }
    .accordion-item.active .accordion-content {
      max-height: 500px;
      transition: max-height 0.3s cubic-bezier(1, 0, 1, 0);
    }
    .accordion-item.active .arrow-icon {
      transform: rotate(180deg);
    }
  </style>
</head>
<body class="font-display bg-white text-gray-900 min-h-screen flex flex-col">

  <%- include('../partials/user-navbar') %>

  <!-- Top Gradient Hero Section -->
  <section class="bg-gradient-to-br from-[#065f46] via-[#059669] to-[#00d9b1] text-white py-24 px-6 relative overflow-hidden text-center">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
    <div class="max-w-4xl mx-auto relative z-10">
      <h1 class="text-4xl md:text-5xl font-black mb-4">Contact Us</h1>
      <p class="text-emerald-50 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
        Have questions about our mentorship model? We'd love to hear from you. Send us a message and we'll respond as soon as possible.
      </p>
    </div>
  </section>

  <!-- 4 Floating overlapping contact info cards -->
  <section class="px-6 max-w-6xl mx-auto w-full relative z-20 floating-card-shift">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      <!-- Card 1: Email -->
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-lg hover:shadow-xl transition text-center flex flex-col items-center">
        <div class="w-10 h-10 rounded-full bg-brand/10 text-brand flex items-center justify-center mb-4">
          <span class="material-icons">mail</span>
        </div>
        <h3 class="font-bold text-gray-900 text-sm mb-1">Email Us</h3>
        <p class="text-[11px] text-gray-400 mb-3">Send us an email anytime!</p>
        <a href="mailto:support@organiclearn.com" class="text-xs font-bold text-brand hover:underline">elearningplatform189@gmail.com
</a>
      </div>
      <!-- Card 2: Phone -->
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-lg hover:shadow-xl transition text-center flex flex-col items-center">
        <div class="w-10 h-10 rounded-full bg-brand/10 text-brand flex items-center justify-center mb-4">
          <span class="material-icons">call</span>
        </div>
        <h3 class="font-bold text-gray-900 text-sm mb-1">Call Us</h3>
        <p class="text-[11px] text-gray-400 mb-3">Mon-Fri from 8am to 5pm</p>
        <a href="tel:+15551234567" class="text-xs font-bold text-brand hover:underline">+1 (555) 123-4567</a>
      </div>
      <!-- Card 3: Location -->
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-lg hover:shadow-xl transition text-center flex flex-col items-center">
        <div class="w-10 h-10 rounded-full bg-brand/10 text-brand flex items-center justify-center mb-4">
          <span class="material-icons">place</span>
        </div>
        <h3 class="font-bold text-gray-900 text-sm mb-1">Visit Us</h3>
        <p class="text-[11px] text-gray-400 mb-3">Headquarters office</p>
        <span class="text-xs text-gray-600 font-medium">123 Education Street, Learning City</span>
      </div>
      <!-- Card 4: Hours -->
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-lg hover:shadow-xl transition text-center flex flex-col items-center">
        <div class="w-10 h-10 rounded-full bg-brand/10 text-brand flex items-center justify-center mb-4">
          <span class="material-icons">schedule</span>
        </div>
        <h3 class="font-bold text-gray-900 text-sm mb-1">Working Hours</h3>
        <p class="text-[11px] text-gray-400 mb-3 font-medium text-center">Mon - Fri: 8am - 5pm</p>
        <span class="text-[11px] text-gray-500">Weekend support available</span>
      </div>
    </div>
  </section>

  <!-- Two-Column Form & FAQ Section -->
  <section class="py-16 md:py-24 px-6 max-w-6xl mx-auto w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      
      <!-- Left Column: Send us a Message Form -->
      <div class="bg-white border border-gray-100 p-8 rounded-3xl shadow-sm">
        <h2 class="text-2xl font-extrabold text-gray-900 mb-6">Send us a Message</h2>
        <form id="contactForm" class="space-y-5" onsubmit="handleContactSubmit(event)">
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs font-bold text-gray-700 uppercase mb-2">Full Name *</label>
              <input type="text" required placeholder="Your full name" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/40"/>
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-700 uppercase mb-2">Email Address *</label>
              <input type="email" required placeholder="your.email@example.com" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/40"/>
            </div>
          </div>

          <div>
            <label class="block text-xs font-bold text-gray-700 uppercase mb-2">Category *</label>
            <select class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/40">
              <option value="general">General Inquiry</option>
              <option value="billing">Billing & Payments</option>
              <option value="tutor">Tutor Application</option>
              <option value="support">Technical Support</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-bold text-gray-700 uppercase mb-2">Subject *</label>
            <input type="text" required placeholder="What is this about?" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/40"/>
          </div>

          <div>
            <label class="block text-xs font-bold text-gray-700 uppercase mb-2">Message *</label>
            <textarea required rows="5" placeholder="Tell us more about your inquiry..." class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/40 resize-none"></textarea>
          </div>

          <button type="submit" class="w-full py-4 bg-brand text-gray-900 text-sm font-bold rounded-xl hover:brightness-110 transition flex items-center justify-center gap-2">
            <span class="material-icons text-base">send</span>
            <span>Send Message</span>
          </button>
        </form>
      </div>

      <!-- Right Column: FAQs & urgent helper box -->
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-extrabold text-gray-900 mb-6">Frequently Asked Questions</h2>
          <div class="space-y-4">
            
            <!-- Accordion 1 -->
            <div class="accordion-item bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm">
              <button onclick="toggleAccordion(this)" class="w-full flex items-center justify-between p-5 text-left font-bold text-gray-800 text-sm focus:outline-none">
                <span>How do you verify the quality of your tutors?</span>
                <span class="material-icons arrow-icon text-gray-400 transition-transform">expand_more</span>
              </button>
              <div class="accordion-content bg-gray-50/50">
                <div class="p-5 text-xs text-gray-500 leading-relaxed border-t border-gray-100">
                  Every mentor undergoes a multi-stage verification including portfolio reviews and technical interviews to ensure elite teaching standards.
                </div>
              </div>
            </div>

            <!-- Accordion 2 -->
            <div class="accordion-item bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm">
              <button onclick="toggleAccordion(this)" class="w-full flex items-center justify-between p-5 text-left font-bold text-gray-800 text-sm focus:outline-none">
                <span>Can I schedule private 1-on-1 mentorship sessions?</span>
                <span class="material-icons arrow-icon text-gray-400 transition-transform">expand_more</span>
              </button>
              <div class="accordion-content bg-gray-50/50">
                <div class="p-5 text-xs text-gray-500 leading-relaxed border-t border-gray-100">
                  Yes, you can book direct 1-on-1 sessions with any mentor through their profile for personalized project guidance and career coaching.
                </div>
              </div>
            </div>

            <!-- Accordion 3 -->
            <div class="accordion-item bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm">
              <button onclick="toggleAccordion(this)" class="w-full flex items-center justify-between p-5 text-left font-bold text-gray-800 text-sm focus:outline-none">
                <span>What makes Organic Learn different from other platforms?</span>
                <span class="material-icons arrow-icon text-gray-400 transition-transform">expand_more</span>
              </button>
              <div class="accordion-content bg-gray-50/50">
                <div class="p-5 text-xs text-gray-500 leading-relaxed border-t border-gray-100">
                  We prioritize deep mentorship and real-world skill architecture over simple video consumption, focusing on high-level professional growth.
                </div>
              </div>
            </div>

            <!-- Accordion 4 -->
            <div class="accordion-item bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm">
              <button onclick="toggleAccordion(this)" class="w-full flex items-center justify-between p-5 text-left font-bold text-gray-800 text-sm focus:outline-none">
                <span>Is there a limit to how many mentors I can connect with?</span>
                <span class="material-icons arrow-icon text-gray-400 transition-transform">expand_more</span>
              </button>
              <div class="accordion-content bg-gray-50/50">
                <div class="p-5 text-xs text-gray-500 leading-relaxed border-t border-gray-100">
                  There are no limits; we encourage students to seek diverse perspectives by connecting with various specialized mentors across our platform.
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- Need Immediate Help? Card -->
        <div class="bg-brand/5 border border-brand/10 p-6 rounded-3xl space-y-4">
          <h3 class="font-extrabold text-gray-800 text-sm">Need Immediate Help?</h3>
          <div class="space-y-3 text-xs">
            <div class="flex items-center gap-2">
              <span class="material-icons text-brand text-sm">chat_bubble</span>
              <span class="text-gray-700 font-semibold">Live Chat Available 24/7</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-icons text-brand text-sm">support_agent</span>
              <span class="text-gray-700 font-semibold">Emergency Support: +1 (555) 999-0000</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-icons text-brand text-sm">priority_high</span>
              <span class="text-gray-700 font-semibold">Priority Email: urgent@organiclearn.com</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Find Us Map mockup -->
  <section class="py-16 bg-gray-50 border-t border-gray-100 px-6 text-center">
    <div class="max-w-6xl mx-auto w-full">
      <h2 class="text-3xl font-extrabold text-gray-900 mb-2">Find Us</h2>
      <p class="text-gray-400 text-sm mb-8 max-w-sm mx-auto">Visit our office or reach out to us online.</p>
      
      <div class="relative w-full h-80 rounded-3xl bg-gray-200 overflow-hidden flex items-center justify-center border border-gray-300">
        <!-- Abstract map pattern layout -->
        <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#9ca3af_1px,transparent_1px)] [background-size:16px_16px]"></div>
        <div class="absolute w-36 h-36 rounded-full bg-brand/10 border-4 border-brand/20 animate-ping"></div>
        <div class="absolute w-16 h-16 rounded-full bg-brand/35 flex items-center justify-center">
          <span class="material-icons text-gray-900 text-3xl">place</span>
        </div>

        <div class="absolute bottom-6 left-6 right-6 sm:left-auto sm:right-6 bg-white border border-gray-100 px-6 py-5 rounded-2xl shadow-xl max-w-xs text-left">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-brand/10 text-brand flex items-center justify-center flex-shrink-0">
              <span class="material-icons text-sm">place</span>
            </div>
            <div>
              <p class="text-xs font-bold text-gray-900">Our Location</p>
              <p class="text-[10px] text-gray-500 mt-1 leading-relaxed">123 Education Street, Learning City, LC 12345</p>
              <span class="inline-block mt-3 text-[9px] font-black uppercase tracking-wider text-gray-400 bg-gray-100 px-2 py-0.5 rounded">INTERACTIVE MAP COMING SOON!</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="px-6 py-12 border-t border-gray-100 bg-[#fcfdfd]">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/>
              <circle cx="12" cy="12" r="1.5" fill="white"/>
            </svg>
          </div>
          <div class="flex flex-col">
            <div class="flex items-center">
              <span class="text-sm font-bold text-gray-800">Learn</span>
              <span class="text-sm font-bold text-brand">ify</span>
            </div>
          </div>
        </div>
        <p class="text-xs text-gray-400 leading-relaxed">A professional learning platform dedicated to depth, architectural excellence, and career mastery.</p>
      </div>
      <div>
        <p class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Mastery Tracks</p>
        <ul class="space-y-2 text-xs text-gray-400">
          <li><a href="/user/courses" class="hover:text-brand transition">Course Library</a></li>
          <li><a href="/tutor/signup" class="hover:text-brand transition">Tutor at Organiclearn</a></li>
          <li><a href="#" class="hover:text-brand transition">Certified Courses</a></li>
          <li><a href="#" class="hover:text-brand transition">Curriculum Paths</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Academic Support</p>
        <ul class="space-y-2 text-xs text-gray-400">
          <li><a href="/user/about" class="hover:text-brand transition">About Us</a></li>
          <li><a href="/tutor/signup" class="hover:text-brand transition">Become a Tutor</a></li>
          <li><a href="#" class="hover:text-brand transition">Privacy Policy</a></li>
          <li><a href="#" class="hover:text-brand transition">Whitepapers</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Ready to Learn?</p>
        <div class="flex gap-2">
          <input type="email" placeholder="your@email.com"
            class="flex-1 px-3 py-2 border border-gray-200 rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-brand/40" />
          <button class="px-3 py-2 bg-brand text-gray-900 text-xs font-bold rounded-lg hover:brightness-110 transition">Apply</button>
        </div>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-10 pt-6 border-t border-gray-100 text-center text-[10px] text-gray-400 uppercase tracking-widest">
      © 2026 Learnify — All Rights Reserved
    </div>
  </footer>

  <script>
    function toggleAccordion(button) {
      const item = button.closest('.accordion-item');
      
      // Close all other accordions
      document.querySelectorAll('.accordion-item').forEach(otherItem => {
        if (otherItem !== item) {
          otherItem.classList.remove('active');
        }
      });
      
      // Toggle current accordion
      item.classList.toggle('active');
    }

    function handleContactSubmit(event) {
      event.preventDefault();
      alert('Thank you for reaching out! Your message has been sent successfully. We will get back to you shortly.');
      document.getElementById('contactForm').reset();
    }
  </script>

</body>
</html>
