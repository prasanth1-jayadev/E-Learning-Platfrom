<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Organic Professional E-Learning Home v2 - Expert Edition</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;300;400;500;600;700;800;900&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2beead",
                        "background-light": "#f6f8f7",
                        "background-dark": "#10221c",
                        "deep-forest": "#0d1b17",
                    },
                    fontFamily: {
                        "display": ["Be Vietnam Pro", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        /* ── Fan Carousel ── */
.fan-stage { perspective: 1200px; perspective-origin: 50% 40%; }
.fan-track { position: relative; display: flex; align-items: center; justify-content: center; height: 440px; cursor: grab; }
.fan-track.dragging { cursor: grabbing; }
.fan-card { position: absolute; width: 300px; background: white; border-radius: 24px; overflow: hidden; cursor: pointer; transition: transform 0.6s cubic-bezier(0.34, 1.2, 0.64, 1), box-shadow 0.5s ease, opacity 0.4s ease; transform-origin: center bottom; box-shadow: 0 8px 32px rgba(0,0,0,0.08); border: 1.5px solid #e7f3ef; will-change: transform; user-select: none; }
.fan-card[data-pos="0"] { transform: translateX(0) translateZ(0) rotateY(0deg) scale(1); z-index: 10; box-shadow: 0 24px 64px rgba(43,238,173,0.18), 0 8px 32px rgba(0,0,0,0.12); }
.fan-card[data-pos="1"] { transform: translateX(260px) translateZ(-100px) rotateY(-18deg) scale(0.9); z-index: 7; }
.fan-card[data-pos="-1"] { transform: translateX(-260px) translateZ(-100px) rotateY(18deg) scale(0.9); z-index: 7; }
.fan-card[data-pos="2"] { transform: translateX(460px) translateZ(-220px) rotateY(-30deg) scale(0.78); z-index: 4; opacity: 0.75; }
.fan-card[data-pos="-2"] { transform: translateX(-460px) translateZ(-220px) rotateY(30deg) scale(0.78); z-index: 4; opacity: 0.75; }
.fan-card[data-pos="3"], .fan-card[data-pos="-3"] { transform: translateX(0) translateZ(-400px) scale(0.5); z-index: 1; opacity: 0; pointer-events: none; }
.fan-card[data-pos="0"] .active-badge { display: flex; }
.active-badge { display: none; }
.fan-card[data-pos="0"] .card-cta { opacity: 1; transform: translateY(0); }
.card-cta { opacity: 0; transform: translateY(8px); transition: opacity 0.4s 0.1s ease, transform 0.4s 0.1s ease; }
.fan-card:not([data-pos="0"]):hover { box-shadow: 0 12px 40px rgba(0,0,0,0.15); filter: brightness(1.04); }
.thumb-overlay { background: linear-gradient(180deg, transparent 40%, rgba(13,27,23,0.7) 100%); }
.dot { width: 6px; height: 6px; border-radius: 50%; background: #c5ddd7; transition: all 0.3s ease; cursor: pointer; }
.dot.active { width: 24px; border-radius: 3px; background: #2beead; }
.nav-btn { position: absolute; top: 50%; transform: translateY(-50%); width: 48px; height: 48px; border-radius: 50%; background: white; border: 1.5px solid #e7f3ef; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 20; transition: background 0.2s, border-color 0.2s, box-shadow 0.2s; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
.nav-btn:hover { background: #2beead; border-color: #2beead; box-shadow: 0 4px 20px rgba(43,238,173,0.35); }
.nav-btn:hover .nav-icon { color: #0d1b17; }
.nav-btn.left { left: 0; } .nav-btn.right { right: 0; }
.star-fill { color: #f59e0b; }
@keyframes popIn { 0% { transform: translateX(0) translateZ(0) rotateY(0deg) scale(0.92); } 60% { transform: translateX(0) translateZ(0) rotateY(0deg) scale(1.03); } 100% { transform: translateX(0) translateZ(0) rotateY(0deg) scale(1); } }
.fan-card[data-pos="0"].just-centered { animation: popIn 0.5s cubic-bezier(0.34, 1.2, 0.64, 1) forwards; }
        .course-card:hover .quick-view {
            opacity: 1;
            transform: translateY(0);
        }
        .quick-view {
            opacity: 0;
            transform: translateY(10px);
            transition: all 0.3s ease-in-out;
        }
        .sticky-nav {
            position: sticky;
            top: 0;
            z-index: 50;
            backdrop-filter: blur(8px);
        }
        .abstract-mesh {
            background-color: #f6f8f7;
            background-image: radial-gradient(at 0% 0%, #2beead33 0, transparent 50%), 
                              radial-gradient(at 100% 100%, #2beead22 0, transparent 50%),
                              linear-gradient(135deg, transparent 0%, rgba(43, 238, 173, 0.05) 100%);
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* Loading Screen Animations */
        @keyframes float {
            0%, 100% {
                transform: translateY(0px) scale(1);
            }
            50% {
                transform: translateY(-20px) scale(1.05);
            }
        }

        @keyframes spin-slow {
            from {
                transform: rotate(0deg);
            }
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes ping-slow {
            0% {
                transform: scale(1);
                opacity: 1;
            }
            50% {
                transform: scale(1.1);
                opacity: 0.5;
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        @keyframes pulse-slow {
            0%, 100% {
                opacity: 0.3;
                transform: scale(1);
            }
            50% {
                opacity: 0.6;
                transform: scale(1.2);
            }
        }

        @keyframes pulse-slower {
            0%, 100% {
                opacity: 0.2;
                transform: scale(1) rotate(0deg);
            }
            50% {
                opacity: 0.5;
                transform: scale(1.3) rotate(180deg);
            }
        }

        @keyframes orbit-1 {
            0% {
                transform: translate(0, 0) scale(1);
                opacity: 0.2;
            }
            25% {
                transform: translate(30px, -20px) scale(1.1);
                opacity: 0.3;
            }
            50% {
                transform: translate(50px, 10px) scale(1);
                opacity: 0.2;
            }
            75% {
                transform: translate(20px, 30px) scale(0.9);
                opacity: 0.25;
            }
            100% {
                transform: translate(0, 0) scale(1);
                opacity: 0.2;
            }
        }

        @keyframes orbit-2 {
            0% {
                transform: translate(0, 0) scale(1) rotate(0deg);
                opacity: 0.15;
            }
            25% {
                transform: translate(-25px, 25px) scale(1.15) rotate(90deg);
                opacity: 0.25;
            }
            50% {
                transform: translate(-40px, -10px) scale(1) rotate(180deg);
                opacity: 0.15;
            }
            75% {
                transform: translate(-15px, -30px) scale(0.95) rotate(270deg);
                opacity: 0.2;
            }
            100% {
                transform: translate(0, 0) scale(1) rotate(360deg);
                opacity: 0.15;
            }
        }

        @keyframes orbit-3 {
            0% {
                transform: translate(0, 0) scale(1);
                opacity: 0.1;
            }
            33% {
                transform: translate(15px, 35px) scale(1.2);
                opacity: 0.2;
            }
            66% {
                transform: translate(-20px, 20px) scale(0.9);
                opacity: 0.15;
            }
            100% {
                transform: translate(0, 0) scale(1);
                opacity: 0.1;
            }
        }

        .animate-orbit-1 {
            animation: orbit-1 8s ease-in-out infinite;
        }

        .animate-orbit-2 {
            animation: orbit-2 10s ease-in-out infinite;
        }

        .animate-orbit-3 {
            animation: orbit-3 12s ease-in-out infinite;
        }

        @keyframes slide-up {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes glow {
            0%, 100% {
                text-shadow: 0 0 20px rgba(0, 217, 177, 0.5);
            }
            50% {
                text-shadow: 0 0 30px rgba(0, 217, 177, 0.8), 0 0 40px rgba(0, 217, 177, 0.6);
            }
        }

        @keyframes loading-bar {
            0% {
                width: 0%;
            }
            100% {
                width: 100%;
            }
        }

        @keyframes fade-out-screen {
            from {
                opacity: 1;
            }
            to {
                opacity: 0;
            }
        }

        .animate-float {
            animation: float 3s ease-in-out infinite;
        }

        .animate-spin-slow {
            animation: spin-slow 3s linear infinite;
        }

        .animate-ping-slow {
            animation: ping-slow 2s ease-in-out infinite;
        }

        .animate-pulse-slow {
            animation: pulse-slow 4s ease-in-out infinite;
        }

        .animate-pulse-slower {
            animation: pulse-slower 5s ease-in-out infinite;
        }

        .animate-slide-up {
            animation: slide-up 0.8s ease-out forwards;
            animation-delay: 0.3s;
            opacity: 0;
        }

        .animate-slide-up-delay {
            animation: slide-up 0.8s ease-out forwards;
            animation-delay: 0.6s;
            opacity: 0;
        }

        .animate-slide-up-delay-2 {
            animation: slide-up 0.8s ease-out forwards;
            animation-delay: 0.9s;
            opacity: 0;
        }

        .animate-glow {
            animation: glow 2s ease-in-out infinite;
        }

        .animate-loading-bar {
            animation: loading-bar 2s ease-in-out forwards;
        }

        .animate-fade-out-screen {
            animation: fade-out-screen 0.6s ease-out forwards;
        }

        #loadingScreen {
            transition: opacity 0.6s ease-out, visibility 0.6s ease-out;
        }

        #loadingScreen.hidden {
            opacity: 0;
            visibility: hidden;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-[#0d1b17] dark:text-[#f8fcfa]">

    <!-- Loading Screen -->
    <div id="loadingScreen"
        class="fixed inset-0 z-[9999] flex items-center justify-center bg-gradient-to-br from-[#0a1612] via-[#0d1b17] to-[#1a3a30]">
        <div class="flex flex-col items-center gap-12">
            <!-- Animated Circles Background - Modern Orbital Animation -->
            <div class="absolute inset-0 overflow-hidden">
                <!-- Main orb -->
                <div class="absolute top-1/3 left-[42%] w-40 h-40 bg-primary/5 rounded-full blur-3xl animate-orbit-1">
                </div>
                <!-- Secondary orb -->
                <div class="absolute top-1/3 left-[42%] w-32 h-32 bg-primary/4 rounded-full blur-2xl animate-orbit-2">
                </div>
                <!-- Accent orb -->
                <div class="absolute top-1/3 left-[42%] w-24 h-24 bg-primary/3 rounded-full blur-xl animate-orbit-3">
                </div>
            </div>

            <!-- Main Logo Container -->
            <div class="relative z-10">
                <!-- Rotating Ring -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <div
                        class="w-40 h-40 rounded-full border-4 border-transparent border-t-primary border-r-primary/50 animate-spin-slow">
                    </div>
                </div>

                <!-- Pulsing Ring -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-32 h-32 rounded-full border-2 border-primary/30 animate-ping-slow"></div>
                </div>

                <!-- Logo Icon with Glow -->
                <div
                    class="relative w-24 h-24 bg-gradient-to-br from-[#00d9b1] to-[#00b894] rounded-2xl flex items-center justify-center shadow-2xl shadow-primary/50 animate-float">
                    <div class="absolute inset-0 bg-primary/20 rounded-2xl blur-xl animate-pulse"></div>
                    <svg class="relative w-14 h-14 text-white drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z" />
                        <circle cx="12" cy="12" r="1.5" fill="white" />
                    </svg>
                </div>
            </div>

            <!-- Brand Name with Animation -->
            <div class="relative z-10 flex flex-col items-center gap-4">
                <div class="flex items-center gap-1 animate-slide-up">
                    <span class="text-5xl font-black text-white tracking-tight">Learn</span>
                    <span class="text-5xl font-black text-[#00d9b1] tracking-tight animate-glow">ify</span>
                </div>

                <!-- Tagline -->
                <div class="flex items-center gap-3 animate-slide-up-delay">
                    <div class="h-px w-8 bg-gradient-to-r from-transparent to-primary"></div>
                    <p class="text-sm text-[#a0c5ba] font-medium tracking-widest uppercase">Learn Today, Lead Tomorrow
                    </p>
                    <div class="h-px w-8 bg-gradient-to-l from-transparent to-primary"></div>
                </div>
            </div>

            <!-- Loading Progress Bar -->
            <div class="relative z-10 w-64 h-1 bg-white/10 rounded-full overflow-hidden animate-slide-up-delay-2">
                <div class="h-full bg-gradient-to-r from-primary to-[#00b894] rounded-full animate-loading-bar"></div>
            </div>

            <!-- Loading Text -->
            <p class="relative z-10 text-primary/80 text-sm font-medium animate-pulse">Loading your experience...</p>
        </div>
    </div>

    <%- include('../partials/user-navbar') %>
