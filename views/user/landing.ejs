    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const courseContainer = document.querySelector('.flex.gap-6.overflow-x-auto.hide-scrollbar');
            const prevBtn = document.querySelector('.flex.gap-2 button:first-child');
            const nextBtn = document.querySelector('.flex.gap-2 button:last-child');
            
            if (courseContainer && prevBtn && nextBtn) {
                const scrollAmount = 350;
                
                prevBtn.addEventListener('click', function() {
                    courseContainer.scrollBy({
                        left: -scrollAmount,
                        behavior: 'smooth'
                    });
                });
                
                nextBtn.addEventListener('click', function() {
                    courseContainer.scrollBy({
                        left: scrollAmount,
                        behavior: 'smooth'
                    });
                });
            }
        });
    </script>

