                </div>
                <div class="lg:col-span-5 relative flex justify-center items-center h-[500px]">
                    <div class="absolute w-[120%] h-[120%] abstract-mesh -z-10 rounded-[4rem] opacity-50 blur-3xl">
                    </div>
                    <div class="relative w-full aspect-square max-w-[450px]">
                        <div class="absolute inset-0 bg-primary/20 rounded-[3rem] rotate-6 border border-primary/30">
                        </div>
                        <div
