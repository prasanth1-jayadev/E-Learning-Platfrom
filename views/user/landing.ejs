        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const track = document.getElementById('fanTrackLanding');
                const dotsContainer = document.getElementById('fanDotsLanding');
                const prevBtn = document.getElementById('fanPrevLanding');
                const nextBtn = document.getElementById('fanNextLanding');

                if (track && dotsContainer && prevBtn && nextBtn) {
                    const cards = Array.from(track.querySelectorAll('.fan-card'));
                    let current = 0;
                    const total = cards.length;
                    let autoTimer;
                    let dragStartX = 0;
                    let isDragging = false;

                    function getPos(index) {
                        let diff = index - current;
                        if (diff > total / 2) diff -= total;
                        if (diff < -total / 2) diff += total;
                        return Math.max(-3, Math.min(3, diff));
                    }

                    function updateDots() {
                        dotsContainer.querySelectorAll('.dot').forEach(function (dot, index) {
                            dot.classList.toggle('active', index === current);
                        });
                    }

                    function renderDots() {
                        dotsContainer.innerHTML = '';
                        cards.forEach(function (_, index) {
                            const dot = document.createElement('div');
                            dot.className = 'dot' + (index === current ? ' active' : '');
                            dot.addEventListener('click', function () {
                                goTo(index);
                            });
                            dotsContainer.appendChild(dot);
                        });
                    }

                    function updatePositions() {
                        cards.forEach(function (card, index) {
                            card.dataset.pos = getPos(index);
                        });
                        updateDots();
                    }

                    function goTo(index) {
                        current = ((index % total) + total) % total;
                        updatePositions();

                        setTimeout(function () {
                            const center = track.querySelector('.fan-card[data-pos="0"]');
                            if (center) {
                                center.classList.remove('just-centered');
                                void center.offsetWidth;
                                center.classList.add('just-centered');
                                setTimeout(function () {
                                    center.classList.remove('just-centered');
                                }, 500);
                            }
                        }, 50);
                    }

                    cards.forEach(function (card, index) {
                        card.addEventListener('click', function () {
                            if (getPos(index) !== 0) {
                                goTo(index);
                            } else if (card.dataset.courseUrl) {
                                window.location.href = card.dataset.courseUrl;
                            }
                        });
                    });

                    prevBtn.addEventListener('click', function () {
                        goTo(current - 1);
                    });

                    nextBtn.addEventListener('click', function () {
                        goTo(current + 1);
                    });

                    document.addEventListener('keydown', function (event) {
                        if (event.key === 'ArrowLeft') goTo(current - 1);
                        if (event.key === 'ArrowRight') goTo(current + 1);
                    });

                    track.addEventListener('mousedown', function (event) {
                        isDragging = true;
                        dragStartX = event.clientX;
                        track.classList.add('dragging');
                    });

                    document.addEventListener('mouseup', function (event) {
                        if (!isDragging) return;
                        isDragging = false;
                        track.classList.remove('dragging');
                        const delta = event.clientX - dragStartX;
                        if (Math.abs(delta) > 50) {
                            delta < 0 ? goTo(current + 1) : goTo(current - 1);
                        }
                    });

                    track.addEventListener('touchstart', function (event) {
                        dragStartX = event.touches[0].clientX;
                    }, { passive: true });

                    track.addEventListener('touchend', function (event) {
                        const delta = event.changedTouches[0].clientX - dragStartX;
                        if (Math.abs(delta) > 40) {
                            delta < 0 ? goTo(current + 1) : goTo(current - 1);
                        }
                    }, { passive: true });

                    function startAutoPlay() {
                        autoTimer = setInterval(function () {
                            goTo(current + 1);
                        }, 4000);
                    }

                    track.addEventListener('mouseenter', function () {
                        clearInterval(autoTimer);
                    });

                    track.addEventListener('mouseleave', startAutoPlay);

                    renderDots();
                    updatePositions();
                    startAutoPlay();
                }
            });

            // Loading Screen Handler
            window.addEventListener('load', function () {
                const loadingScreen = document.getElementById('loadingScreen');

                // Wait for minimum display time and page load
                setTimeout(function () {
                    loadingScreen.classList.add('hidden');

                    // Remove from DOM after transition
                    setTimeout(function () {
                        loadingScreen.remove();
                    }, 600);
                }, 1500); // Show for at least 1.5 seconds
            });

            // Fallback: Hide loading screen after maximum time
            setTimeout(function () {
                const loadingScreen = document.getElementById('loadingScreen');
                if (loadingScreen && !loadingScreen.classList.contains('hidden')) {
                    loadingScreen.classList.add('hidden');
                    setTimeout(function () {
                        loadingScreen.remove();
                    }, 600);
                }
            }, 5000); // Maximum 5 seconds
        </script>

</body>
