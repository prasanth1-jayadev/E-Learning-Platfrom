<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= tutor.fullName %> - Learnify</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#00d9b1'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gray-50">
  <%- include('../partials/user-navbar') %>

  <div class="max-w-7xl mx-auto px-6 py-12">
    
    <!-- Tutor Header Card -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8">
      <div class="flex flex-col md:flex-row items-start gap-8">
        
        <!-- Avatar -->
        <div class="flex-shrink-0">
          <% if (tutor.avatar) { %>
            <img src="<%= tutor.avatar %>" alt="<%= tutor.fullName %>" 
                 class="w-40 h-40 rounded-full object-cover border-4 border-primary/20">
          <% } else { %>
            <div class="w-40 h-40 rounded-full bg-gradient-to-br from-teal-500 to-teal-700 flex items-center justify-center border-4 border-primary/20">
              <span class="text-5xl font-bold text-white"><%= tutor.fullName.charAt(0).toUpperCase() %></span>
            </div>
          <% } %>
        </div>
        
        <!-- Info -->
        <div class="flex-1">
          <h1 class="text-4xl font-bold text-gray-900 mb-3"><%= tutor.fullName %></h1>
          
          <% if (tutor.bio) { %>
            <p class="text-lg text-gray-600 mb-6"><%= tutor.bio %></p>
          <% } else { %>
            <p class="text-lg text-gray-600 mb-6">Professional Instructor</p>
          <% } %>
          
          <!-- Stats Grid -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-6">
            <div class="text-center md:text-left">
              <p class="text-3xl font-bold text-primary"><%= totalCourses %></p>
              <p class="text-sm text-gray-500">Courses</p>
            </div>
            <div class="text-center md:text-left">
              <p class="text-3xl font-bold text-primary"><%= totalStudents %></p>
              <p class="text-sm text-gray-500">Students</p>
            </div>
            <div class="text-center md:text-left">
              <p class="text-3xl font-bold text-primary">4.8</p>
              <p class="text-sm text-gray-500">Rating</p>
            </div>
            <div class="text-center md:text-left">
              <p class="text-3xl font-bold text-primary"><%= tutor.subjects ? tutor.subjects.split(',').length : 0 %></p>
              <p class="text-sm text-gray-500">Subjects</p>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="flex flex-wrap gap-4">
            <% if (tutor.email) { %>
              <div class="flex items-center gap-2 text-gray-600">
                <i class="fas fa-envelope text-primary"></i>
                <span class="text-sm"><%= tutor.email %></span>
              </div>
            <% } %>
            <% if (tutor.phone) { %>
              <div class="flex items-center gap-2 text-gray-600">
                <i class="fas fa-phone text-primary"></i>
                <span class="text-sm"><%= tutor.phone %></span>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Subjects -->
      <% if (tutor.subjects) { %>
        <div class="mt-8 pt-8 border-t border-gray-200">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Specializations</h3>
          <div class="flex flex-wrap gap-2">
            <% tutor.subjects.split(',').forEach(subject => { %>
              <span class="px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-medium">
                <%= subject.trim() %>
              </span>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Courses Section -->
    <div class="bg-white rounded-2xl shadow-sm p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900">
          Courses by <%= tutor.fullName %>
        </h2>
        <span class="text-sm text-gray-500"><%= totalCourses %> course<%= totalCourses !== 1 ? 's' : '' %></span>
      </div>
      
      <% if (courses.length > 0) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% courses.forEach(course => { %>
            <a href="/user/course/<%= course._id %>" class="group block">
              <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300">
                <!-- Thumbnail -->
                <div class="relative overflow-hidden">
                  <% if (course.thumbnail) { %>
                    <img src="<%= course.thumbnail %>" alt="<%= course.title %>" 
                         class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-300">
                  <% } else { %>
                    <div class="w-full h-48 bg-gradient-to-br from-teal-500 to-teal-700 flex items-center justify-center">
                      <i class="fas fa-book text-white text-5xl"></i>
                    </div>
                  <% } %>
                  
                  <!-- Category Badge -->
                  <% if (course.category) { %>
                    <span class="absolute top-3 right-3 px-3 py-1 bg-white/90 backdrop-blur-sm rounded-full text-xs font-semibold text-gray-700">
                      <%= course.category.name %>
                    </span>
                  <% } %>
                </div>
                
                <!-- Content -->
                <div class="p-5">
                  <h3 class="font-bold text-gray-900 mb-2 group-hover:text-primary transition line-clamp-2">
                    <%= course.title %>
                  </h3>
                  
                  <% if (course.description) { %>
                    <p class="text-sm text-gray-600 mb-4 line-clamp-2">
                      <%= course.description %>
                    </p>
                  <% } %>
                  
                  <!-- Footer -->
                  <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                    <div class="flex items-center gap-2 text-gray-500 text-sm">
                      <i class="fas fa-play-circle"></i>
                      <span><%= course.lessons ? course.lessons.length : 0 %> lessons</span>
                    </div>
                    <p class="text-xl font-bold text-primary">
                      <% if (course.price === 0) { %>
                        Free
                      <% } else { %>
                        ₹<%= course.price.toLocaleString() %>
                      <% } %>
                    </p>
                  </div>
                </div>
              </div>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center py-12">
          <i class="fas fa-book-open text-gray-300 text-6xl mb-4"></i>
          <p class="text-gray-500 text-lg">No courses available yet</p>
        </div>
      <% } %>
    </div>

  </div>

  <!-- Footer -->
  <footer class="bg-white border-t border-gray-200 mt-12">
    <div class="max-w-7xl mx-auto px-6 py-8 text-center text-sm text-gray-500">
      © 2024 Learnify. All rights reserved.
    </div>
  </footer>

</body>
</html>
