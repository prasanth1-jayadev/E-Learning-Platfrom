<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= course.title %> - Learnify
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#00d9b1'
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50">
    <%- include('../partials/user-navbar') %>

        <div class="max-w-7xl mx-auto px-4 py-6">

            <a href="/user/courses" class="inline-flex items-center text-sm text-teal-600 hover:text-teal-700 mb-6">
                <i class="fas fa-arrow-left mr-2"></i>
                Back to Courses
            </a>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

                <div class="lg:col-span-2 space-y-6">

                    <div class="bg-black rounded-lg overflow-hidden">
                        <% if (course.lessons && course.lessons.length> 0 && course.lessons[0].videoUrl) { %>
                            <!-- First video is always free (preview) -->
                            <video id="mainVideo" controls controlsList="nodownload" oncontextmenu="return false;"
                                class="w-full h-[220px] sm:h-[320px] md:h-[400px] object-cover">
                                <source src="<%= course.lessons[0].videoUrl %>">
                                Your browser does not support the video tag.
                            </video>
                            <% if (!isPurchased && course.lessons.length> 1) { %>
                                <!-- Show preview badge for non-purchased users -->
                                <div class="bg-gradient-to-r from-teal-600 to-green-600 text-white px-4 py-2 text-sm">
                                    <i class="fas fa-eye mr-2"></i>
                                    <strong>Free Preview</strong> - Purchase to unlock <%= course.lessons.length - 1 %>
                                        more lesson<%= course.lessons.length - 1> 1 ? 's' : '' %>
                                </div>
                                <% } %>
                                    <% } else { %>

                                        <div class="text-white p-6 text-center">
                                            No video available
                                        </div>

                                        <% } %>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-xl font-bold text-gray-900">Course content</h2>
                            <span class="text-sm text-gray-500">
                                <%= course.lessons.length %> lessons
                            </span>
                        </div>

                        <div class="space-y-2">
                            <% if (course.lessons && course.lessons.length> 0) { %>
                                <% course.lessons.forEach((lesson, index)=> { %>
                                    <% if (index===0) { %>
                                        <!-- First lesson is always free (preview) -->
                                        <div id="lesson-item-0" onclick="playVideo('<%= lesson.videoUrl || '' %>', 0)"
                                            class="lesson-select-item border-2 border-teal-200 bg-teal-50 rounded-lg p-4 hover:bg-teal-100 transition cursor-pointer">
                                            <div class="flex items-center justify-between">
                                                <div class="flex items-center gap-3">
                                                    <div
                                                        class="w-10 h-10 rounded-full bg-teal-600 flex items-center justify-center flex-shrink-0">
                                                        <i class="fas fa-play text-white text-sm"></i>
                                                    </div>
                                                    <div>
                                                        <div class="flex items-center gap-2">
                                                            <h3 class="font-semibold text-gray-900 text-sm">
                                                                <%= lesson.title %>
                                                            </h3>
                                                            <span
                                                                class="px-2 py-0.5 bg-teal-600 text-white text-xs rounded-full font-semibold">FREE</span>
                                                        </div>
                                                        <p class="text-xs text-gray-600 mt-1">
                                                            <%= lesson.description || 'Watch this free preview lesson'
                                                                %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <span class="text-xs text-gray-600 font-semibold">
                                                    <%= Math.round((lesson.duration || 0) / 60) %> min
                                                </span>
                                            </div>
                                        </div>
                                        <% } else if (isPurchased) { %>
                                            <!-- Other lessons - unlocked for purchased users -->
                                            <div id="lesson-item-<%= index %>" onclick="playVideo('<%= lesson.videoUrl || '' %>', <%= index %>)"
                                                class="lesson-select-item border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition cursor-pointer">
                                                <div class="flex items-center justify-between">
                                                    <div class="flex items-center gap-3">
                                                        <div
                                                            class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center flex-shrink-0">
                                                            <i class="fas fa-play text-teal-600 text-sm"></i>
                                                        </div>
                                                        <div>
                                                            <h3 class="font-semibold text-gray-900 text-sm">
                                                                <%= lesson.title %>
                                                            </h3>
                                                            <p class="text-xs text-gray-500 mt-1">
                                                                <%= lesson.description || 'Lesson ' + (index + 1) %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                    <span class="text-xs text-gray-500">
                                                        <%= Math.round((lesson.duration || 0) / 60) %> min
                                                    </span>
                                                </div>
                                            </div>
                                            <% } else { %>
                                                <!-- Other lessons - locked for non-purchased users -->
                                                <div onclick="showPurchasePrompt()"
                                                    class="border border-gray-300 rounded-lg p-4 bg-gray-50 hover:bg-gray-100 transition cursor-pointer">
                                                    <div class="flex items-center justify-between">
                                                        <div class="flex items-center gap-3">
                                                            <div
                                                                class="w-10 h-10 rounded-full bg-gray-300 flex items-center justify-center flex-shrink-0">
                                                                <i class="fas fa-lock text-gray-600 text-sm"></i>
                                                            </div>
                                                            <div>
                                                                <h3 class="font-semibold text-gray-700 text-sm">
                                                                    <%= lesson.title %>
                                                                </h3>
                                                                <p class="text-xs text-gray-500 mt-1">
                                                                    <i class="fas fa-lock mr-1"></i>Locked - Purchase to
                                                                    unlock
                                                                </p>
                                                            </div>
                                                        </div>
                                                        <span class="text-xs text-gray-500">
                                                            <%= Math.round((lesson.duration || 0) / 60) %> min
                                                        </span>
                                                    </div>
                                                </div>
                                                <% } %>
                                                    <% }); %>
                                                        <% } else { %>
                                                            <div class="text-center py-8 text-gray-500">
                                                                <i class="fas fa-book-open text-4xl mb-3"></i>
                                                                <p>No lessons available yet</p>
                                                            </div>
                                                            <% } %>
                        </div>
                    </div>


                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <span
                            class="inline-block px-3 py-1 bg-teal-100 text-teal-700 text-xs font-semibold rounded-full mb-3">
                            <%= course.category %>
                        </span>



                        <h1 class="text-3xl font-bold text-gray-900 mb-3">
                            <%= course.title %>
                        </h1>

                        <!-- Rating Stars -->
                        <div class="flex items-center gap-2 mb-4">
                            <div class="flex items-center text-amber-400">
                                <% const fullStars=Math.floor(course.rating || 0); %>
                                    <% const hasHalf=(course.rating || 0) % 1>= 0.5; %>
                                        <% for(let i=1; i <=5; i++) { %>
                                            <% if (i <=fullStars) { %>
                                                <i class="fas fa-star"></i>
                                                <% } else if (i===fullStars + 1 && hasHalf) { %>
                                                    <i class="fas fa-star-half-alt"></i>
                                                    <% } else { %>
                                                        <i class="far fa-star text-gray-300"></i>
                                                        <% } %>
                                                            <% } %>
                            </div>
                            <span class="text-sm font-semibold text-gray-700">
                                <%= course.rating ? course.rating.toFixed(1) : '0.0' %>
                            </span>
                            <span class="text-xs text-gray-500">
                                (<%= course.reviewCount || 0 %> reviews)
                            </span>
                        </div>




                        <p class="text-gray-600 mb-4">
                            <%= course.description %>
                        </p>

                        <div class="flex items-center gap-6 text-sm text-gray-500">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-users text-teal-600"></i>
                                <span>
                                    <%= course.enrolledStudents.length %> students enrolled
                                </span>
                            </div>
                            <div class="flex items-center gap-2">
                                <i class="fas fa-clock text-teal-600"></i>
                                <span>Updated <%= new Date(course.updatedAt).toLocaleDateString('en-US', {
                                        month: 'short' , day: 'numeric' , year: 'numeric' }) %></span>
                            </div>
                            <div class="flex items-center gap-2">
                                <i class="fas fa-book text-teal-600"></i>
                                <span>
                                    <%= course.lessons.length %> lessons
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <div class="flex items-start gap-4 mb-6">

                            <a href="/user/tutor/<%= course.tutor._id %>" class="flex-shrink-0">
                                <% if (course.tutor.avatar) { %>
                                    <img src="<%= course.tutor.avatar %>" alt="<%= course.tutor.fullName %>"
                                        class="w-16 h-16 rounded-full object-cover hover:ring-4 hover:ring-primary/20 transition">
                                    <% } else { %>
                                        <div
                                            class="w-16 h-16 rounded-full bg-teal-100 flex items-center justify-center hover:ring-4 hover:ring-primary/20 transition">
                                            <span class="text-teal-700 font-bold text-xl">
                                                <%= course.tutor.fullName.charAt(0).toUpperCase() %>
                                            </span>
                                        </div>
                                        <% } %>
                            </a>

                            <div>
                                <!-- Clickable Tutor Name -->
                                <a href="/user/tutor/<%= course.tutor._id %>"
                                    class="text-lg font-bold text-gray-900 hover:text-teal-600 transition">
                                    <%= course.tutor.fullName %>
                                </a>

                                <p class="text-sm text-gray-500">
                                    Professional Instructor
                                </p>

                                <p class="text-sm text-gray-600 mt-2">
                                    <%= course.tutor.bio || 'Expert in ' + course.category
                                        + ' with years of teaching experience' %>
                                </p>
                            </div>

                        </div>
                    </div>
                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h2 class="text-xl font-bold text-gray-900 mb-4">What you'll learn</h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div class="flex items-start gap-3">
                                <i class="fas fa-check-circle text-teal-600 mt-1"></i>
                                <span class="text-sm text-gray-700">Master <%= course.category %> fundamentals and core
                                        concepts</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-check-circle text-teal-600 mt-1"></i>
                                <span class="text-sm text-gray-700">Build practical projects and real-world
                                    applications</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-check-circle text-teal-600 mt-1"></i>
                                <span class="text-sm text-gray-700">Learn industry best practices and professional
                                    techniques</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-check-circle text-teal-600 mt-1"></i>
                                <span class="text-sm text-gray-700">Get hands-on experience with practical
                                    lessons</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-check-circle text-teal-600 mt-1"></i>
                                <span class="text-sm text-gray-700">Develop problem-solving and analytical skills</span>
                            </div>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-check-circle text-teal-600 mt-1"></i>
                                <span class="text-sm text-gray-700">Apply knowledge to real-world scenarios and
                                    projects</span>
                            </div>
                        </div>
                    </div>



                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h2 class="text-xl font-bold text-gray-900 mb-4">About This Course</h2>
                        <p class="text-gray-700 leading-relaxed">
                            <%= course.description %>
                        </p>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h2 class="text-xl font-bold text-gray-900 mb-4">About the Instructor</h2>

                        <div class="flex items-start gap-4">
                            <% if (course.tutor.avatar) { %>
                                <img src="<%= course.tutor.avatar %>" alt="<%= course.tutor.fullName %>"
                                    class="w-20 h-20 rounded-full object-cover">
                                <% } else { %>
                                    <div class="w-20 h-20 rounded-full bg-teal-100 flex items-center justify-center">
                                        <span class="text-teal-700 font-bold text-2xl">
                                            <%= course.tutor.fullName.charAt(0).toUpperCase() %>
                                        </span>
                                    </div>
                                    <% } %>

                                        <div>
                                            <h3 class="text-lg font-bold text-gray-900 mb-1">
                                                <%= course.tutor.fullName %>
                                            </h3>
                                            <p class="text-sm text-gray-500 mb-2">Course Instructor</p>
                                            <p class="text-sm text-gray-700">
                                                <%= course.tutor.bio || 'I am a master in ' +
                                                    course.category.toLowerCase() %>
                                            </p>
                                        </div>
                        </div>
                    </div>

                    <!-- Reviews & Ratings Section -->
                    <div class="bg-white rounded-lg shadow-sm p-6 space-y-6">
                        <div class="flex items-center justify-between border-b pb-4">
                            <h2 class="text-xl font-bold text-gray-900">Student Reviews</h2>
                            <div class="flex items-center gap-2">
                                <span class="text-3xl font-extrabold text-teal-600">
                                    <%= course.rating ? course.rating.toFixed(1) : '0.0' %>
                                </span>
                                <div class="text-sm">
                                    <div class="flex text-amber-400">
                                        <% for(let i=1; i <=5; i++) { %>
                                            <% if (i <=Math.round(course.rating || 0)) { %>
                                                <i class="fas fa-star"></i>
                                                <% } else { %>
                                                    <i class="far fa-star text-gray-300"></i>
                                                    <% } %>
                                                        <% } %>
                                    </div>
                                    <p class="text-gray-500 text-xs mt-0.5">
                                        <%= course.reviewCount || 0 %> course ratings
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Write Review Form (Only visible to users who paid & haven't reviewed yet) -->
                        <% if (isPurchased) { %>
                            <% if (!hasReviewed) { %>
                                <div class="bg-gray-50 p-5 rounded-lg border border-gray-100">
                                    <h3 class="font-bold text-gray-800 mb-3 text-base">Rate & Review this Course</h3>
                                    <form id="reviewForm" class="space-y-4">
                                        <!-- Star Selector -->
                                        <div>
                                            <label class="block text-sm font-semibold text-gray-700 mb-1">Your
                                                Rating</label>
                                            <div class="flex gap-2 text-2xl text-gray-300 cursor-pointer"
                                                id="starSelector">
                                                <i class="far fa-star hover:text-amber-400 star-btn" data-value="1"></i>
                                                <i class="far fa-star hover:text-amber-400 star-btn" data-value="2"></i>
                                                <i class="far fa-star hover:text-amber-400 star-btn" data-value="3"></i>
                                                <i class="far fa-star hover:text-amber-400 star-btn" data-value="4"></i>
                                                <i class="far fa-star hover:text-amber-400 star-btn" data-value="5"></i>
                                            </div>
                                            <input type="hidden" name="rating" id="ratingInput" value="0">
                                        </div>

                                        <!-- Review Comment -->
                                        <div>
                                            <label for="comment"
                                                class="block text-sm font-semibold text-gray-700 mb-1">Your
                                                Review</label>
                                            <textarea id="comment" name="comment" rows="3" required
                                                placeholder="Write your review here..."
                                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"></textarea>
                                        </div>

                                        <button type="submit"
                                            class="bg-teal-600 hover:bg-teal-700 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm shadow">
                                            Submit Review
                                        </button>
                                    </form>
                                </div>
                                <% } else { %>
                                    <div class="bg-teal-50 border border-teal-100 rounded-lg p-4 text-center">
                                        <i class="fas fa-check-circle text-teal-600 text-xl mb-2"></i>
                                        <h4 class="font-semibold text-teal-800 text-sm">Thank you for reviewing!</h4>
                                        <p class="text-teal-700 text-xs mt-1">You have already submitted a rating for
                                            this course.</p>
                                    </div>
                                    <% } %>
                                        <% } else { %>
                                            <div
                                                class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center text-sm text-gray-500">
                                                <i class="fas fa-lock text-gray-400 mb-1 text-lg"></i>
                                                <p>You must purchase and enroll in this course to leave a review.</p>
                                            </div>
                                            <% } %>

                                                <!-- Review List -->
                                                <div class="space-y-4 pt-2">
                                                    <% if (reviews && reviews.length> 0) { %>
                                                        <% reviews.forEach(review=> { %>
                                                            <div
                                                                class="border-b border-gray-100 pb-4 last:border-b-0 last:pb-0">
                                                                <div class="flex items-start gap-3">
                                                                    <!-- User Avatar -->
                                                                    <% if (review.user.avatar) { %>
                                                                        <img src="<%= review.user.avatar %>"
                                                                            alt="<%= review.user.fullName %>"
                                                                            class="w-10 h-10 rounded-full object-cover">
                                                                        <% } else { %>
                                                                            <div
                                                                                class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center font-bold text-teal-700 text-sm">
                                                                                <%= review.user.fullName.charAt(0).toUpperCase()
                                                                                    %>
                                                                            </div>
                                                                            <% } %>

                                                                                <div class="flex-1 min-w-0">
                                                                                    <div
                                                                                        class="flex items-center justify-between gap-2">
                                                                                        <h4
                                                                                            class="font-bold text-gray-900 text-sm">
                                                                                            <%= review.user.fullName %>
                                                                                        </h4>
                                                                                        <span
                                                                                            class="text-xs text-gray-400">
                                                                                            <%= new
                                                                                                Date(review.createdAt).toLocaleDateString('en-US',
                                                                                                { month: 'short' ,
                                                                                                day: 'numeric' ,
                                                                                                year: 'numeric' }) %>
                                                                                        </span>
                                                                                    </div>

                                                                                    <!-- Review Stars -->
                                                                                    <div
                                                                                        class="flex text-amber-400 text-xs my-1">
                                                                                        <% for(let i=1; i <=5; i++) { %>
                                                                                            <% if (i <=review.rating) {
                                                                                                %>
                                                                                                <i
                                                                                                    class="fas fa-star"></i>
                                                                                                <% } else { %>
                                                                                                    <i
                                                                                                        class="far fa-star text-gray-300"></i>
                                                                                                    <% } %>
                                                                                                        <% } %>
                                                                                    </div>

                                                                                    <p
                                                                                        class="text-gray-700 text-sm mt-1 leading-relaxed">
                                                                                        <%= review.comment %>
                                                                                    </p>
                                                                                </div>
                                                                </div>
                                                            </div>
                                                            <% }); %>
                                                                <% } else { %>
                                                                    <div class="text-center py-6 text-gray-400 text-sm">
                                                                        <i
                                                                            class="far fa-comment-dots text-3xl mb-2 text-gray-300"></i>
                                                                        <p>No reviews yet. Be the first to share your
                                                                            thoughts!</p>
                                                                    </div>
                                                                    <% } %>
                                                </div>
                    </div>
                </div>

                <div class="lg:col-span-1">
                    <div class="bg-white rounded-lg shadow-lg overflow-hidden sticky top-6">

                        <% if (course.thumbnail) { %>
                            <img src="<%= course.thumbnail %>" alt="<%= course.title %>"
                                class="w-full h-48 object-cover">
                            <% } else { %>
                                <div
                                    class="w-full h-48 bg-gradient-to-br from-teal-500 to-teal-700 flex items-center justify-center">
                                    <i class="fas fa-book text-white text-6xl"></i>
                                </div>
                                <% } %>

                                    <div class="p-6">

                                        <div class="mb-4">
                                            <% if (course.price===0) { %>
                                                <span class="text-3xl font-bold text-teal-600">Free</span>
                                                <% } else { %>
                                                    <span class="text-3xl font-bold text-teal-600">₹<%=
                                                            course.price.toLocaleString() %></span>
                                                    <% } %>
                                        </div>

                                        <!-- Buttons based on purchase status -->
                                        <% if (isPurchased) { %>
                                            <!-- Already Purchased -->
                                            <div
                                                class="mb-3 p-3 bg-green-50 border border-green-200 rounded-lg text-center">
                                                <i class="fas fa-check-circle text-green-600 mr-2"></i>
                                                <span class="text-green-700 font-semibold">Already Enrolled</span>
                                            </div>
                                            <button onclick="window.location.href='/user/courses'"
                                                class="w-full bg-teal-600 text-white font-semibold py-3 rounded-lg hover:bg-teal-700 transition mb-3">
                                                <i class="fas fa-play-circle mr-2"></i>Continue Learning
                                            </button>
                                            <button onclick="startChat('<%= course._id %>', '<%= course.tutor._id %>')"
                                                class="w-full border-2 border-teal-600 text-teal-600 font-semibold py-2 rounded-lg hover:bg-teal-50 transition mb-3">
                                                <i class="fas fa-comments mr-1"></i>Chat with Tutor
                                            </button>

                                            <% } else { %>
                                                <!-- Not Purchased -->
                                                <% if (!user) { %>
                                                    <!-- User not logged in -->
                                                    <button onclick="window.location.href='/user/login'"
                                                        class="w-full bg-teal-600 text-white font-semibold py-3 rounded-lg hover:bg-teal-700 transition mb-3">
                                                        <i class="fas fa-sign-in-alt mr-2"></i>Login to Enroll
                                                    </button>
                                                    <% } else { %>
                                                        <!-- User logged in -->
                                                        <% if (course.price===0) { %>
                                                            <!-- Free Course - Show Enroll Now -->
                                                            <button onclick="enrollFreeCourse('<%= course._id %>')"
                                                                class="w-full bg-teal-600 text-white font-bold py-4 rounded-xl hover:bg-teal-700 transition mb-3 text-lg shadow-lg">
                                                                <i class="fas fa-graduation-cap mr-2"></i>Enroll Now
                                                            </button>
                                                            <div class="flex gap-3">
                                                                <button
                                                                    class="flex-1 border-2 border-teal-600 text-teal-600 font-semibold py-3 rounded-xl hover:bg-teal-50 transition flex items-center justify-center">
                                                                    <i class="fas fa-shopping-cart text-xl"></i>
                                                                </button>
                                                                <button
                                                                    class="flex-1 border-2 border-gray-300 text-gray-600 font-semibold py-3 rounded-xl hover:bg-gray-50 transition flex items-center justify-center">
                                                                    <i class="fas fa-heart text-xl"></i>
                                                                </button>
                                                            </div>
                                                            <% } else { %>
                                                                <!-- Paid Course - Enroll Now as main button -->
                                                                <button
                                                                    onclick="enrollNowDirect('<%= course._id %>', '<%= course.price %>', '<%= course.title %>')"
                                                                    class="w-full bg-teal-600 text-white font-bold py-2 rounded-xl hover:bg-teal-700 transition mb-3 text-lg shadow-lg">
                                                                    <i class="fas fa-graduation-cap mr-2"></i>Enroll Now
                                                                </button>
                                                                <div class="flex gap-3">
                                                                    <% if (isInCart) { %>
                                                                        <!-- Already in Cart - Disabled State -->
                                                                        <button disabled
