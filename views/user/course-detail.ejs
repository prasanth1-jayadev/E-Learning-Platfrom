        <!-- your entire page code -->

        <!-- Razorpay Checkout Script -->
        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

        <script>
            const isPurchased = <%= isPurchased ? 'true' : 'false' %>;
            const totalLessons = <%= course.lessons.length %>;

            function playVideo(url, lessonIndex) {
                // First lesson (index 0) is always free
                if (lessonIndex === 0) {
                    // Allow playing first video for everyone
                    const video = document.getElementById('mainVideo');
                    const source = video.querySelector("source");

                    if (!url) {
                        console.error("No video URL found");
                        return;
                    }

                    source.src = url;
                    video.load();
                    video.play();

                    video.scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });
                    return;
                }

                // For other lessons, check if user has purchased
                if (!isPurchased && lessonIndex > 0) {
                    showPurchasePrompt();
                    return;
                }

                // Play video for purchased users
                const video = document.getElementById('mainVideo');
                const source = video.querySelector("source");

                if (!url) {
                    console.error("No video URL found");
                    return;
                }

                source.src = url;
                video.load();
                video.play();

                video.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
            }

            function showPurchasePrompt() {
                Swal.fire({
                    title: '🔒 Lesson Locked',
                    html: `
        <p class="text-gray-600 mb-4">This lesson is locked. Purchase the course to unlock all ${totalLessons - 1} remaining lessons.</p>
        <div class="bg-teal-50 border border-teal-200 rounded-lg p-4 text-left">
          <p class="font-semibold text-teal-900 mb-2">What you'll get:</p>
          <ul class="text-sm text-gray-700 space-y-1">
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Access to all ${totalLessons} video lessons</li>
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Lifetime access to course content</li>
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Certificate of completion</li>
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Learn at your own pace</li>
          </ul>
        </div>
      `,
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonColor: '#00d9b1',
                    cancelButtonColor: '#6B7280',
                    confirmButtonText: '<i class="fas fa-shopping-cart mr-2"></i>Purchase Now',
                    cancelButtonText: 'Maybe Later'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Scroll to purchase section
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                });
            }

            // Prevent right-click on video
            document.addEventListener('contextmenu', function (e) {
                if (e.target.tagName === 'VIDEO' || e.target.tagName === 'SOURCE') {
                    e.preventDefault();
                    return false;
                }
            });

            // Add to Cart
            async function addToCart(courseId) {
                try {
                    const response = await fetch('/user/cart/add', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ courseId })
                    });

                    const data = await response.json();

                    if (data.success) {
                        // Update cart count in navbar
                        if (typeof window.updateCartCount === 'function') {
                            window.updateCartCount();
                        }

                        await Swal.fire({
                            title: 'Added to Cart!',
                            text: 'Course has been added to your cart.',
                            icon: 'success',
                            showCancelButton: true,
                            confirmButtonColor: '#00d9b1',
                            cancelButtonColor: '#6B7280',
                            confirmButtonText: 'View Cart',
                            cancelButtonText: 'Continue Shopping'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '/user/cart';
                            } else {
                                window.location.reload();
                            }
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message || 'Failed to add to cart',
                            icon: 'error'
                        });
                    }
                } catch (error) {
                    console.error('Add to cart error:', error);
                    Swal.fire({
                        title: 'Error!',
                        text: 'Failed to add to cart. Please try again.',
                        icon: 'error'
                    });
                }
            }

            // Enroll Now Direct (Single Course Payment)
            async function enrollNowDirect(courseId, price, title) {
                try {
                    const response = await fetch('/user/payment/create-order', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ courseIds: [courseId] })
                    });

                    const data = await response.json();

                    if (!data.success) {
                        alert(data.message || 'Failed to create order');
                        return;
                    }

                    const options = {
                        key: 'rzp_test_RXk9uJlrmjEW0r',
                        amount: data.order.amount,
                        currency: data.order.currency,
                        name: 'Learnify',
                        description: title,
                        order_id: data.order.id,
                        handler: async function (response) {
                            const verifyResponse = await fetch('/user/payment/verify', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature,
                                    courseIds: [courseId]
                                })
                            });

                            const verifyData = await verifyResponse.json();

                            console.log('Payment verification response:', verifyData);

                            if (verifyData.success) {
                                console.log('Redirecting to:', verifyData.redirectUrl);
                                // Redirect to success page
                                window.location.href = verifyData.redirectUrl || '/user/payment/success';
                            } else {
                                console.log('Payment failed, redirecting to failure page');
                                // Redirect to failure page
                                window.location.href = `/user/payment/failure?error=${encodeURIComponent(verifyData.message)}&courseIds=${courseId}`;
                            }
                        },
                        prefill: {
                            name: '<%= user ? user.fullName : "" %>',
                            email: '<%= user ? user.email : "" %>'
                        },
                        theme: {
                            color: '#00d9b1'
                        },
                        modal: {
                            ondismiss: function () {
                                // Redirect to failure page if user closes modal
                                window.location.href = `/user/payment/failure?error=Payment cancelled by user&courseIds=${courseId}`;
                            }
                        }
                    };

                    const razorpay = new Razorpay(options);
                    razorpay.on('payment.failed', function (response) {
                        // Redirect to failure page on payment failure
                        window.location.href = `/user/payment/failure?orderId=${response.error.metadata.order_id}&error=${encodeURIComponent(response.error.description)}&courseIds=${courseId}`;
                    });
                    razorpay.open();

                } catch (error) {
                    console.error('Payment error:', error);
                    alert('Payment failed. Please try again.');
                }
            }

            // Enroll in Free Course
            async function enrollFreeCourse(courseId) {
                try {
                    const response = await fetch('/user/enroll-free', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ courseId })
                    });

                    const data = await response.json();

                    if (data.success) {
                        alert('Successfully enrolled in the course!');
                        window.location.reload();
                    } else {
                        alert(data.message || 'Enrollment failed');
                    }
                } catch (error) {
                    console.error('Enrollment error:', error);
                    alert('Enrollment failed. Please try again.');
                }
            }
        </script>


</body>

</html>