        <!-- your entire page code -->

        <!-- Razorpay Checkout Script -->
        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

        <script>
            const isPurchased = <%= isPurchased ? 'true' : 'false' %>;
            const totalLessons = <%= course.lessons.length %>;

            function playVideo(url, lessonIndex) {
                // First lesson (index 0) is always free
                if (lessonIndex === 0) {
                    // Allow playing first video for everyone
                    const video = document.getElementById('mainVideo');
                    const source = video.querySelector("source");

                    if (!url) {
                        console.error("No video URL found");
                        return;
                    }

                    source.src = url;
                    video.load();
                    video.play();

                    video.scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });
                    
                    updateActiveLessonHighlight(lessonIndex);
                    return;
                }

                // For other lessons, check if user has purchased
                if (!isPurchased && lessonIndex > 0) {
                    showPurchasePrompt();
                    return;
                }

                // Play video for purchased users
                const video = document.getElementById('mainVideo');
                const source = video.querySelector("source");

                if (!url) {
                    console.error("No video URL found");
                    return;
                }

                source.src = url;
                video.load();
                video.play();

                video.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
                
                updateActiveLessonHighlight(lessonIndex);
            }

            function updateActiveLessonHighlight(lessonIndex) {
                document.querySelectorAll('.lesson-select-item').forEach((item, idx) => {
                    if (idx === lessonIndex) {
                        item.classList.remove('border-teal-200', 'bg-teal-50', 'border-gray-200', 'bg-white', 'hover:bg-gray-50');
                        item.classList.add('border-2', 'border-teal-500', 'bg-teal-50/50');
                    } else {
                        if (idx === 0) {
                            item.classList.remove('border-teal-500', 'bg-teal-50/50');
                            item.classList.add('border-2', 'border-teal-200', 'bg-teal-50');
                        } else {
                            item.classList.remove('border-teal-500', 'border-2', 'bg-teal-50/50');
                            item.classList.add('border', 'border-gray-200');
                        }
                    }
                });
            }

            function showPurchasePrompt() {
                Swal.fire({
                    title: '🔒 Lesson Locked',
                    html: `
        <p class="text-gray-600 mb-4">This lesson is locked. Purchase the course to unlock all ${totalLessons - 1} remaining lessons.</p>
        <div class="bg-teal-50 border border-teal-200 rounded-lg p-4 text-left">
          <p class="font-semibold text-teal-900 mb-2">What you'll get:</p>
          <ul class="text-sm text-gray-700 space-y-1">
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Access to all ${totalLessons} video lessons</li>
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Lifetime access to course content</li>
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Certificate of completion</li>
            <li><i class="fas fa-check text-teal-600 mr-2"></i>Learn at your own pace</li>
          </ul>
        </div>
      `,
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonColor: '#00d9b1',
                    cancelButtonColor: '#6B7280',
                    confirmButtonText: '<i class="fas fa-shopping-cart mr-2"></i>Purchase Now',
                    cancelButtonText: 'Maybe Later'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Scroll to purchase section
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                });
            }

            // Prevent right-click on video
            document.addEventListener('contextmenu', function (e) {
                if (e.target.tagName === 'VIDEO' || e.target.tagName === 'SOURCE') {
                    e.preventDefault();
                    return false;
                }
            });

            // Add to Cart
            async function addToCart(courseId) {
                try {
                    const response = await fetch('/user/cart/add', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ courseId })
                    });

                    const data = await response.json();

                    if (data.success) {
                        // Update cart count in navbar
                        if (typeof window.updateCartCount === 'function') {
                            window.updateCartCount();
                        }

                        await Swal.fire({
                            title: 'Added to Cart!',
                            text: 'Course has been added to your cart.',
                            icon: 'success',
                            showCancelButton: true,
                            confirmButtonColor: '#00d9b1',
                            cancelButtonColor: '#6B7280',
                            confirmButtonText: 'View Cart',
                            cancelButtonText: 'Continue Shopping'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '/user/cart';
                            } else {
                                window.location.reload();
                            }
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message || 'Failed to add to cart',
                            icon: 'error'
                        });
                    }
                } catch (error) {
                    console.error('Add to cart error:', error);
                    Swal.fire({
                        title: 'Error!',
                        text: 'Failed to add to cart. Please try again.',
                        icon: 'error'
                    });
                }
            }

            // Wishlist Functions
            let isInWishlist = false;

            // Check if course is in wishlist on page load
            async function checkWishlist(courseId) {
                try {
                    const response = await fetch(`/user/wishlist/check/${courseId}`);
                    const data = await response.json();
                    isInWishlist = data.inWishlist;
                    updateWishlistButton();
                } catch (error) {
                    console.error('Check wishlist error:', error);
                }
            }

            // Toggle wishlist
            async function toggleWishlist(courseId) {
                try {
                    const url = isInWishlist
                        ? `/user/wishlist/remove/${courseId}`
                        : '/user/wishlist/add';

                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: isInWishlist ? null : JSON.stringify({ courseId })
                    });

                    const data = await response.json();

                    if (data.success) {
                        isInWishlist = !isInWishlist;
                        updateWishlistButton();

                        if (typeof window.updateWishlistCount === 'function') {
                            window.updateWishlistCount();
                        }

                        Swal.fire({
                            title: 'Success!',
                            text: data.message,
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message,
                            icon: 'error'
                        });
                    }
                } catch (error) {
                    console.error('Wishlist error:', error);
                    Swal.fire({
                        title: 'Error!',
                        text: 'Something went wrong',
                        icon: 'error'
                    });
                }
            }

            // Update wishlist button appearance
            function updateWishlistButton() {
                const btn = document.getElementById('wishlistBtn');
                const icon = document.getElementById('wishlistIcon');

                if (btn && icon) {
                    if (isInWishlist) {
                        btn.classList.remove('border-gray-300', 'text-gray-600');
                        btn.classList.add('border-red-500', 'text-red-500', 'bg-red-50');
                    } else {
                        btn.classList.add('border-gray-300', 'text-gray-600');
                        btn.classList.remove('border-red-500', 'text-red-500', 'bg-red-50');
                    }
                }
            }

            // Check wishlist status on page load
            checkWishlist('<%= course._id %>');

            // Highlight the first lesson by default on load
            updateActiveLessonHighlight(0);

            // Enroll Now Direct (Single Course Payment)
            async function enrollNowDirect(courseId, price, title) {
                try {
                    const response = await fetch('/user/payment/create-order', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ courseIds: [courseId] })
                    });

                    const data = await response.json();

                    if (!data.success) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Order Failed',
                            text: data.message || 'Failed to create order',
                            confirmButtonColor: '#00d9b1'
                        });
                        return;
                    }

                    const options = {
                        key: 'rzp_test_RXk9uJlrmjEW0r',
                        amount: data.order.amount,
                        currency: data.order.currency,
                        name: 'Learnify',
                        description: title,
                        order_id: data.order.id,
                        handler: async function (response) {
                            const verifyResponse = await fetch('/user/payment/verify', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature,
                                    courseIds: [courseId]
                                })
                            });

                            const verifyData = await verifyResponse.json();

                            console.log('Payment verification response:', verifyData);

                            if (verifyData.success) {
                                console.log('Redirecting to:', verifyData.redirectUrl);
                                // Redirect to success page
                                window.location.href = verifyData.redirectUrl || '/user/payment/success';
                            } else {
                                console.log('Payment failed, redirecting to failure page');
                                // Redirect to failure page
                                window.location.href = `/user/payment/failure?error=${encodeURIComponent(verifyData.message)}&courseIds=${courseId}`;
                            }
                        },
                        prefill: {
                            name: '<%= user ? user.fullName : "" %>',
                            email: '<%= user ? user.email : "" %>'
                        },
                        theme: {
                            color: '#00d9b1'
                        },
                        modal: {
                            ondismiss: function () {
                                // Redirect to failure page if user closes modal
                                window.location.href = `/user/payment/failure?error=Payment cancelled by user&courseIds=${courseId}`;
                            }
                        }
                    };

                    const razorpay = new Razorpay(options);
                    razorpay.on('payment.failed', function (response) {
                        // Redirect to failure page on payment failure
                        window.location.href = `/user/payment/failure?orderId=${response.error.metadata.order_id}&error=...&courseIds=${courseId}`;

                    });
                    razorpay.open();

                } catch (error) {
                    console.error('Payment error:', error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Payment Failed',
                        text: 'Payment failed. Please try again.',
                        confirmButtonColor: '#00d9b1'
                    });
                }
            }

            // Enroll in Free Course
            async function enrollFreeCourse(courseId) {
                try {
                    const response = await fetch('/user/enroll-free', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ courseId })
                    });

                    const data = await response.json();

                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: 'Successfully enrolled in the course!',
                            confirmButtonColor: '#00d9b1'
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Enrollment Failed',
                            text: data.message || 'Enrollment failed',
                            confirmButtonColor: '#00d9b1'
                        });
                    }
                } catch (error) {
                    console.error('Enrollment error:', error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Enrollment failed. Please try again.',
                        confirmButtonColor: '#00d9b1'
                    });
                }
            }

            async function startChat(courseId, tutorId) {
                try {
                    const res = await fetch('/chat/conversation/individual', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ courseId, tutorId })
                    });
                    const data = await res.json();
                    if (data.success) {
                        window.location.href = '/user/chat';
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                    }
                } catch (err) {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to start chat' });
                }
            }

            // --- Interactive Star Selector & Submit Logic ---
            document.addEventListener('DOMContentLoaded', () => {
                const starSelector = document.getElementById('starSelector');
                const ratingInput = document.getElementById('ratingInput');
                const reviewForm = document.getElementById('reviewForm');

                if (starSelector && ratingInput) {
                    const stars = starSelector.querySelectorAll('.star-btn');

                    stars.forEach(star => {
                        // Highlight stars on mouse over
                        star.addEventListener('mouseover', function () {
                            const hoverVal = parseInt(this.getAttribute('data-value'));
                            highlightStars(hoverVal);
                        });

                        // Reset to selected rating on mouse leave
                        star.addEventListener('mouseleave', function () {
                            const currentVal = parseInt(ratingInput.value);
                            highlightStars(currentVal);
                        });

                        // Set rating on click
                        star.addEventListener('click', function () {
                            const clickVal = parseInt(this.getAttribute('data-value'));
                            ratingInput.value = clickVal;
                            highlightStars(clickVal);
                        });
                    });

                    function highlightStars(count) {
                        stars.forEach(s => {
                            const val = parseInt(s.getAttribute('data-value'));
                            if (val <= count) {
                                s.classList.remove('far', 'text-gray-300');
                                s.classList.add('fas', 'text-amber-400');
                            } else {
                                s.classList.remove('fas', 'text-amber-400');
                                s.classList.add('far', 'text-gray-300');
                            }
                        });
                    }
                }

                if (reviewForm) {
                    reviewForm.addEventListener('submit', async (e) => {
                        e.preventDefault();

                        const rating = parseInt(ratingInput.value);
                        const comment = document.getElementById('comment').value.trim();

                        if (!rating || rating === 0) {
                            Swal.fire({
                                icon: 'warning',
                                title: 'Rating Required',
                                text: 'Please select a star rating (1 to 5 stars) before submitting.',
                                confirmButtonColor: '#00d9b1'
                            });
                            return;
                        }

                        try {
                            const courseId = '<%= course._id %>';
                            const response = await fetch(`/user/course/${courseId}/review`, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ rating, comment })
                            });

                            const data = await response.json();

                            if (data.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thank You!',
                                    text: data.message,
                                    confirmButtonColor: '#00d9b1'
                                }).then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Submission Failed',
                                    text: data.message || 'Something went wrong',
                                    confirmButtonColor: '#00d9b1'
                                });
                            }
                        } catch (err) {
                            console.error('Review submit error:', err);
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'Unable to submit review. Please try again later.',
                                confirmButtonColor: '#00d9b1'
                            });
                        }
                    });
                }
            });
        </script>


