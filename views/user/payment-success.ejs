<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Successful - Learnify</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {    
                extend: {
                    colors: {
                        primary: '#00d9b1'
                    }
                }
            }
        }
    </script>
    <style>
        body {
            overflow-x: hidden;
        }

        /* Success Modal Animation */
        @keyframes modalFadeIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .success-modal {
            animation: modalFadeIn 0.4s ease-out;
        }

        /* Checkmark Animation */
        @keyframes drawCheck {
            0% {
                stroke-dashoffset: 100;
            }
            100% {
                stroke-dashoffset: 0;
            }
        }

        @keyframes scaleIn {
            0% {
                transform: scale(0);
                opacity: 0;
            }
            60% {
                transform: scale(1.1);
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .checkmark-circle {
            animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .checkmark-path {
            stroke-dasharray: 100;
            stroke-dashoffset: 100;
            animation: drawCheck 0.5s ease-out 0.3s forwards;
        }

        /* Confetti */
        .confetti {
            position: fixed;
            width: 8px;
            height: 8px;
            pointer-events: none;
            z-index: 9999;
        }

        @keyframes confettiFall {
            to {
                transform: translateY(100vh) rotate(360deg);
                opacity: 0;
            }
        }

        /* Fade In */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }

        /* Backdrop */
        .backdrop-blur-custom {
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }
    </style>
</head>
<body class="bg-gray-50">
    
    <!-- Success Modal Popup -->
    <div id="successModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 backdrop-blur-custom bg-black/40">
        <div class="success-modal bg-white rounded-2xl shadow-2xl max-w-md w-full p-10 text-center">
            
            <!-- Success Icon -->
            <div class="mb-6 flex justify-center">
                <svg class="checkmark-circle" width="100" height="100" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="45" fill="#00d9b1" opacity="0.1"/>
                    <circle cx="50" cy="50" r="40" fill="none" stroke="#00d9b1" stroke-width="4"/>
                    <path class="checkmark-path" d="M 30 50 L 43 63 L 70 36" fill="none" stroke="#00d9b1" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>

            <!-- Success Message -->
            <div class="fade-in-up" style="animation-delay: 0.4s; opacity: 0;">
                <h1 class="text-3xl font-bold text-gray-900 mb-3">
                    Payment Successful!
                </h1>
                <p class="text-gray-600 mb-8">
                    Your payment has been processed successfully.
                </p>
                
                <button onclick="closeModal()" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200">
                    Continue
                </button>
                
                <!-- Manual Play Button (hidden by default, shows only if needed) -->
                <button id="manualPlayBtn" onclick="manualPlaySound()" class="mt-3 text-teal-600 hover:text-teal-700 text-sm underline hidden">
                    🔊 Click to play success sound
                </button>
            </div>
        </div>
    </div>

    <%- include('../partials/user-navbar') %>
    
    <div class="max-w-5xl mx-auto px-4 py-12">
        
        <!-- Success Header -->
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-teal-100 rounded-full mb-4">
                <i class="fas fa-check text-4xl text-teal-600"></i>
            </div>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Thank You!</h1>
            <p class="text-xl text-gray-600">Your payment was successful</p>
        </div>

        <!-- Payment Details Card -->
        <div class="bg-white rounded-xl shadow-md overflow-hidden mb-6">
            <div class="bg-teal-600 px-6 py-4">
                <h2 class="text-xl font-semibold text-white">Payment Details</h2>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Transaction ID</p>
                        <p class="font-semibold text-gray-900 break-all"><%= paymentId || 'N/A' %></p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Order ID</p>
                        <p class="font-semibold text-gray-900 break-all"><%= orderId || 'N/A' %></p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Amount Paid</p>
                        <p class="text-2xl font-bold text-teal-600">₹<%= amount ? amount.toLocaleString() : '0' %></p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Payment Date</p>
                        <p class="font-semibold text-gray-900"><%= new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Enrolled Courses -->
        <% if (courses && courses.length > 0) { %>
        <div class="bg-white rounded-xl shadow-md overflow-hidden mb-6">
            <div class="bg-teal-600 px-6 py-4">
                <h2 class="text-xl font-semibold text-white">Enrolled Courses</h2>
            </div>
            <div class="p-6">
                <div class="space-y-4">
                    <% courses.forEach(course => { %>
                    <div class="flex items-center gap-4 p-4 border border-gray-200 rounded-lg hover:border-teal-300 hover:shadow-sm transition">
                        <% if (course.thumbnail) { %>
                            <img src="<%= course.thumbnail %>" alt="<%= course.title %>" class="w-20 h-20 rounded-lg object-cover">
                        <% } else { %>
                            <div class="w-20 h-20 bg-teal-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-book text-teal-600 text-2xl"></i>
                            </div>
                        <% } %>
                        <div class="flex-1">
                            <h3 class="font-semibold text-gray-900 mb-1"><%= course.title %></h3>
                            <div class="flex items-center gap-3 text-sm text-gray-600">
                                <span class="inline-flex items-center px-2 py-1 bg-teal-50 text-teal-700 rounded font-medium">
                                    <%= course.category %>
                                </span>
                                <span><i class="fas fa-book-open mr-1"></i><%= course.lessons ? course.lessons.length : 0 %> Lessons</span>
                            </div>
                        </div>
                        <div class="flex items-center justify-center w-10 h-10 bg-teal-100 rounded-full">
                            <i class="fas fa-check text-teal-600"></i>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <a href="/user/courses" 
               class="flex-1 inline-flex items-center justify-center px-6 py-4 bg-teal-600 hover:bg-teal-700 text-white font-semibold rounded-lg transition duration-200 shadow-md">
                <i class="fas fa-play-circle mr-2"></i>
                Start Learning
            </a>
            <a href="/user/home" 
               class="flex-1 inline-flex items-center justify-center px-6 py-4 bg-white hover:bg-gray-50 text-gray-700 font-semibold rounded-lg border-2 border-gray-300 hover:border-teal-600 transition duration-200">
                <i class="fas fa-home mr-2"></i>
                Go to Home
            </a>
        </div>

        <!-- Info Box -->
        <div class="bg-teal-50 border border-teal-200 rounded-lg p-4 text-center">
            <p class="text-teal-800">
                <i class="fas fa-envelope mr-2"></i>
                A confirmation email has been sent to your registered email address.
            </p>
        </div>

        <!-- Support Link -->
        <div class="text-center mt-8">
            <p class="text-gray-600">
                Need help? <a href="#" class="text-teal-600 hover:text-teal-700 font-semibold hover:underline">Contact Support</a>
            </p>
        </div>
    </div>

    <script>
        // Simple and reliable sound playback
        let audioPlayed = false;
        
        function playSuccessSound() {
            if (audioPlayed) return;
            
            // Light, pleasant success sounds
            const soundUrls = [
                'https://cdn.pixabay.com/audio/2021/08/04/audio_0625c1539c.mp3', // Light success tone
                'https://cdn.pixabay.com/audio/2022/03/24/audio_c9c5d99b8c.mp3', // Soft chime
                'https://assets.mixkit.co/active_storage/sfx/2019/2019-preview.mp3'  // Gentle notification
            ];
            
            const audio = new Audio(soundUrls[0]);
            audio.volume = 0.5;
            
            audio.play()
                .then(() => {
                    audioPlayed = true;
                    // Hide manual button if it was shown
                    const manualBtn = document.getElementById('manualPlayBtn');
                    if (manualBtn) manualBtn.style.display = 'none';
                })
                .catch(error => {
                    // Try second sound
                    const audio2 = new Audio(soundUrls[1]);
                    audio2.volume = 0.5;
                    audio2.play()
                        .then(() => {
                            audioPlayed = true;
                        })
                        .catch(err => {
                            // Show manual button only if both fail
                            const manualBtn = document.getElementById('manualPlayBtn');
                            if (manualBtn) manualBtn.classList.remove('hidden');
                        });
                });
        }

        // Manual play function
        function manualPlaySound() {
            audioPlayed = false; // Reset to allow replay
            playSuccessSound();
        }

        // Create confetti
        function createConfetti() {
            const colors = ['#00d9b1', '#00c4a0', '#00af8f', '#009a7e'];
            const confettiCount = 60;
            
            for (let i = 0; i < confettiCount; i++) {
                setTimeout(() => {
                    const confetti = document.createElement('div');
                    confetti.className = 'confetti';
                    confetti.style.left = Math.random() * 100 + 'vw';
                    confetti.style.top = '-10px';
                    confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                    confetti.style.width = (Math.random() * 6 + 4) + 'px';
                    confetti.style.height = confetti.style.width;
                    confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                    confetti.style.animation = `confettiFall ${Math.random() * 2 + 2}s linear forwards`;
                    
                    document.body.appendChild(confetti);
                    
                    setTimeout(() => confetti.remove(), 4000);
                }, i * 15);
            }
        }

        // Close modal
        function closeModal() {
            const modal = document.getElementById('successModal');
            modal.style.opacity = '0';
            modal.style.transition = 'opacity 0.3s ease-out';
            setTimeout(() => {
                modal.style.display = 'none';
            }, 300);
        }

        // Initialize
        window.addEventListener('load', function() {
            // Try to play sound after short delay
            setTimeout(() => {
                playSuccessSound();
            }, 800);
            
            // Show manual button after 3 seconds only if sound didn't play
            setTimeout(() => {
                if (!audioPlayed) {
                    const manualBtn = document.getElementById('manualPlayBtn');
                    if (manualBtn) manualBtn.classList.remove('hidden');
                }
            }, 3000);
            
            // Create confetti
            setTimeout(() => {
                createConfetti();
            }, 700);
            
            // Auto-close modal
            setTimeout(() => {
                closeModal();
            }, 4000);
        });

        // Try to play on any user interaction
        ['click', 'touchstart'].forEach(eventType => {
            document.addEventListener(eventType, function playOnInteraction() {
                if (!audioPlayed) {
                    playSuccessSound();
                }
            }, { once: true });
        });
    </script>
</body>
</html>
