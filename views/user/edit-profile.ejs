<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Edit Profile - Learnify</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2beead",
                        "background-light": "#f6f8f7",
                        "background-dark": "#10221c",
                        "deep-forest": "#0d1b17",
                    },
                    fontFamily: { "display": ["Be Vietnam Pro", "sans-serif"] },
                    borderRadius: {"DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "2xl": "2rem", "full": "9999px"},
                },
            },
        }
    </script>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-[#0d1b17] dark:text-[#f8fcfa]">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="w-full max-w-2xl bg-white dark:bg-[#1a3a30] rounded-2xl shadow-xl p-8">
            <!-- Header -->
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-3xl font-black text-[#0d1b17] dark:text-white">Edit Profile</h1>
                    <p class="text-[#4c9a80] dark:text-[#a0c5ba] mt-1">Update your personal information</p>
                </div>
                <a href="/user/profile" class="px-4 py-2 bg-gray-100 dark:bg-[#0d1b17] text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-200 dark:hover:bg-[#1a3a30] transition-colors">
                    Back to Profile
                </a>
            </div>

            <!-- Edit Profile Form -->
            <form id="editProfileForm" class="space-y-6">
                <!-- Full Name -->
                <div>
                    <label class="block text-sm font-bold mb-2" for="fullName">Full Name</label>
                    <input type="text" id="fullName" value="<%= user.fullName %>"
                           class="w-full px-4 py-3 bg-background-light dark:bg-[#0d1b17] border border-gray-200 dark:border-[#1a3a30] rounded-xl focus:ring-2 focus:ring-primary focus:border-primary"
                           placeholder="Enter your full name"/>
                    <p id="fullNameError" class="text-red-500 text-sm mt-1 hidden"></p>
                </div>

                <!-- Phone Number -->
                <div>
                    <label class="block text-sm font-bold mb-2" for="phone">Phone Number</label>
                    <input type="tel" id="phone" value="<%= user.phone || '' %>"
                           class="w-full px-4 py-3 bg-background-light dark:bg-[#0d1b17] border border-gray-200 dark:border-[#1a3a30] rounded-xl focus:ring-2 focus:ring-primary focus:border-primary"
                           placeholder="Enter your phone number"/>
                    <p id="phoneError" class="text-red-500 text-sm mt-1 hidden"></p>
                </div>

                <!-- Current Email (Read-only) -->
                <div>
                    <label class="block text-sm font-bold mb-2">Current Email</label>
                    <input type="email" value="<%= user.email %>" readonly
                           class="w-full px-4 py-3 bg-gray-100 dark:bg-[#0d1b17] border border-gray-200 dark:border-[#1a3a30] rounded-xl cursor-not-allowed"
                           disabled/>
                </div>

                <!-- New Email (Optional) -->
                <div>
                    <label class="block text-sm font-bold mb-2" for="newEmail">New Email (Optional)</label>
                    <input type="email" id="newEmail"
                           class="w-full px-4 py-3 bg-background-light dark:bg-[#0d1b17] border border-gray-200 dark:border-[#1a3a30] rounded-xl focus:ring-2 focus:ring-primary focus:border-primary"
                           placeholder="Enter new email to change"/>
                    <p class="text-xs text-gray-500 mt-1">Leave empty if you don't want to change your email</p>
                    <p id="emailError" class="text-red-500 text-sm mt-1 hidden"></p>
                </div>

                <!-- Submit Button -->
                <button type="submit" 
                        class="w-full bg-primary text-[#0d1b17] py-4 rounded-xl font-black text-lg shadow-xl shadow-primary/20 hover:scale-[1.01] transition-transform">
                    Update Profile
                </button>
            </form>

            <!-- OTP Verification Modal (Hidden by default) -->
            <div id="otpModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
                <div class="bg-white dark:bg-[#1a3a30] rounded-2xl p-8 max-w-md w-full mx-4">
                    <h2 class="text-2xl font-black mb-4">Verify New Email</h2>
                    <p class="text-gray-600 dark:text-gray-400 mb-6">We've sent a verification code to your new email address</p>
                    
                    <div class="mb-6">
                        <label class="block text-sm font-bold mb-2" for="otpInput">Enter OTP</label>
                        <input type="text" id="otpInput" maxlength="6"
                               class="w-full px-4 py-3 bg-background-light dark:bg-[#0d1b17] border border-gray-200 dark:border-[#1a3a30] rounded-xl focus:ring-2 focus:ring-primary focus:border-primary text-center text-2xl tracking-widest"
                               placeholder="000000"/>
                        <p id="otpError" class="text-red-500 text-sm mt-1 hidden"></p>
                    </div>

                    <div class="flex gap-3">
                        <button onclick="verifyOTP()" 
                                class="flex-1 bg-primary text-[#0d1b17] py-3 rounded-xl font-bold hover:scale-[1.02] transition-transform">
                            Verify
                        </button>
                        <button onclick="resendOTP()" 
                                class="flex-1 bg-gray-100 dark:bg-[#0d1b17] text-gray-700 dark:text-gray-300 py-3 rounded-xl font-bold hover:bg-gray-200 dark:hover:bg-[#1a3a30] transition-colors">
                            Resend OTP
                        </button>
                    </div>
                    
                    <button onclick="closeOTPModal()" 
                            class="w-full mt-3 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 py-2">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let pendingData = null;

        document.getElementById('editProfileForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const fullName = document.getElementById('fullName').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const newEmail = document.getElementById('newEmail').value.trim();

            // Reset errors
            document.querySelectorAll('[id$="Error"]').forEach(el => el.classList.add('hidden'));

            // Validation
            if (!fullName) {
                document.getElementById('fullNameError').textContent = 'Full name is required';
                document.getElementById('fullNameError').classList.remove('hidden');
                return;
            }

            try {
                const response = await fetch('/user/update-profile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName, phone, newEmail })
                });

                const data = await response.json();

                if (response.ok) {
                    if (data.requiresOTP) {
                        // Show OTP modal
                        pendingData = { fullName, phone, newEmail };
                        document.getElementById('otpModal').classList.remove('hidden');
                        showToast('OTP sent to your new email', 'success');
                    } else {
                        // Profile updated without email change
                        showToast('Profile updated successfully!', 'success');
                        setTimeout(() => {
                            window.location.href = '/user/profile';
                        }, 1500);
                    }
                } else {
                    showToast(data.message || 'Update failed', 'error');
                }
            } catch (error) {
                showToast('Something went wrong', 'error');
                console.error(error);
            }
        });

        async function verifyOTP() {
            const otp = document.getElementById('otpInput').value.trim();
            const otpError = document.getElementById('otpError');

            if (!otp || otp.length !== 6) {
                otpError.textContent = 'Please enter a valid 6-digit OTP';
                otpError.classList.remove('hidden');
                return;
            }

            try {
                const response = await fetch('/user/verify-email-change', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        otp,
                        ...pendingData
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    showToast('Email updated successfully!', 'success');
                    setTimeout(() => {
                        window.location.href = '/user/profile';
                    }, 1500);
                } else {
                    otpError.textContent = data.message || 'Invalid OTP';
                    otpError.classList.remove('hidden');
                }
            } catch (error) {
                showToast('Verification failed', 'error');
                console.error(error);
            }
        }

        async function resendOTP() {
            if (!pendingData || !pendingData.newEmail) return;

            try {
                const response = await fetch('/user/resend-email-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: pendingData.newEmail })
                });

                const data = await response.json();

                if (response.ok) {
                    showToast('OTP resent successfully!', 'success');
                    document.getElementById('otpInput').value = '';
                    document.getElementById('otpError').classList.add('hidden');
                } else {
                    showToast(data.message || 'Failed to resend OTP', 'error');
                }
            } catch (error) {
                showToast('Failed to resend OTP', 'error');
                console.error(error);
            }
        }

        function closeOTPModal() {
            document.getElementById('otpModal').classList.add('hidden');
            document.getElementById('otpInput').value = '';
            document.getElementById('otpError').classList.add('hidden');
            pendingData = null;
        }

        function showToast(message, type) {
            // Simple toast implementation
            const toast = document.createElement('div');
            toast.className = `fixed top-4 right-4 px-6 py-3 rounded-xl shadow-lg z-50 ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            } text-white font-medium`;
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
</body>
</html>
