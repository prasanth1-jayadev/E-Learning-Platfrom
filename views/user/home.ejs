  <!-- ════════════════════════════════════════════════
       SCRIPT A — SCROLL-TRIGGERED BOOK OPEN
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      const hero         = document.getElementById('hero-section');
      const bookCover    = document.getElementById('bookCover');
      const bookInner    = document.getElementById('bookInner');
      const bookGlow     = document.getElementById('bookGlow');
      const progressPill = document.getElementById('progressPill');
      const floatIcons   = document.querySelectorAll('.float-icon');
      let opened = false;

      function openBook() {
        if (opened) return;
        opened = true;
        bookGlow.classList.add('visible');
        bookCover.classList.add('open');
        bookInner.classList.add('visible');
        progressPill.classList.add('visible');
        floatIcons.forEach(ic => ic.classList.add('visible'));
      }

      // IntersectionObserver fires when 30% of hero is on screen
      new IntersectionObserver(
        entries => entries.forEach(e => { if (e.isIntersecting) openBook(); }),
        { threshold: 0.30 }
      ).observe(hero);

      // Already visible on load?
      if (hero.getBoundingClientRect().top < window.innerHeight * 0.7) openBook();
    })();
  </script>


  <!-- ════════════════════════════════════════════════
       SCRIPT B — ANTI-GRAVITY MAGNETIC CIRCLES
       160 circles fixed to a grid; mouse proximity
       launches them upward + sideways (repulsion +
       anti-gravity lift); spring returns to home.
  ════════════════════════════════════════════════ -->
  <script>
    (function () {
      const canvas = document.getElementById('ag-canvas');
      const ctx    = canvas.getContext('2d');
      let W, H;
      let mx = -9999, my = -9999;

      function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
        rehome();
      }

      window.addEventListener('resize',    resize);
      window.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
      window.addEventListener('mouseleave',() => { mx = -9999;    my = -9999; });

      /* colour palette — brand teal / greens / grays */
      const PAL = [
        [43,  238, 173],
        [16,  185, 129],
        [0,   217, 177],
        [134, 239, 172],
        [167, 243, 208],
        [156, 163, 175],
      ];

      const COLS_N = 18, ROWS_N = 12;
      const circles = [];

      /* Build grid */
      for (let c = 0; c < COLS_N; c++) {
        for (let r = 0; r < ROWS_N; r++) {
          const col    = PAL[Math.floor(Math.random() * PAL.length)];
          const radius = 3 + Math.random() * 10;
          circles.push({
            hx: 0, hy: 0,      // set by rehome()
            ci: c, ri: r,
            x: 0, y: 0,
            vx: 0, vy: 0,
            radius,
            col,
            baseAlpha : 0.08 + Math.random() * 0.10,
            alpha: 0,
            phase : Math.random() * Math.PI * 2,
          });
        }
      }

      function rehome() {
        circles.forEach(p => {
          p.hx = (p.ci / (COLS_N - 1)) * (W || window.innerWidth);
          p.hy = (p.ri / (ROWS_N - 1)) * (H || window.innerHeight);
          if (p.x === 0 && p.y === 0) { p.x = p.hx; p.y = p.hy; }
        });
      }

      resize(); // init canvas + home positions

      /* Physics constants */
      const REPEL_R   = 140;   // influence radius (px)
      const REPEL_F   = 3.0;   // repulsion strength
      const LIFT      = 1.6;   // extra upward push factor
      const SPRING    = 0.052; // spring constant back to home
      const DAMP      = 0.80;  // velocity damping per frame
      const IDLE_AMP  = 0.45;  // idle bob amplitude
      const IDLE_SPD  = 0.0005;

      function draw(ts) {
        ctx.clearRect(0, 0, W, H);
        const t = ts * IDLE_SPD;

        circles.forEach(p => {
          /* idle drift of home position */
          const ix = p.hx + Math.cos(p.phase * 0.7 + t * 0.8) * IDLE_AMP;
          const iy = p.hy + Math.sin(p.phase      + t        ) * IDLE_AMP;

          /* repulsion from mouse */
          const dx   = p.x - mx;
          const dy   = p.y - my;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < REPEL_R && dist > 1) {
            const f   = (1 - dist / REPEL_R) * REPEL_F;
            const nx  = dx / dist;
            const ny  = dy / dist;
            p.vx += nx * f;
            p.vy += ny * f - LIFT * f * 0.55;   // anti-gravity upward bias
          }

          /* spring back */
          p.vx += (ix - p.x) * SPRING;
          p.vy += (iy - p.y) * SPRING;

          /* damping */
          p.vx *= DAMP;
          p.vy *= DAMP;

          p.x += p.vx;
          p.y += p.vy;

          /* alpha brightens when disturbed */
          const disp   = Math.sqrt((p.x - p.hx) ** 2 + (p.y - p.hy) ** 2);
          const excite = Math.min(disp / 45, 1);
          p.alpha      = p.baseAlpha + excite * 0.32;

          /* render */
          const [r, g, b] = p.col;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${r},${g},${b},${p.alpha})`;
          ctx.fill();
        });

        requestAnimationFrame(draw);
      }

      requestAnimationFrame(draw);
    })();
  </script>

</body>
