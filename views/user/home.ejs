    <script>
      (function() {
        const carousel = document.getElementById('tutorCarouselHome');
        const prevBtn  = document.getElementById('prevTutorBtnHome');
        const nextBtn  = document.getElementById('nextTutorBtnHome');
        const totalTutors   = <%= tutors.length %>;
        let currentIndex    = 0;
        const tutorsPerView = window.innerWidth >= 768 ? 3 : 1;
        const maxIndex      = Math.max(0, totalTutors - tutorsPerView);
        function updateCarousel() {
          carousel.style.transform = `translateX(${-(currentIndex * (100 / tutorsPerView))}%)`;
          prevBtn.disabled = currentIndex === 0;
          nextBtn.disabled = currentIndex >= maxIndex;
          prevBtn.style.opacity = currentIndex === 0 ? '0.5' : '1';
          nextBtn.style.opacity = currentIndex >= maxIndex ? '0.5' : '1';
        }
        prevBtn.addEventListener('click', () => { if (currentIndex > 0) { currentIndex--; updateCarousel(); } });
        nextBtn.addEventListener('click', () => { if (currentIndex < maxIndex) { currentIndex++; updateCarousel(); } });
        updateCarousel();
      })();
    </script>
