                <span class="text-xs font-bold <%= course.price === 0 ? 'text-brand' : 'text-gray-900' %>">
                  <% if (course.price === 0) { %>Free<% } else { %>₹<%= course.price.toLocaleString() %><% } %>
                </span>
              </div>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="col-span-4 text-center py-8">
