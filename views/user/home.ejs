<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Learnify - Home</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { brand: '#2beead' },
          fontFamily: { display: ['Be Vietnam Pro', 'sans-serif'] }
        }
      }
    }
  </script>

  <style>
    /* ═══════════════════════════════════════
       ANTI-GRAVITY CANVAS — fixed background
    ═══════════════════════════════════════ */
    #ag-canvas {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
    }
    body > *:not(#ag-canvas) {
      position: relative;
      z-index: 1;
    }

    /* ═══════════════════════════════════════
       3-D BOOK
    ═══════════════════════════════════════ */
    .book-scene {
      perspective: 1000px;
      width: 240px;
      height: 300px;
      position: relative;
    }
    .book-body {
      width: 100%;
      height: 100%;
      position: relative;
      transform-style: preserve-3d;
    }
    .book-spine {
      position: absolute;
      left: 0; top: 8px; bottom: 8px;
      width: 16px;
      background: linear-gradient(to right, #064e3b, #065f46, #064e3b);
      border-radius: 3px 0 0 3px;
      box-shadow: -4px 0 14px rgba(0,0,0,0.4);
      z-index: 5;
    }
    .book-back {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #064e3b 0%, #065f46 100%);
      border-radius: 4px 12px 12px 4px;
      box-shadow: 8px 12px 40px rgba(0,0,0,0.35);
    }
    .book-pages-edge {
      position: absolute;
      top: 10px; bottom: 10px;
      right: 0;
      width: 14px;
      background: repeating-linear-gradient(
        to bottom,
        #f5f5ef 0px, #f5f5ef 3px,
        #e0e0d8 3px, #e0e0d8 4px
      );
      border-radius: 0 4px 4px 0;
      box-shadow: 3px 0 8px rgba(0,0,0,0.12);
    }
    /* Front cover — flips open */
    .book-cover {
      position: absolute;
      inset: 0;
      transform-style: preserve-3d;
      transform-origin: left center;
      transform: rotateY(0deg);
      transition: transform 1.3s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 4;
    }
    .book-cover.open {
      transform: rotateY(-152deg);
    }
    .book-cover-front {
      position: absolute;
      inset: 0;
      background: linear-gradient(145deg, #059669 0%, #10b981 50%, #2beead 100%);
      border-radius: 4px 12px 12px 4px;
      padding: 22px 18px;
      backface-visibility: hidden;
      box-shadow: 4px 0 22px rgba(0,0,0,0.28);
      overflow: hidden;
    }
    .book-cover-front::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        -45deg,
        transparent 0px, transparent 16px,
        rgba(255,255,255,0.05) 16px, rgba(255,255,255,0.05) 17px
      );
    }
    .book-cover-back {
      position: absolute;
      inset: 0;
      background: linear-gradient(145deg, #f0f0ea 0%, #e4e4dc 100%);
      border-radius: 4px 12px 12px 4px;
      backface-visibility: hidden;
      transform: rotateY(180deg);
    }
    /* Inner page lines */
    .book-inner {
      position: absolute;
      inset: 6px 14px 6px 16px;
      z-index: 3;
      display: flex;
      flex-direction: column;
      gap: 3px;
      opacity: 0;
      transition: opacity 0.5s ease 1.0s;
    }
    .book-inner.visible { opacity: 1; }
    .page-line {
      height: 7px;
      border-radius: 2px;
      background: #e2e8e4;
    }
    .page-line.accent  { background: rgba(43,238,173,0.38); }
    .page-line.short   { width: 58%; }
    .page-line.medium  { width: 82%; }
    .page-line.heading { height: 12px; background: rgba(43,238,173,0.55); margin-bottom: 5px; width: 72%; }
    .mini-chart {
      margin-top: 10px;
      display: flex;
      align-items: flex-end;
      gap: 5px;
      height: 42px;
    }
    .mini-bar {
      flex: 1;
      border-radius: 3px 3px 0 0;
      background: rgba(43,238,173,0.25);
    }
    .mini-bar:nth-child(2) { background: rgba(43,238,173,0.45); }
    .mini-bar:nth-child(3) { background: rgba(43,238,173,0.65); }
    .mini-bar:nth-child(4) { background: rgba(43,238,173,0.88); }
    .mini-bar:nth-child(5) { background: rgba(43,238,173,0.55); }

    /* Floating icons */
    .float-icon {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      opacity: 0;
      transform: scale(0.5) translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
      box-shadow: 0 6px 24px rgba(0,0,0,0.10);
    }
    .float-icon.visible {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
    .fi-1 { transition-delay: 1.15s; }
    .fi-2 { transition-delay: 1.35s; }
    .fi-3 { transition-delay: 1.55s; }
    .fi-4 { transition-delay: 1.75s; }

    @keyframes bob  { 0%,100%{transform:scale(1) translateY(0);} 50%{transform:scale(1) translateY(-9px);} }
    @keyframes bob2 { 0%,100%{transform:scale(1) translateY(0) rotate(-4deg);} 50%{transform:scale(1) translateY(-11px) rotate(4deg);} }
    @keyframes bob3 { 0%,100%{transform:scale(1) translateY(0) rotate(3deg);} 50%{transform:scale(1) translateY(-7px) rotate(-3deg);} }

    .float-icon.visible.fi-1 { animation: bob  3.4s ease-in-out infinite; }
    .float-icon.visible.fi-2 { animation: bob2 4.0s ease-in-out infinite; }
    .float-icon.visible.fi-3 { animation: bob  3.8s ease-in-out 0.4s infinite; }
    .float-icon.visible.fi-4 { animation: bob3 3.6s ease-in-out 0.2s infinite; }

    /* Progress pill */
    .progress-pill {
      position: absolute;
      background: white;
      border-radius: 16px;
      padding: 8px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.13);
      white-space: nowrap;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease 1.5s, transform 0.6s ease 1.5s;
    }
    .progress-pill.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Glow */
    .book-glow {
      position: absolute;
      inset: -40px;
      background: radial-gradient(ellipse at 55% 60%, rgba(43,238,173,0.20) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
      opacity: 0;
      transition: opacity 1s ease 0.2s;
    }
    .book-glow.visible { opacity: 1; }
  </style>
</head>

