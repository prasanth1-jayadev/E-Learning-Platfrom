<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile - Learnify</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { primary: '#2beead' },
          fontFamily: { display: ['Be Vietnam Pro', 'sans-serif'] }
        }
      }
    }
  </script>
</head>

<body class="font-display bg-[#f0f4f3] min-h-screen flex flex-col">
  <%- include('../partials/user-navbar') %>

    <!-- Main content -->
    <div class="flex-1 max-w-5xl mx-auto w-full px-4 sm:px-6 py-8 flex flex-col md:flex-row gap-6 items-start">

      <!-- Left Sidebar -->
      <style>
        .scrollbar-none::-webkit-scrollbar { display: none; }
        .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
      </style>
      <aside class="w-full md:w-64 flex-shrink-0 bg-white rounded-2xl shadow-sm p-5">
        <!-- Avatar + Name -->
        <div class="flex flex-col items-center mb-5">
          <div class="relative mb-3 cursor-pointer group" onclick="document.getElementById('userAvatarInput').click()">
            <div id="sidebarAvatar"
              class="w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center overflow-hidden group-hover:brightness-95 transition">
              <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" alt="<%= user.fullName %>" class="w-full h-full object-cover">
                <% } else { %>
                  <svg class="w-9 h-9 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                    <path
                      d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
                  </svg>
                  <% } %>
            </div>
            <div
              class="absolute bottom-0 right-0 w-5 h-5 bg-[#00d9b1] rounded-full border-2 border-white flex items-center justify-center shadow-sm">
              <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316A2.192 2.192 0 0014.536 4H9.464c-.69 0-1.328.384-1.649.983l-.988 1.192zm3.423 7.575a2.25 2.25 0 114.5 0 2.25 2.25 0 01-4.5 0z" />
              </svg>
            </div>
          </div>
          <input type="file" id="userAvatarInput" class="hidden" accept="image/jpeg,image/jpg,image/png,image/webp"
            onchange="previewAvatar(this)">
          <p class="font-bold text-gray-900 text-sm mb-2">
            <%= user.fullName %>
          </p>

          <!-- Change Photo Button -->
          <button id="changePhotoBtn" onclick="document.getElementById('userAvatarInput').click()"
            class="flex items-center gap-1 text-xs text-gray-600 border border-gray-200 rounded-full px-3 py-1 hover:bg-gray-50 transition">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Change Photo
          </button>

          <!-- Upload/Cancel Buttons (hidden by default) -->
          <div id="uploadButtons" style="display: none; margin-top: 1rem; gap: 0.5rem; justify-content: center;">
            <button type="button" onclick="uploadAvatar()"
              style="background: #00d9b1; color: white; border: none; padding: 0.5rem 1.25rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.3s;">
              Upload
            </button>
            <button type="button" onclick="cancelUpload()"
              style="background: #f3f4f6; color: #666; border: none; padding: 0.5rem 1.25rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.3s;">
              Cancel
            </button>
          </div>
        </div>

        <!-- Nav -->
        <nav class="flex flex-row overflow-x-auto gap-2 md:flex-col md:space-y-1 pb-2 md:pb-0 whitespace-nowrap scrollbar-none">
          <a href="#"
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-primary text-white text-sm font-semibold">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Profile
          </a>
          <a href="/user/my-courses"
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            My Courses
          </a>
          <!-- <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          My Orders
        </a> -->
          <a href="/user/cart"
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Shopping Cart
          </a>
          <a href="/user/wishlist"
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            Wishlist
          </a>
          <a href="javascript:void(0)" onclick="confirmLogout('/user/logout')"
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-red-500 hover:bg-red-50 text-sm font-medium transition mt-2 md:mt-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Logout
          </a>
        </nav>
      </aside>

      <!-- Right Content -->
      <div class="flex-1 flex flex-col gap-5">

        <!-- Profile Settings Card -->
        <div class="bg-white rounded-2xl shadow-sm p-7">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-bold text-gray-900">Profile Settings</h2>
            <button id="editBtn" onclick="toggleEdit()"
              class="flex items-center gap-2 bg-primary text-gray-900 text-xs font-bold px-4 py-2 rounded-lg hover:brightness-110 transition">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
              </svg>
              <span id="editBtnText">Edit Profile</span>
            </button>
          </div>

          <div class="space-y-5">
            <!-- Name -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Name</label>
              <input type="text" id="fullName" value="<%= user.fullName %>" readonly
                class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none focus:border-primary focus:bg-white transition" />
            </div>

            <!-- Phone -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone</label>
              <input type="text" id="phone" value="<%= user.phone || '' %>" placeholder="Enter your phone number"
                readonly
                class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none focus:border-primary focus:bg-white transition" />
            </div>

            <!-- Email -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
              <div class="flex gap-3">
                <input type="email" value="<%= user.email %>" readonly
                  class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-800 bg-gray-50 focus:outline-none" />
                <button onclick="openEmailModal()"
                  class="px-4 py-2.5 border border-primary text-primary text-xs font-bold rounded-lg hover:bg-primary/5 transition whitespace-nowrap">
                  Change Email
                </button>
              </div>
              <p class="text-xs text-gray-400 mt-1.5">Email changes require verification for security</p>
            </div>

            <!-- Save Button (Hidden by default) -->
            <div id="saveSection" class="hidden pt-2">
              <button onclick="saveProfile()"
                class="w-full bg-primary text-gray-900 py-3 rounded-lg font-bold hover:brightness-110 transition">
                Save Changes
              </button>
            </div>

            <!-- Change Password -->
            <div class="pt-2">
              <button onclick="openPasswordModal()"
                class="flex items-center gap-2 px-5 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-600 font-medium hover:bg-gray-50 transition">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                </svg>
                Change Password
              </button>
            </div>
          </div>
        </div>

        <!-- Account Preferences Card -->
        <!-- <div class="bg-white rounded-2xl shadow-sm p-7">
        <h2 class="text-lg font-bold text-gray-900 mb-5">Account Preferences</h2>

         Dark Mode toggle -->
        <!-- <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-semibold text-gray-800">Dark Mode</p>
            <p class="text-xs text-primary mt-0.5">Switch theme appearance</p>
          </div> -->
        <!-- Toggle (off state) -->
        <!-- <button class="relative w-11 h-6 bg-gray-200 rounded-full transition focus:outline-none">
            <span class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full shadow transition-transform"></span>
          </button>
        </div>
      </div> -->

      </div>
    </div>

    <!-- Footer -->
    <footer class="text-center text-xs text-gray-400 py-6">
      © 2024 Learnify. All rights reserved.
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      function confirmLogout(logoutUrl) {
        Swal.fire({
          title: 'Are you sure?',
          text: 'You will be logged out of your account',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#ef4444',
          cancelButtonColor: '#6b7280',
          confirmButtonText: 'Yes, logout',
          cancelButtonText: 'Cancel'
        }).then((result) => {
          if (result.isConfirmed) {
            window.location.href = logoutUrl;
          }
        });
      }

      // Profile Edit Functions
      let isEditing = false;

      function toggleEdit() {
        isEditing = !isEditing;
        const fullNameInput = document.getElementById('fullName');
        const phoneInput = document.getElementById('phone');
        const editBtn = document.getElementById('editBtn');
        const editBtnText = document.getElementById('editBtnText');
        const saveSection = document.getElementById('saveSection');

        if (isEditing) {
          // Enable editing
          fullNameInput.readOnly = false;
          phoneInput.readOnly = false;
          fullNameInput.classList.remove('bg-gray-50');
          phoneInput.classList.remove('bg-gray-50');
          fullNameInput.classList.add('bg-white');
          phoneInput.classList.add('bg-white');
          editBtnText.textContent = 'Cancel';
          editBtn.classList.remove('bg-primary');
          editBtn.classList.add('bg-gray-200');
          saveSection.classList.remove('hidden');
          fullNameInput.focus();
        } else {
          // Disable editing
          fullNameInput.readOnly = true;
          phoneInput.readOnly = true;
          fullNameInput.classList.add('bg-gray-50');
          phoneInput.classList.add('bg-gray-50');
          fullNameInput.classList.remove('bg-white');
          phoneInput.classList.remove('bg-white');
          editBtnText.textContent = 'Edit Profile';
          editBtn.classList.add('bg-primary');
          editBtn.classList.remove('bg-gray-200');
          saveSection.classList.add('hidden');
          // Reset values
          fullNameInput.value = '<%= user.fullName %>';
          phoneInput.value = '<%= user.phone || "" %>';
        }
      }

      async function saveProfile() {
        const fullName = document.getElementById('fullName').value.trim();
        const phone = document.getElementById('phone').value.trim();



        const nameRegex = /^(?=.{2,50}$)[a-zA-Z]+(?: [a-zA-Z]+)*$/;
        const phoneRegex = /^[0-9]{10}$/;

        if (!nameRegex.test(fullName)) {
          showToast('Please enter a valid name  ', 'error');
          return;
        }

        if (phone && !phoneRegex.test(phone)) {
          showToast('Please enter a valid 10-digit phone number', 'error');
          return;
        }



        try {
          const response = await fetch('/user/update-profile', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fullName, phone })
          });

          const data = await response.json();

          if (response.ok) {
            showToast('Profile updated successfully!', 'success');
            toggleEdit();
            setTimeout(() => location.reload(), 1500);
          } else {
            showToast(data.message || 'Update failed', 'error');
          }
        } catch (error) {
          showToast('Something went wrong', 'error');
          console.error(error);
        }
      }

      // Email Change Modal Functions
      function openEmailModal() {
        document.getElementById('emailModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closeEmailModal() {
        document.getElementById('emailModal').classList.add('hidden');
        document.getElementById('newEmail').value = '';
        document.getElementById('emailError').classList.add('hidden');
        document.body.style.overflow = 'auto';
      }

      async function sendEmailOTP() {
        const newEmail = document.getElementById('newEmail').value.trim();
        const emailError = document.getElementById('emailError');

        if (!newEmail) {
          emailError.textContent = 'Please enter a new email';
          emailError.classList.remove('hidden');
          return;
        }

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(newEmail)) {
          emailError.textContent = 'Please enter a valid email';
          emailError.classList.remove('hidden');
          return;
        }

        try {
          const response = await fetch('/user/send-email-change-otp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ newEmail })
          });

          const data = await response.json();

          if (response.ok) {
            showToast('OTP sent to your new email', 'success');
            closeEmailModal();
            openOTPModal(newEmail);
          } else {
            emailError.textContent = data.message || 'Failed to send OTP';
            emailError.classList.remove('hidden');
          }
        } catch (error) {
          showToast('Something went wrong', 'error');
          console.error(error);
        }
      }

      // OTP Modal Functions
      let currentNewEmail = '';
      let resendTimer = null;

      function openOTPModal(newEmail) {
        currentNewEmail = newEmail;
        document.getElementById('otpModal').classList.remove('hidden');
        document.getElementById('otpNewEmail').textContent = newEmail;
        startResendTimer();
      }

      function closeOTPModal() {
        document.getElementById('otpModal').classList.add('hidden');
        document.getElementById('otpInput').value = '';
        document.getElementById('otpError').classList.add('hidden');
        currentNewEmail = '';
        if (resendTimer) clearInterval(resendTimer);
      }

      async function verifyEmailOTP() {
        const otp = document.getElementById('otpInput').value.trim();
        const otpError = document.getElementById('otpError');

        if (!otp || otp.length !== 4) {
          otpError.textContent = 'Please enter a valid 4-digit OTP';
          otpError.classList.remove('hidden');
          return;
        }

        try {
          const response = await fetch('/user/verify-email-change', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ otp, newEmail: currentNewEmail })
          });

          const data = await response.json();

          if (response.ok) {
            showToast('Email changed successfully!', 'success');
            closeOTPModal();
            setTimeout(() => location.reload(), 1500);
          } else {
            otpError.textContent = data.message || 'Invalid OTP';
            otpError.classList.remove('hidden');
          }
        } catch (error) {
          showToast('Verification failed', 'error');
          console.error(error);
        }
      }

      async function resendEmailOTP() {
        try {
          const response = await fetch('/user/resend-email-otp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: currentNewEmail })
          });

          const data = await response.json();

          if (response.ok) {
            showToast('OTP resent successfully!', 'success');
            document.getElementById('otpInput').value = '';
            document.getElementById('otpError').classList.add('hidden');
            startResendTimer();
          } else {
            showToast(data.message || 'Failed to resend OTP', 'error');
          }
        } catch (error) {
          showToast('Failed to resend OTP', 'error');
          console.error(error);
        }
      }

      function startResendTimer() {
        let seconds = 60;
        const resendBtn = document.getElementById('resendBtn');
        const resendText = document.getElementById('resendText');

        resendBtn.disabled = true;
        resendBtn.classList.add('opacity-50', 'cursor-not-allowed');

        resendTimer = setInterval(() => {
          seconds--;
          resendText.textContent = `Resend OTP (${seconds}s)`;

          if (seconds <= 0) {
            clearInterval(resendTimer);
            resendBtn.disabled = false;
            resendBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            resendText.textContent = 'Resend OTP';
          }
        }, 1000);
      }

      function showToast(message, type) {
        const toast = document.createElement('div');
        toast.className = `fixed top-4 right-4 px-6 py-3 rounded-xl shadow-lg z-50 ${type === 'success' ? 'bg-green-500' : 'bg-red-500'
          } text-white font-medium animate-fade-in`;
        toast.textContent = message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
      }

      // Avatar Upload Functions
      let selectedFile = null;

      function previewAvatar(input) {
        const file = input.files[0];
        if (!file) return;

        // Validate file type
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
          showToast('Please upload a valid image (JPG, PNG, or WEBP)', 'error');
          input.value = '';
          return;
        }

        // Validate file size (max 5MB)
        if (file.size > 5 * 1024 * 1024) {
          showToast('Image size must be less than 5MB', 'error');
          input.value = '';
          return;
        }

        selectedFile = file;

        // Show preview
        const reader = new FileReader();
        reader.onload = function (e) {
          const avatarImg = document.getElementById('sidebarAvatar');
          avatarImg.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover" alt="Preview">`;
        };
        reader.readAsDataURL(file);

        // Show upload/cancel buttons, hide change photo button
        document.getElementById('changePhotoBtn').style.display = 'none';
        document.getElementById('uploadButtons').style.display = 'flex';
      }

      async function uploadAvatar() {
        if (!selectedFile) {
          showToast('Please select an image first', 'error');
          return;
        }

        const formData = new FormData();
        formData.append('avatar', selectedFile);

        // Show loading state
        const uploadButtons = document.getElementById('uploadButtons');
        const originalHTML = uploadButtons.innerHTML;
        uploadButtons.innerHTML = '<div class="text-center text-primary text-xs">Uploading...</div>';

        try {
          const response = await fetch('/user/upload-avatar', {
            method: 'POST',
            body: formData
          });

          const data = await response.json();

          if (response.ok) {
            showToast('Profile photo updated successfully!', 'success');
            setTimeout(() => location.reload(), 1500);
          } else {
            showToast(data.message || 'Failed to upload photo', 'error');
            uploadButtons.innerHTML = originalHTML;
            cancelUpload();
          }
        } catch (error) {
          showToast('Something went wrong', 'error');
          console.error(error);
          uploadButtons.innerHTML = originalHTML;
          cancelUpload();
        }
      }

      function cancelUpload() {
        selectedFile = null;
        document.getElementById('userAvatarInput').value = '';

        // Restore original avatar
        const avatarImg = document.getElementById('sidebarAvatar');
        const hasAvatar = <%- user.avatar ? 'true' : 'false' %>;
        const avatarUrl = '<%- user.avatar || "" %>';
        const userName = '<%- user.fullName || "" %>';

        if (hasAvatar) {
          avatarImg.innerHTML = '<img src="' + avatarUrl + '" alt="' + userName + '" class="w-full h-full object-cover">';
        } else {
          avatarImg.innerHTML = '<svg class="w-9 h-9 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>';
        }

        // Show change photo button, hide upload/cancel buttons
        document.getElementById('changePhotoBtn').style.display = 'flex';
        document.getElementById('uploadButtons').style.display = 'none';
      }

      // Password Change Modal Functions
      function openPasswordModal() {
        document.getElementById('passwordModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closePasswordModal() {
        document.getElementById('passwordModal').classList.add('hidden');
        document.getElementById('currentPassword').value = '';
        document.getElementById('newPassword').value = '';
        document.getElementById('confirmPassword').value = '';
        document.getElementById('passwordError').classList.add('hidden');
        document.body.style.overflow = 'auto';

        // Reset all password fields to hidden state
        ['currentPassword', 'newPassword', 'confirmPassword'].forEach(id => {
          const input = document.getElementById(id);
          const eyeOpen = document.getElementById(id + '-eye-open');
          const eyeClosed = document.getElementById(id + '-eye-closed');
          if (input.type === 'text') {
            input.type = 'password';
            eyeOpen.classList.remove('hidden');
            eyeClosed.classList.add('hidden');
          }
        });
      }

      function togglePasswordVisibility(fieldId) {
        const input = document.getElementById(fieldId);
        const eyeOpen = document.getElementById(fieldId + '-eye-open');
        const eyeClosed = document.getElementById(fieldId + '-eye-closed');

        if (input.type === 'password') {
          input.type = 'text';
          eyeOpen.classList.add('hidden');
          eyeClosed.classList.remove('hidden');
        } else {
          input.type = 'password';
          eyeOpen.classList.remove('hidden');
          eyeClosed.classList.add('hidden');
        }
      }

      async function changePassword() {
        const currentPassword = document.getElementById('currentPassword').value.trim();
        const newPassword = document.getElementById('newPassword').value.trim();
        const confirmPassword = document.getElementById('confirmPassword').value.trim();
        const passwordError = document.getElementById('passwordError');

        if (!currentPassword || !newPassword || !confirmPassword) {
          passwordError.textContent = 'All fields are required';
          passwordError.classList.remove('hidden');
          return;
        }

        if (newPassword !== confirmPassword) {
          passwordError.textContent = 'New passwords do not match';
          passwordError.classList.remove('hidden');
          return;
        }

        if (newPassword.length < 8) {
          passwordError.textContent = 'Password must be at least 8 characters';
          passwordError.classList.remove('hidden');
          return;
        }

        const hasUpperCase = /[A-Z]/.test(newPassword);
        const hasLowerCase = /[a-z]/.test(newPassword);
        const hasNumbers = /\d/.test(newPassword);

        if (!hasUpperCase || !hasLowerCase || !hasNumbers) {
          passwordError.textContent = 'Password must contain uppercase, lowercase, and number';
          passwordError.classList.remove('hidden');
          return;
        }

        try {
          const response = await fetch('/user/change-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ currentPassword, newPassword })
          });

          const data = await response.json();

          if (response.ok) {
            showToast('Password changed successfully!', 'success');
            closePasswordModal();
          } else {
            passwordError.textContent = data.message || 'Failed to change password';
            passwordError.classList.remove('hidden');
          }
        } catch (error) {
          showToast('Something went wrong', 'error');
          console.error(error);
        }
      }
    </script>

    <!-- Email Change Modal -->
    <div id="emailModal"
      class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
      <div class="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
        <h2 class="text-2xl font-black mb-2">Change Email</h2>
        <p class="text-gray-600 mb-6">Enter your new email address</p>

        <div class="mb-6">
          <label class="block text-sm font-bold mb-2" for="newEmail">New Email Address</label>
          <input type="email" id="newEmail"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary"
            placeholder="Enter new email" />
