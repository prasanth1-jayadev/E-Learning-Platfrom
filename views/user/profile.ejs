          </button>
          <button id="resendBtn" onclick="resendEmailOTP()"
            class="flex-1 bg-gray-100 text-gray-700 py-3 rounded-xl font-bold hover:bg-gray-200 transition">
            <span id="resendText">Resend OTP</span>
          </button>
        </div>

        <button onclick="closeOTPModal()" class="w-full text-gray-500 hover:text-gray-700 py-2">
          Cancel
        </button>
      </div>
    </div>

    <!-- Change Password Modal -->
    <div id="passwordModal"
      class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
      <div class="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
        <h2 class="text-2xl font-black mb-2">Change Password</h2>
        <p class="text-gray-600 mb-6">Enter your current and new password</p>

        <div class="mb-4">
          <label class="block text-sm font-bold mb-2" for="currentPassword">Current Password</label>
          <div class="relative">
            <input type="password" id="currentPassword"
              class="w-full px-4 py-3 pr-12 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="Enter current password" />
            <button type="button" onclick="togglePasswordVisibility('currentPassword')"
