<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function confirmLogout(logoutUrl) {
    Swal.fire({
        title: 'Are you sure?',
        text: 'You will be logged out of your account',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Yes, logout',
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = logoutUrl;
        }
    });
}

// Profile Edit Functions
let isEditing = false;

function toggleEdit() {
    isEditing = !isEditing;
    const fullNameInput = document.getElementById('fullName');
    const phoneInput = document.getElementById('phone');
    const editBtn = document.getElementById('editBtn');
    const editBtnText = document.getElementById('editBtnText');
    const saveSection = document.getElementById('saveSection');

    if (isEditing) {
        // Enable editing
        fullNameInput.readOnly = false;
        phoneInput.readOnly = false;
        fullNameInput.classList.remove('bg-gray-50');
        phoneInput.classList.remove('bg-gray-50');
        fullNameInput.classList.add('bg-white');
        phoneInput.classList.add('bg-white');
        editBtnText.textContent = 'Cancel';
        editBtn.classList.remove('bg-primary');
        editBtn.classList.add('bg-gray-200');
        saveSection.classList.remove('hidden');
        fullNameInput.focus();
    } else {
        // Disable editing
        fullNameInput.readOnly = true;
        phoneInput.readOnly = true;
        fullNameInput.classList.add('bg-gray-50');
        phoneInput.classList.add('bg-gray-50');
        fullNameInput.classList.remove('bg-white');
        phoneInput.classList.remove('bg-white');
        editBtnText.textContent = 'Edit Profile';
        editBtn.classList.add('bg-primary');
        editBtn.classList.remove('bg-gray-200');
        saveSection.classList.add('hidden');
        // Reset values
        fullNameInput.value = '<%= user.fullName %>';
        phoneInput.value = '<%= user.phone || "" %>';
    }
}

async function saveProfile() {
    const fullName = document.getElementById('fullName').value.trim();
    const phone = document.getElementById('phone').value.trim();

    if (!fullName) {
        showToast('Name is required', 'error');
        return;
    }

    try {
        const response = await fetch('/user/update-profile', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fullName, phone })
        });

        const data = await response.json();

        if (response.ok) {
            showToast('Profile updated successfully!', 'success');
            toggleEdit();
            setTimeout(() => location.reload(), 1500);
        } else {
            showToast(data.message || 'Update failed', 'error');
        }
    } catch (error) {
        showToast('Something went wrong', 'error');
        console.error(error);
    }
}

// Email Change Modal Functions
function openEmailModal() {
    document.getElementById('emailModal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
}

function closeEmailModal() {
    document.getElementById('emailModal').classList.add('hidden');
    document.getElementById('newEmail').value = '';
    document.getElementById('emailError').classList.add('hidden');
    document.body.style.overflow = 'auto';
}

async function sendEmailOTP() {
    const newEmail = document.getElementById('newEmail').value.trim();
    const emailError = document.getElementById('emailError');

    if (!newEmail) {
        emailError.textContent = 'Please enter a new email';
        emailError.classList.remove('hidden');
        return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(newEmail)) {
        emailError.textContent = 'Please enter a valid email';
        emailError.classList.remove('hidden');
        return;
    }

    try {
        const response = await fetch('/user/send-email-change-otp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ newEmail })
        });

        const data = await response.json();

        if (response.ok) {
            showToast('OTP sent to your new email', 'success');
            closeEmailModal();
            openOTPModal(newEmail);
        } else {
            emailError.textContent = data.message || 'Failed to send OTP';
            emailError.classList.remove('hidden');
        }
    } catch (error) {
        showToast('Something went wrong', 'error');
        console.error(error);
    }
}

// OTP Modal Functions
let currentNewEmail = '';
let resendTimer = null;

function openOTPModal(newEmail) {
    currentNewEmail = newEmail;
    document.getElementById('otpModal').classList.remove('hidden');
    document.getElementById('otpNewEmail').textContent = newEmail;
    startResendTimer();
}

function closeOTPModal() {
    document.getElementById('otpModal').classList.add('hidden');
    document.getElementById('otpInput').value = '';
    document.getElementById('otpError').classList.add('hidden');
    currentNewEmail = '';
    if (resendTimer) clearInterval(resendTimer);
}

async function verifyEmailOTP() {
    const otp = document.getElementById('otpInput').value.trim();
    const otpError = document.getElementById('otpError');

    if (!otp || otp.length !== 4) {
        otpError.textContent = 'Please enter a valid 4-digit OTP';
        otpError.classList.remove('hidden');
        return;
    }

    try {
        const response = await fetch('/user/verify-email-change', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ otp, newEmail: currentNewEmail })
        });

        const data = await response.json();

        if (response.ok) {
            showToast('Email changed successfully!', 'success');
            closeOTPModal();
            setTimeout(() => location.reload(), 1500);
        } else {
            otpError.textContent = data.message || 'Invalid OTP';
            otpError.classList.remove('hidden');
        }
    } catch (error) {
        showToast('Verification failed', 'error');
        console.error(error);
    }
}

async function resendEmailOTP() {
    try {
        const response = await fetch('/user/resend-email-otp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: currentNewEmail })
        });

        const data = await response.json();

        if (response.ok) {
            showToast('OTP resent successfully!', 'success');
            document.getElementById('otpInput').value = '';
            document.getElementById('otpError').classList.add('hidden');
            startResendTimer();
        } else {
            showToast(data.message || 'Failed to resend OTP', 'error');
        }
    } catch (error) {
        showToast('Failed to resend OTP', 'error');
        console.error(error);
    }
}

function startResendTimer() {
    let seconds = 60;
    const resendBtn = document.getElementById('resendBtn');
    const resendText = document.getElementById('resendText');
    
    resendBtn.disabled = true;
    resendBtn.classList.add('opacity-50', 'cursor-not-allowed');
    
    resendTimer = setInterval(() => {
        seconds--;
        resendText.textContent = `Resend OTP (${seconds}s)`;
        
        if (seconds <= 0) {
            clearInterval(resendTimer);
            resendBtn.disabled = false;
            resendBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            resendText.textContent = 'Resend OTP';
        }
    }, 1000);
}

function showToast(message, type) {
    const toast = document.createElement('div');
    toast.className = `fixed top-4 right-4 px-6 py-3 rounded-xl shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500' : 'bg-red-500'
    } text-white font-medium animate-fade-in`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}
</script>

<!-- Email Change Modal -->
<div id="emailModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
        <h2 class="text-2xl font-black mb-2">Change Email</h2>
        <p class="text-gray-600 mb-6">Enter your new email address</p>
        
        <div class="mb-6">
            <label class="block text-sm font-bold mb-2" for="newEmail">New Email Address</label>
            <input type="email" id="newEmail"
                   class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary"
                   placeholder="Enter new email"/>
            <p id="emailError" class="text-red-500 text-sm mt-1 hidden"></p>
        </div>

        <div class="flex gap-3">
            <button onclick="sendEmailOTP()" 
                    class="flex-1 bg-primary text-gray-900 py-3 rounded-xl font-bold hover:brightness-110 transition">
                Send OTP
            </button>
            <button onclick="closeEmailModal()" 
                    class="flex-1 bg-gray-100 text-gray-700 py-3 rounded-xl font-bold hover:bg-gray-200 transition">
                Cancel
            </button>
        </div>
    </div>
</div>

<!-- OTP Verification Modal -->
<div id="otpModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
        <h2 class="text-2xl font-black mb-2">Verify Email</h2>
        <p class="text-gray-600 mb-1">We've sent a verification code to:</p>
        <p class="text-primary font-bold mb-6" id="otpNewEmail"></p>
        
        <div class="mb-6">
            <label class="block text-sm font-bold mb-2" for="otpInput">Enter OTP</label>
            <input type="text" id="otpInput" maxlength="4"
                   class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary text-center text-2xl tracking-widest"
                   placeholder="0000"/>
            <p id="otpError" class="text-red-500 text-sm mt-1 hidden"></p>
        </div>

        <div class="flex gap-3 mb-3">
            <button onclick="verifyEmailOTP()" 
                    class="flex-1 bg-primary text-gray-900 py-3 rounded-xl font-bold hover:brightness-110 transition">
                Verify
            </button>
            <button id="resendBtn" onclick="resendEmailOTP()" 
                    class="flex-1 bg-gray-100 text-gray-700 py-3 rounded-xl font-bold hover:bg-gray-200 transition">
                <span id="resendText">Resend OTP</span>
            </button>
        </div>
        
        <button onclick="closeOTPModal()" 
                class="w-full text-gray-500 hover:text-gray-700 py-2">
            Cancel
        </button>
    </div>
</div>

</body>
</html>
