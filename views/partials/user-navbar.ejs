      class="hidden sm:flex px-4 py-2 bg-[#00d9b1] text-gray-900 text-xs font-bold rounded-lg hover:brightness-110 transition">
      Become a Tutor
    </a>

    <!-- Wishlist Icon -->
    <a href="/user/wishlist" class="p-2 text-gray-400 hover:text-[#00d9b1] transition relative" title="Wishlist">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </a>

    <!-- Cart Icon with Badge -->
