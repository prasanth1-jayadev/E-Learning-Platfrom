    <!-- Navigation Links -->
    <div class="hidden md:flex items-center gap-6 text-sm text-gray-600 font-medium">
      <a href="/user/home" class="hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'text-[#00d9b1] font-semibold' : '' %>">
        Home
      </a>
      <a href="/user/courses" class="hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'courses' ? 'text-[#00d9b1] font-semibold' : '' %>">
        Courses
      </a>
      <a href="/user/tutors" class="hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'tutors' ? 'text-[#00d9b1] font-semibold' : '' %>">
        Tutors
      </a>
      <a href="/user/about" class="hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'about' ? 'text-[#00d9b1] font-semibold' : '' %>">
        About Us
      </a>
      <a href="/user/contact" class="hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'contact' ? 'text-[#00d9b1] font-semibold' : '' %>">
        Contact
      </a>
    </div>
  </div>

  <!-- Right Side Actions -->
  <div class="flex items-center gap-3">
    <!-- Become a Tutor Button -->
