        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.fullName %>" class="w-full h-full object-cover">
        <% } else { %>
          <svg class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
          </svg>
        <% } %>
      </a>
    <% } else { %>
      <a href="/user/login"
        class="px-4 py-2 bg-gray-100 text-gray-700 text-xs font-bold rounded-lg hover:bg-gray-200 transition">
        Login
      </a>
    <% } %>

    <!-- Mobile Menu Button -->
    <button id="mobileMenuBtn" class="md:hidden p-2 text-gray-600 hover:text-gray-900">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobileMenu" class="hidden md:hidden bg-white border-b border-gray-100 shadow-lg">
  <div class="px-6 py-4 space-y-3">
    <a href="/user/home" class="block text-sm font-medium text-gray-600 hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'text-[#00d9b1]' : '' %>">
      Home
    </a>
    <a href="/user/courses" class="block text-sm font-medium text-gray-600 hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'courses' ? 'text-[#00d9b1]' : '' %>">
      Courses
    </a>
    <a href="/user/tutors" class="block text-sm font-medium text-gray-600 hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'tutors' ? 'text-[#00d9b1]' : '' %>">
      Tutors
    </a>
    <a href="/user/about" class="block text-sm font-medium text-gray-600 hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'about' ? 'text-[#00d9b1]' : '' %>">
      About Us
    </a>
    <a href="/user/contact" class="block text-sm font-medium text-gray-600 hover:text-[#00d9b1] transition-colors <%= typeof currentPage !== 'undefined' && currentPage === 'contact' ? 'text-[#00d9b1]' : '' %>">
      Contact
    </a>
    <a href="/tutor/signup" class="block px-4 py-2 bg-[#00d9b1] text-gray-900 text-sm font-bold rounded-lg hover:brightness-110 transition text-center">
      Become a Tutor
    </a>
  </div>
</div>

<!-- Mobile Menu Toggle Script -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    
    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
      });
    }

    // Fetch and update cart count
    <% if (typeof user !== 'undefined' && user) { %>
      fetchCartCount();
    <% } %>
  });

  // Function to fetch cart count
  async function fetchCartCount() {
    try {
      const response = await fetch('/user/cart/count');
      const data = await response.json();
      
      if (data.success && data.count > 0) {
        const cartCountElement = document.getElementById('cartCount');
        if (cartCountElement) {
          cartCountElement.textContent = data.count;
          cartCountElement.classList.remove('hidden');
        }
      }
    } catch (error) {
      console.error('Error fetching cart count:', error);
    }
  }

  // Make fetchCartCount available globally for other pages to update cart count
  window.updateCartCount = fetchCartCount;
</script>

<style>
  /* Tailwind config for brand color */
  .bg-brand { background-color: #00d9b1; }
  .text-brand { color: #00d9b1; }
  .ring-brand { --tw-ring-color: #00d9b1; }
</style>
