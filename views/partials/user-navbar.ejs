<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenuDrawer = document.getElementById('mobileMenuDrawer');
    const mobileMenuBackdrop = document.getElementById('mobileMenuBackdrop');

    function openMenu() {
      if (mobileMenuBtn) mobileMenuBtn.classList.add('active');
      if (mobileMenuDrawer) mobileMenuDrawer.classList.add('active');
      if (mobileMenuBackdrop) {
        mobileMenuBackdrop.classList.remove('hidden');
        void mobileMenuBackdrop.offsetWidth; // force reflow
        mobileMenuBackdrop.classList.remove('opacity-0');
        mobileMenuBackdrop.classList.add('opacity-100');
      }
      if (mobileMenuDrawer) {
        mobileMenuDrawer.classList.remove('hidden');
        void mobileMenuDrawer.offsetWidth; // force reflow
        mobileMenuDrawer.style.transform = 'translateX(0)';
      }
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      if (mobileMenuBtn) mobileMenuBtn.classList.remove('active');
      if (mobileMenuDrawer) mobileMenuDrawer.classList.remove('active');
      if (mobileMenuBackdrop) {
        mobileMenuBackdrop.classList.remove('opacity-100');
        mobileMenuBackdrop.classList.add('opacity-0');
      }
      if (mobileMenuDrawer) {
        mobileMenuDrawer.style.transform = 'translateX(100%)';
      }
      document.body.style.overflow = '';
      setTimeout(() => {
        if (mobileMenuBackdrop) mobileMenuBackdrop.classList.add('hidden');
        if (mobileMenuDrawer) mobileMenuDrawer.classList.add('hidden');
      }, 400);
    }

    function toggleMenu() {
      if (mobileMenuBtn) {
        const isOpen = mobileMenuBtn.classList.contains('active');
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      }
    }

    if (mobileMenuBtn && mobileMenuDrawer && mobileMenuBackdrop) {
      mobileMenuBtn.addEventListener('click', toggleMenu);
      mobileMenuBackdrop.addEventListener('click', closeMenu);
    }

    <% if (typeof user !== 'undefined' && user) { %>
      fetchCartCount();
      fetchWishlistCount();
      fetchUserNotifications();
      initializeNotificationSocket();
      fetchUnreadMessageCount();
    <% } %>
  });

  async function fetchCartCount() {
    try {
      const response = await fetch('/user/cart/count');
      const data = await response.json();
      const el = document.getElementById('cartCount');
      if (el) {
        if (data.success && data.count > 0) { el.textContent = data.count; el.classList.remove('hidden'); }
        else { el.classList.add('hidden'); }
      }
    } catch (e) { console.error('Cart count error:', e); }
  }

  async function fetchWishlistCount() {
    try {
      const response = await fetch('/user/wishlist/count');
      const data = await response.json();
      const el = document.getElementById('wishlistCount');
      if (el) {
        if (data.success && data.count > 0) { el.textContent = data.count; el.classList.remove('hidden'); }
        else { el.classList.add('hidden'); }
      }
    } catch (e) { console.error('Wishlist count error:', e); }
  }

  let notifOpen = false;
  function toggleNotificationDropdown(e) {
    e.stopPropagation();
    const dropdown = document.getElementById('notifDropdown');
    notifOpen = !notifOpen;
    if (notifOpen) { dropdown.classList.remove('hidden'); fetchUserNotifications(); }
    else { dropdown.classList.add('hidden'); }
  }

  document.addEventListener('click', () => {
    const dropdown = document.getElementById('notifDropdown');
    if (dropdown) { dropdown.classList.add('hidden'); notifOpen = false; }
  });

  async function fetchUserNotifications() {
    try {
      const response = await fetch('/chat/notifications');
      const data = await response.json();
      if (data.success) updateNotificationUI(data.notifications, data.unreadCount);
    } catch (err) { console.error('Notifications error:', err); }
  }

  function updateNotificationUI(notifications, unreadCount) {
    const badge = document.getElementById('notifBadge');
    if (badge) {
      if (unreadCount > 0) { badge.textContent = unreadCount; badge.classList.remove('hidden'); }
      else { badge.classList.add('hidden'); }
    }
    const list = document.getElementById('notifList');
    if (!list) return;
    if (!notifications || notifications.length === 0) {
      list.innerHTML = `<div class="p-4 text-center text-gray-400">No notifications</div>`;
      return;
    }
    list.innerHTML = notifications.map(n => `
      <div onclick="markNotificationAsRead(event, '${n._id}')" class="p-3 hover:bg-gray-50 cursor-pointer transition flex items-start gap-2 ${n.isRead ? '' : 'bg-blue-50/40'}">
        <div class="flex-1 min-w-0">
          <p class="font-semibold truncate ${n.isRead ? 'text-gray-600' : 'text-blue-900'}">${n.title}</p>
          <p class="text-gray-600 mt-0.5 text-[11px] leading-relaxed break-words">${n.message}</p>
          <span class="text-[9px] text-gray-400 block mt-1">${new Date(n.createdAt).toLocaleDateString()} ${new Date(n.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
        </div>
        ${n.isRead ? '' : '<span class="w-1.5 h-1.5 bg-blue-500 rounded-full mt-1.5 flex-shrink-0"></span>'}
      </div>
    `).join('');
  }

  async function markNotificationAsRead(e, id) {
    e.stopPropagation();
    try { await fetch(`/chat/notifications/${id}/read`, { method: 'POST' }); fetchUserNotifications(); }
    catch (err) { console.error(err); }
  }

  async function markAllNotificationsAsRead(e) {
    e.stopPropagation();
    try { await fetch('/chat/notifications/read-all', { method: 'POST' }); fetchUserNotifications(); }
    catch (err) { console.error(err); }
  }

  async function fetchUnreadMessageCount() {
    try {
      const response = await fetch('/chat/unread-count?role=user');
      const data = await response.json();
      if (data.success) {
        const navbarBadge = document.getElementById('navbarUserChatBadge');
        if (navbarBadge) {
          navbarBadge.textContent = data.count;
          if (data.count > 0) {
            navbarBadge.classList.remove('hidden');
            navbarBadge.classList.add('flex');
          } else {
            navbarBadge.classList.add('hidden');
            navbarBadge.classList.remove('flex');
          }
        }
        const drawerBadge = document.getElementById('mobileDrawerUserChatBadge');
        if (drawerBadge) {
          drawerBadge.textContent = data.count;
          if (data.count > 0) {
            drawerBadge.classList.remove('hidden');
            drawerBadge.classList.add('flex');
          } else {
            drawerBadge.classList.add('hidden');
            drawerBadge.classList.remove('flex');
          }
        }
        const sidebarBadge = document.getElementById('sidebarUserChatBadge');
        if (sidebarBadge) {
          sidebarBadge.textContent = data.count;
          if (data.count > 0) {
            sidebarBadge.classList.remove('hidden');
            sidebarBadge.classList.add('flex');
          } else {
            sidebarBadge.classList.add('hidden');
            sidebarBadge.classList.remove('flex');
          }
        }
      }
    } catch (err) {
      console.error('Error fetching unread message count:', err);
    }
  }

  function initializeNotificationSocket() {
    if (typeof io === 'undefined') {
      const script = document.createElement('script');
      script.src = '/socket.io/socket.io.js';
      script.onload = connectNotifSocket;
      document.head.appendChild(script);
    } else { connectNotifSocket(); }
  }

  function connectNotifSocket() {
    <% if (typeof user !== 'undefined' && user) { %>
      const socket = io({ auth: { userId: '<%= user._id %>', userType: 'user' } });
      socket.on('new_notification', () => { fetchUserNotifications(); });
      socket.on('new_message_notification', () => { fetchUnreadMessageCount(); });
    <% } %>
  }

  window.updateCartCount = fetchCartCount;
  window.updateWishlistCount = fetchWishlistCount;
  window.fetchUnreadMessageCount = fetchUnreadMessageCount;
</script>

