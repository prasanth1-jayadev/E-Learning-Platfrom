<!-- User Profile Sidebar -->
<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
</style>
<aside class="w-full md:w-64 flex-shrink-0 bg-white rounded-2xl shadow-sm p-5">
  <!-- Avatar + Name -->
  <div class="flex flex-col items-center mb-5">
    <div class="relative mb-3">
      <div class="w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center overflow-hidden">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.fullName %>" class="w-full h-full object-cover">
        <% } else { %>
          <svg class="w-9 h-9 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
          </svg>
        <% } %>
      </div>
      <div class="absolute bottom-0 right-0 w-5 h-5 bg-primary rounded-full border-2 border-white flex items-center justify-center">
        <svg class="w-2.5 h-2.5 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12z"/>
        </svg>
      </div>
    </div>
    <p class="font-bold text-gray-900 text-sm text-center"><%= user.fullName %></p>
    <p class="text-xs text-gray-500 text-center mt-1"><%= user.email %></p>
  </div>

  <!-- Nav -->
  <nav class="flex flex-row overflow-x-auto gap-2 md:flex-col md:space-y-1 pb-2 md:pb-0 whitespace-nowrap scrollbar-none">
    <a href="/user/profile" class="flex items-center gap-3 px-3 py-2.5 rounded-xl <%= currentPage === 'profile' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50' %> text-sm font-<%= currentPage === 'profile' ? 'semibold' : 'medium' %> transition">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      Profile
    </a>
    <a href="/user/my-courses" class="flex items-center gap-3 px-3 py-2.5 rounded-xl <%= currentPage === 'my-courses' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50' %> text-sm font-<%= currentPage === 'my-courses' ? 'semibold' : 'medium' %> transition">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
      </svg>
      My Courses
    </a>
    <a href="/user/cart" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
      Shopping Cart
    </a>
    <a href="/user/wishlist" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 text-sm font-medium transition">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
      Wishlist
    </a>
    <a href="/user/chat" class="flex items-center gap-3 px-3 py-2.5 rounded-xl <%= typeof currentPage !== 'undefined' && currentPage === 'chat' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50' %> text-sm font-<%= typeof currentPage !== 'undefined' && currentPage === 'chat' ? 'semibold' : 'medium' %> transition justify-between">
      <div class="flex items-center gap-3">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <span>Chat</span>
      </div>
      <span id="sidebarUserChatBadge" class="bg-red-500 text-white text-[9px] font-bold rounded-full w-4 h-4 flex items-center justify-center hidden">
        0
      </span>
    </a>
    <a href="#" onclick="event.preventDefault(); confirmLogout('/user/logout')" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-red-500 hover:bg-red-50 text-sm font-medium transition mt-2 md:mt-2">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Logout
    </a>
  </nav>
</aside>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function confirmLogout(logoutUrl) {
    Swal.fire({
        title: 'Are you sure?',
        text: 'You will be logged out of your account',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Yes, logout',
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = logoutUrl;
        }
    });
}
</script>
