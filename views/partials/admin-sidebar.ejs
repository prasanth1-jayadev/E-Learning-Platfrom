            <div class="flex flex-col">
                <div class="flex items-center">
                    <span class="text-lg font-bold text-slate-800 dark:text-white">Learn</span>
                    <span class="text-lg font-bold text-[#00d9b1]">ify</span>
                </div>
            </div>
        </div>
        
        <!-- Admin Profile Card -->
        <div class="flex items-center gap-3 p-3 mb-6 bg-slate-50 dark:bg-slate-800/50 rounded-xl">
            <img alt="Admin Avatar" class="w-10 h-10 rounded-full border border-slate-200 dark:border-slate-700" src="https://ui-avatars.com/api/?name=Admin&background=00d9b1&color=fff&bold=true"/>
            <div class="overflow-hidden flex-1">
                <p class="text-sm font-semibold truncate text-slate-800 dark:text-white">Admin</p>
                <a class="text-xs text-[#00d9b1] hover:underline" href="/admin/profile">View Profile</a>
            </div>
        </div>
        
        <nav class="space-y-1">
            <a class="flex items-center gap-3 px-4 py-3 <%= currentPage === 'dashboard' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800' %> rounded-xl transition-all" href="/admin/dashboard">
                <span class="material-icons-outlined text-[20px]">dashboard</span>
                <span class="font-medium">Dashboard</span>
            </a>
            
            <a class="flex items-center gap-3 px-4 py-3 <%= currentPage === 'tutor-applications' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800' %> rounded-xl transition-all" href="/admin/tutor-applications">
