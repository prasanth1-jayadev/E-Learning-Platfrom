            <a class="flex items-center gap-3 px-4 py-3 <%= currentPage === 'categories' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800' %> rounded-xl transition-all" href="/admin/categories">
                <span class="material-icons-outlined text-[20px]">category</span>
                <span class="font-medium">Categories</span>
            </a>
            
            <a class="flex items-center gap-3 px-4 py-3 <%= currentPage === 'courses' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800' %> rounded-xl transition-all" href="/admin/courses">
                <span class="material-icons-outlined text-[20px]">menu_book</span>
                <span class="font-medium">Courses</span>
            </a>
            
            <a class="flex items-center gap-3 px-4 py-3 <%= currentPage === 'coupons' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800' %> rounded-xl transition-all" href="/admin/coupons">
                <span class="material-icons-outlined text-[20px]">local_offer</span>
                <span class="font-medium">Coupons</span>
            </a>
            
            <a class="flex items-center gap-3 px-4 py-3 <%= currentPage === 'sales-report' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800' %> rounded-xl transition-all" href="/admin/sales-report">
