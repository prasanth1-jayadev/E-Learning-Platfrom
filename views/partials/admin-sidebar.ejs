                <span class="font-medium">Tutors</span>
            </a>
            
            <a class="flex items-center gap-3 px-4 py-3 <%= currentPage === 'students' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800' %> rounded-xl transition-all" href="/admin/students">
