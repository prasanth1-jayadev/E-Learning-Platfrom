<!-- Sidebar -->
<aside class="w-60 flex-shrink-0 bg-white rounded-2xl shadow-sm p-5">
  <!-- Profile Section -->
  <div class="flex flex-col items-center mb-8 pb-6 border-b border-gray-100">
