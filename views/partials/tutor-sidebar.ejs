<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function handleLogout(event) {
        event.preventDefault();

        Swal.fire({
            title: 'Logout',
            text: 'Are you sure you want to logout?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#00d9b1',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Yes, logout',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/tutor/logout';
            }
        });
    }

    function showLockedMessage(event) {
        event.preventDefault();

        Swal.fire({
            title: 'Account Pending Approval',
            text: 'Your account is under review. You will have access to all features once the admin approves your account.',
            icon: 'info',
            confirmButtonColor: '#00d9b1',
            confirmButtonText: 'OK'
        });
    }

    // Mobile sidebar toggle logic
    document.addEventListener('DOMContentLoaded', () => {
        const sidebar = document.querySelector('.sidebar');
        const toggleBtn = document.getElementById('tutorSidebarToggle');
        const backdrop = document.getElementById('tutorSidebarBackdrop');

        if (toggleBtn && sidebar && backdrop) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                backdrop.classList.toggle('active');
                if (sidebar.classList.contains('open')) {
                    document.body.style.overflow = 'hidden';
                } else {
                    document.body.style.overflow = '';
                }
            });

            backdrop.addEventListener('click', () => {
                sidebar.classList.remove('open');
                backdrop.classList.remove('active');
                document.body.style.overflow = '';
            });

            // Close sidebar when clicking links inside it (for same page/anchor links or responsiveness)
            const navLinks = sidebar.querySelectorAll('.nav-link');
            navLinks.forEach(link => {
                link.addEventListener('click', () => {
                    if (window.innerWidth < 768) {
                        sidebar.classList.remove('open');
                        backdrop.classList.remove('active');
                        document.body.style.overflow = '';
                    }
                });
            });
        }
    });
</script>

