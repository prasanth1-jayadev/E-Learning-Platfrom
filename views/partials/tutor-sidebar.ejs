<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function handleLogout(event) {
    event.preventDefault();
    
    Swal.fire({
        title: 'Logout',
        text: 'Are you sure you want to logout?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#00d9b1',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, logout',
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = '/tutor/logout';
        }
    });
}

function showLockedMessage(event) {
    event.preventDefault();
    
    Swal.fire({
        title: 'Account Pending Approval',
        text: 'Your account is under review. You will have access to all features once the admin approves your account.',
        icon: 'info',
        confirmButtonColor: '#00d9b1',
        confirmButtonText: 'OK'
    });
}
</script>

<style>
    /* Sidebar Styles */
    .sidebar { 
        width: 260px; 
        background: white; 
        padding: 1.5rem 1rem; 
        display: flex; 
        flex-direction: column; 
        gap: 1.5rem; 
        position: fixed; 
        height: 100vh; 
        overflow-y: auto; 
        border-right: 1px solid #e5e7eb;
        left: 0;
        top: 0;
        z-index: 100;
    }
    .logo { display: flex; align-items: center; gap: 0.5rem; padding: 0 0.5rem; }
    .logo-icon { width: 36px; height: 36px; background: #00d9b1; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 1.25rem; }
    .logo-text { font-weight: 700; font-size: 1.05rem; }
    .profile-section { text-align: center; padding: 1rem 0.5rem; }
    .profile-avatar { width: 70px; height: 70px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); margin: 0 auto 0.75rem; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.75rem; font-weight: 700; }
    .profile-name { font-weight: 600; font-size: 0.95rem; margin-bottom: 0.75rem; line-height: 1.3; }
    .share-profile-btn { background: #f0f0f0; border: none; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.8rem; font-weight: 500; cursor: pointer; transition: background 0.3s; width: 100%; }
    .share-profile-btn:hover { background: #e0e0e0; }
    .nav-menu { list-style: none; }
    .nav-item { margin-bottom: 0.35rem; }
    .nav-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.7rem 0.85rem; text-decoration: none; color: #666; border-radius: 8px; transition: all 0.3s; font-size: 0.9rem; }
    .nav-link:hover { background: #f5f7f6; color: #00d9b1; }
    .nav-link.active { background: #00d9b1; color: white; }
    .nav-link.locked { opacity: 0.5; cursor: not-allowed; }
    .nav-link.locked:hover { background: transparent; color: #666; }
    .nav-link svg { width: 20px; height: 20px; flex-shrink: 0; }
    .help-section { background: #f0f9f6; padding: 1rem; border-radius: 8px; margin-top: auto; }
    .help-section h4 { font-size: 0.9rem; margin-bottom: 0.5rem; }
    .help-section p { font-size: 0.75rem; color: #666; margin-bottom: 0.75rem; line-height: 1.4; }
    .help-btn { background: white; border: 1px solid #00d9b1; color: #00d9b1; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.8rem; font-weight: 500; cursor: pointer; width: 100%; transition: all 0.3s; }
    .help-btn:hover { background: #00d9b1; color: white; }
    
    /* Responsive Breakpoints */
    @media (max-width: 1439px) {
        .sidebar { width: 240px; }
    }
    
    @media (max-width: 1023px) {
        .sidebar { width: 220px; padding: 1.25rem 0.85rem; }
    }
    
    @media (max-width: 899px) {
        .sidebar { width: 200px; padding: 1rem 0.75rem; gap: 1.25rem; }
        .logo-text { font-size: 0.95rem; }
        .profile-avatar { width: 60px; height: 60px; font-size: 1.5rem; }
        .profile-name { font-size: 0.85rem; }
        .nav-link { padding: 0.6rem 0.75rem; font-size: 0.85rem; }
    }
    
    @media (max-width: 767px) {
        .sidebar { 
            position: fixed; 
            left: -260px; 
            transition: left 0.3s ease; 
            z-index: 1000;
            width: 260px;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        }
        .sidebar.open { left: 0; }
    }
</style>
