    #tutorNotifDrawer .clear-all-btn:hover {
        text-decoration: underline;
    }

    #tutorNotifDrawer .close-drawer-btn {
        background: none;
        border: none;
        color: #9ca3af;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2px;
    }

    #tutorNotifDrawer .close-drawer-btn:hover {
        color: #4b5563;
    }

    #tutorNotifDrawer .close-drawer-btn svg {
        width: 20px;
        height: 20px;
    }

    #tutorNotifList {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
    }

    #tutorNotifList .no-notifications {
        padding: 2rem;
        text-align: center;
        color: #9ca3af;
        font-size: 0.875rem;
    }

    #tutorNotifList .notification-item {
        padding: 0.75rem;
        border-radius: 8px;
        margin-bottom: 0.25rem;
        cursor: pointer;
        transition: background-color 0.2s;
        display: flex;
        align-items: start;
        gap: 0.5rem;
        border-bottom: 1px solid #f3f4f6;
        text-align: left;
    }

    #tutorNotifList .notification-item:hover {
        background-color: #f9fafb;
    }

    #tutorNotifList .notification-item.unread {
        background-color: rgba(0, 217, 177, 0.08);
    }

    #tutorNotifList .notification-content {
        flex: 1;
        min-width: 0;
    }

    #tutorNotifList .notification-title {
        margin: 0;
        font-weight: 600;
        color: #1f2937;
        font-size: 0.8rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    #tutorNotifList .notification-message {
        margin: 0.125rem 0 0;
        color: #4b5563;
        font-size: 0.75rem;
        line-height: 1.4;
        word-break: break-word;
    }

    #tutorNotifList .notification-time {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.65rem;
        color: #9ca3af;
    }

    #tutorNotifList .unread-dot {
        width: 6px;
        height: 6px;
        background-color: #00d9b1;
        border-radius: 50%;
        margin-top: 6px;
        flex-shrink: 0;
    }

    .relative {
        position: relative !important;
    }

    #tutorNotifBadge {
        position: absolute;
        top: -8px;
        right: -8px;
        background-color: #ef4444;
        color: white;
        font-size: 8px;
        font-weight: 700;
        border-radius: 50%;
        width: 16px;
        height: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        z-index: 10;
    }
</style>

<!-- Tutor Notification Drawer Panel -->
<div id="tutorNotifDrawer"
    class="fixed top-0 right-0 h-full w-80 bg-white shadow-2xl border-l border-gray-200 z-[999] transform translate-x-full transition-transform duration-300 flex flex-col font-sans">
    <div class="drawer-header p-4 border-b border-gray-150 flex items-center justify-between bg-primary/10">
        <h3 class="font-bold text-gray-800 text-sm">Notifications</h3>
        <div class="header-actions flex items-center gap-3">
            <button onclick="markAllTutorNotificationsAsRead(event)"
                class="clear-all-btn text-xs text-primary hover:underline font-semibold">Clear all</button>
            <button onclick="toggleTutorNotifications(event)"
                class="close-drawer-btn text-gray-400 hover:text-gray-600">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </div>
    <div id="tutorNotifList" class="flex-1 overflow-y-auto divide-y divide-gray-50 p-2 text-xs">
        <div class="p-4 text-center text-gray-400">Loading...</div>
    </div>
</div>

<script>
    let tutorNotifOpen = false;

    function toggleTutorNotifications(e) {
        if (e) e.preventDefault();
        const drawer = document.getElementById('tutorNotifDrawer');
        tutorNotifOpen = !tutorNotifOpen;
        if (tutorNotifOpen) {
            drawer.classList.remove('translate-x-full');
            fetchTutorNotifications();
        } else {
            drawer.classList.add('translate-x-full');
        }
    }

    async function fetchTutorNotifications() {
        try {
            const response = await fetch('/chat/notifications');
            const data = await response.json();
            if (data.success) {
                updateTutorNotifUI(data.notifications, data.unreadCount);
            }
        } catch (err) {
            console.error('Error fetching tutor notifications:', err);
        }
    }

    function updateTutorNotifUI(notifications, unreadCount) {
        const badge = document.getElementById('tutorNotifBadge');
        if (badge) {
            if (unreadCount > 0) {
                badge.textContent = unreadCount;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }

        const list = document.getElementById('tutorNotifList');
        if (!list) return;

        if (!notifications || notifications.length === 0) {
            list.innerHTML = `<div class="no-notifications p-8 text-center text-gray-400">No notifications</div>`;
            return;
        }

        list.innerHTML = notifications.map(n => `
            <div onclick="markTutorNotificationAsRead(event, '${n._id}')" class="notification-item p-3 hover:bg-gray-50 cursor-pointer rounded-lg mb-1 transition flex items-start gap-2 ${n.isRead ? '' : 'unread bg-emerald-50/50'}">
                <div class="notification-content flex-1 min-w-0">
                    <p class="notification-title font-semibold text-gray-800 truncate ${n.isRead ? 'text-gray-650' : 'text-emerald-950'}">${n.title}</p>
                    <p class="notification-message text-gray-600 text-[11px] leading-relaxed mt-0.5 break-words">${n.message}</p>
                    <span class="notification-time text-[9px] text-gray-400 block mt-1">${new Date(n.createdAt).toLocaleDateString()} ${new Date(n.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                </div>
                ${n.isRead ? '' : '<span class="unread-dot w-1.5 h-1.5 bg-primary rounded-full mt-1.5 flex-shrink-0"></span>'}
            </div>
        `).join('');
    }

    async function markTutorNotificationAsRead(e, id) {
        e.stopPropagation();
        try {
            await fetch(`/chat/notifications/${id}/read`, { method: 'POST' });
            fetchTutorNotifications();
        } catch (err) {
            console.error('Error marking tutor notification as read:', err);
        }
    }

    async function markAllTutorNotificationsAsRead(e) {
        e.stopPropagation();
        try {
            await fetch('/chat/notifications/read-all', { method: 'POST' });
            fetchTutorNotifications();
        } catch (err) {
            console.error('Error marking all tutor notifications as read:', err);
        }
    }

    // Load socket.io script dynamically if not present, and connect for tutor
    function initializeTutorNotificationSocket() {
        if (typeof io === 'undefined') {
            const script = document.createElement('script');
            script.src = '/socket.io/socket.io.js';
            script.onload = connectTutorNotifSocket;
            document.head.appendChild(script);
        } else {
            connectTutorNotifSocket();
        }
    }

    function connectTutorNotifSocket() {
        <% if (typeof tutor !== 'undefined' && tutor) { %>
            const socket = io({
        auth: {
            userId: '<%= tutor._id %>',
            userType: 'tutor'
        }
    });
            socket.on('new_notification', () => {
                fetchTutorNotifications();
            });
        <% } %>
    }

    document.addEventListener('DOMContentLoaded', () => {
        <% if (typeof tutor !== 'undefined' && tutor) { %>
            fetchTutorNotifications();
            initializeTutorNotificationSocket();
        <% } %>
    });
</script>